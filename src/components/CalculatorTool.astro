---
import type { Calculator } from '@/data/calculators';
import { groupLabels } from '@/data/calculators';

interface Props {
  calculator: Calculator;
  compact?: boolean;
}

const { calculator, compact = false } = Astro.props;
const presetsBySlug: Record<string, Array<{ label: string; values: Record<string, number | string> }>> = {
  'seller-margin': [
    { label: '스마트스토어 소형 상품', values: { price: 29900, cost: 12000, platformFee: 5.6, paymentFee: 3.3, shipping: 3000, adCost: 1200, returnRate: 2 } },
    { label: '광고비 높은 신상품', values: { price: 39900, cost: 18500, platformFee: 10.8, paymentFee: 3.3, shipping: 3500, adCost: 4500, returnRate: 5 } }
  ],
  'break-even-price': [
    { label: '저마진 생활용품', values: { cost: 9000, fixedCost: 3600, feeRate: 12, targetMargin: 18 } },
    { label: '브랜드 상품 목표가', values: { cost: 28000, fixedCost: 6200, feeRate: 14, targetMargin: 30 } }
  ],
  'ad-roas-limit': [
    { label: '검색광고 시작 전', values: { price: 34900, cost: 16000, feeRate: 13.5, shipping: 3500, targetProfit: 5000 } },
    { label: '마진 낮은 상품 점검', values: { price: 21900, cost: 11000, feeRate: 14, shipping: 3200, targetProfit: 3500 } }
  ],
  'return-loss': [
    { label: '반품 적은 생활용품', values: { orders: 120, profitPerOrder: 7200, returnRate: 3, lossPerReturn: 8000 } },
    { label: '의류/사이즈 반품 많음', values: { orders: 180, profitPerOrder: 9200, returnRate: 12, lossPerReturn: 13000 } }
  ],
  'platform-fee-compare': [
    { label: '스마트스토어 vs 자사몰', values: { price: 39900, orders: 200, feeA: 5.6, feeB: 3.3, fixedB: 99000 } },
    { label: '마켓 vs 저수수료 채널', values: { price: 45900, orders: 350, feeA: 13, feeB: 7, fixedB: 55000 } }
  ],
  'vat-profit': [
    { label: '부가세 포함 판매가', values: { grossPrice: 55000, cost: 26000, expense: 8000, vatRate: 10 } },
    { label: 'B2B 납품가 확인', values: { grossPrice: 220000, cost: 135000, expense: 26000, vatRate: 10 } }
  ],
  'discount-margin': [
    { label: '15% 쿠폰 행사', values: { regularPrice: 39900, discountRate: 15, cost: 17000, feeRate: 13.5, shipping: 3500, adCost: 1500 } },
    { label: '시즌오프 30%', values: { regularPrice: 69000, discountRate: 30, cost: 31000, feeRate: 12.5, shipping: 3500, adCost: 2500 } }
  ],
  'coupon-burden': [
    { label: '반반 부담 쿠폰', values: { price: 45900, coupon: 5000, sellerBurdenRate: 50, cost: 21000, feeRate: 12.5, shipping: 3500 } },
    { label: '판매자 전액 부담', values: { price: 32900, coupon: 4000, sellerBurdenRate: 100, cost: 14500, feeRate: 13, shipping: 3200 } }
  ],
  'bundle-shipping-profit': [
    { label: '3개 묶음 구매', values: { price: 12900, cost: 5200, quantity: 3, feeRate: 13, shippingCharge: 3000, actualShipping: 4200 } },
    { label: '무료배송 묶음', values: { price: 18900, cost: 7600, quantity: 2, feeRate: 12, shippingCharge: 0, actualShipping: 3800 } }
  ],
  'subscription-cut': [
    { label: 'OTT/앱 구독 정리', values: { monthlyTotal: 89000, cutRate: 35, newService: 12000 } },
    { label: '업무툴 비용 점검', values: { monthlyTotal: 180000, cutRate: 25, newService: 35000 } }
  ],
  'internet-switch': [
    { label: '3년 약정 갈아타기', values: { penalty: 180000, reward: 420000, oldMonthly: 42000, newMonthly: 36000, months: 36 } },
    { label: '위약금 큰 상황', values: { penalty: 360000, reward: 450000, oldMonthly: 39000, newMonthly: 33000, months: 24 } }
  ],
  'rental-total-cost': [
    { label: '정수기 3년 약정', values: { monthly: 29900, months: 36, install: 0, reward: 150000 } },
    { label: '비데/공청기 묶음', values: { monthly: 49900, months: 60, install: 50000, reward: 300000 } }
  ],
  'electricity-cost': [
    { label: '에어컨 하루 6시간', values: { watt: 900, hours: 6, days: 30, rate: 180 } },
    { label: '전기히터 집중 사용', values: { watt: 1800, hours: 5, days: 25, rate: 220 } }
  ],
  'moving-cost': [
    { label: '원룸/소형 이사', values: { base: 350000, options: 80000, cleaning: 150000, brokerage: 250000, bufferRate: 10 } },
    { label: '가족 이사 예산', values: { base: 1200000, options: 280000, cleaning: 350000, brokerage: 800000, bufferRate: 12 } }
  ],
  'card-installment': [
    { label: '가전 12개월 할부', values: { price: 1200000, months: 12, annualRate: 8.5, upfrontFee: 0 } },
    { label: '무이자 할부 확인', values: { price: 800000, months: 6, annualRate: 0, upfrontFee: 0 } }
  ],
  'commute-fuel-cost': [
    { label: '자가용 출퇴근', values: { distance: 36, days: 22, fuelEconomy: 11, fuelPrice: 1680, parking: 0 } },
    { label: '주차비 포함', values: { distance: 52, days: 20, fuelEconomy: 9.5, fuelPrice: 1720, parking: 80000 } }
  ],
  'savings-maturity': [
    { label: '월 30만원 2년', values: { monthlyDeposit: 300000, months: 24, annualRate: 3.8, taxRate: 15.4 } },
    { label: '월 100만원 1년', values: { monthlyDeposit: 1000000, months: 12, annualRate: 4.2, taxRate: 15.4 } }
  ],
  'loan-interest': [
    { label: '주담대 30년 원리금', values: { principal: 300000000, annualRate: 4.2, years: 30, repaymentType: 'equal-payment' } },
    { label: '신용대출 5년 원금균등', values: { principal: 50000000, annualRate: 5.8, years: 5, repaymentType: 'equal-principal' } }
  ],
  'deposit-interest': [
    { label: '1천만원 1년 예금', values: { principal: 10000000, months: 12, annualRate: 3.6, taxRate: 15.4 } },
    { label: '5천만원 6개월 예금', values: { principal: 50000000, months: 6, annualRate: 3.4, taxRate: 15.4 } }
  ],
  'loan-affordability': [
    { label: '월 70만원 부담', values: { monthlyPayment: 700000, annualRate: 4.5, years: 30, income: 3500000 } },
    { label: '맞벌이 월 180만원', values: { monthlyPayment: 1800000, annualRate: 4.2, years: 30, income: 8000000 } }
  ],
  'payback-period': [
    { label: '장비 구매 회수', values: { initialCost: 5000000, monthlyRevenue: 900000, monthlyCost: 350000, resaleValue: 500000 } },
    { label: '광고/외주 투자', values: { initialCost: 2500000, monthlyRevenue: 650000, monthlyCost: 180000, resaleValue: 0 } }
  ],
  'hourly-rate': [
    { label: '부업 월수익 점검', values: { revenue: 3000000, expense: 1200000, hours: 120, taxRate: 10 } },
    { label: '프리랜서 단가 점검', values: { revenue: 6500000, expense: 1800000, hours: 150, taxRate: 18 } }
  ]
};
const presets = presetsBySlug[calculator.slug] ?? [];
---
<section
  class={`calculator-tool ${compact ? 'compact-tool' : ''}`}
  data-calculator={calculator.slug}
  data-calculator-title={calculator.shortTitle}
  data-calculator-group={groupLabels[calculator.group]}
  data-calculator-href={`/calculators/${calculator.slug}/`}
>
  <div class="tool-form">
    <div class="tool-heading">
      <div>
        <span class="tool-kicker">입력값</span>
        <h2>{calculator.title}</h2>
        <p>{calculator.description}</p>
      </div>
      <button type="button" data-reset>초기값</button>
    </div>
    {presets.length > 0 && (
      <div class="preset-panel" aria-label="추천 입력값">
        <strong>추천 입력값</strong>
        <div>
          {presets.map((preset) => (
            <button type="button" data-preset-values={JSON.stringify(preset.values)}>{preset.label}</button>
          ))}
        </div>
      </div>
    )}
    <div class="input-grid">
      {calculator.inputs.map((input) => (
        <label>
          <span>{input.label}</span>
          <div class="input-wrap">
            {input.type === 'select' ? (
              <select data-calc-input data-default={input.value} name={input.key}>
                {(input.options ?? []).map((option) => (
                  <option value={option.value} selected={option.value === input.value}>{option.label}</option>
                ))}
              </select>
            ) : (
              <input
                data-calc-input
                data-default={input.value}
                name={input.key}
                type="number"
                value={input.value}
                min={input.min}
                max={input.max}
                step={input.step ?? 1}
              />
            )}
            {input.suffix && <em>{input.suffix}</em>}
          </div>
        </label>
      ))}
    </div>
  </div>
  <aside class="result-panel" aria-live="polite">
    <div class="result-head">
      <span data-result-status>계산 중</span>
      <p data-result-primary-label>결과</p>
    </div>
    <strong data-result-primary>0원</strong>
    <div class="metric-list" data-result-metrics></div>
    <div class="schedule-wrap" data-result-schedule hidden></div>
    <p class="result-note" data-result-note></p>
    <div class="result-actions">
      <button type="button" data-result-copy>결과 복사</button>
      <button type="button" data-share-link>공유 링크</button>
      <button type="button" data-favorite-toggle aria-pressed="false">즐겨찾기</button>
      <span data-result-feedback aria-live="polite"></span>
    </div>
    <p class="result-caption">입력값은 이 브라우저에 자동 저장되고, 바꾸면 바로 다시 계산됩니다.</p>
  </aside>
</section>

<style>
  .calculator-tool {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.82fr);
    gap: 20px;
    align-items: start;
  }
  .tool-form,
  .result-panel {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    box-shadow: var(--shadow-sm);
  }
  .tool-form {
    padding: 24px;
    backdrop-filter: blur(10px);
  }
  .tool-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 22px;
    padding-bottom: 18px;
    border-bottom: 1px solid #edf1ef;
  }
  .tool-heading h2 {
    margin: 0 0 6px;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: clamp(1.18rem, 1.6vw, 1.55rem);
    line-height: 1.28;
    letter-spacing: 0;
    color: var(--ink);
  }
  .tool-kicker {
    display: block;
    margin-bottom: 7px;
    color: var(--green);
    font: 900 0.78rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-heading p {
    margin: 0;
    max-width: 620px;
    color: var(--muted);
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.94rem;
    line-height: 1.6;
  }
  .tool-heading button {
    min-width: 72px;
    border: 1px solid #cfd8d3;
    border-radius: 8px;
    background: #fff;
    color: #2e4239;
    font-weight: 800;
    font-size: 0.82rem;
    padding: 8px 10px;
    cursor: pointer;
  }
  .tool-heading button:hover {
    border-color: #91b8a4;
    background: #f3faf6;
  }
  .preset-panel {
    display: grid;
    gap: 10px;
    margin-bottom: 18px;
    border: 1px solid #dce5e0;
    border-radius: 8px;
    background: linear-gradient(180deg, #fbfdfc, #f4f8f6);
    padding: 14px;
  }
  .preset-panel strong {
    color: #33443c;
    font: 900 0.84rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .preset-panel div {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .preset-panel button {
    min-height: 34px;
    border: 1px solid #cfd8d3;
    border-radius: 8px;
    background: #fff;
    color: #1c2a23;
    padding: 0 11px;
    font: 900 0.8rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    cursor: pointer;
  }
  .preset-panel button:hover {
    border-color: var(--green);
    background: var(--green-soft);
    color: var(--green-strong);
  }
  .input-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 12px;
  }
  label {
    display: grid;
    gap: 8px;
    min-width: 0;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    color: #33443c;
  }
  .input-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    min-height: 48px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
  }
  input,
  select {
    width: 100%;
    min-width: 0;
    border: 0;
    background: transparent;
    color: var(--ink);
    font: 800 1rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 14px 12px;
    outline: none;
  }
  select {
    appearance: none;
    cursor: pointer;
  }
  .input-wrap:focus-within {
    border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(22, 130, 79, 0.12);
  }
  em {
    padding-right: 12px;
    color: var(--subtle);
    font-style: normal;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .result-panel {
    padding: 24px;
    color: #f6fbf8;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    position: sticky;
    top: 96px;
    overflow: hidden;
    border-color: rgba(16, 35, 27, 0.22);
    background:
      radial-gradient(circle at 100% 0, rgba(142, 242, 188, 0.16), transparent 32%),
      linear-gradient(180deg, #123025, #0e2119);
    box-shadow: var(--shadow-lg);
  }
  .result-panel::before {
    content: "";
    display: block;
    height: 4px;
    margin: -24px -24px 20px;
    background: #8ef2bc;
  }
  .result-panel[data-tone="warn"]::before { background: #d98716; }
  .result-panel[data-tone="bad"]::before { background: #c83b3b; }
  .result-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 12px;
  }
  .result-head span {
    border-radius: 999px;
    background: rgba(142, 242, 188, 0.14);
    color: #b7ffd3;
    border: 1px solid rgba(142, 242, 188, 0.26);
    padding: 6px 10px;
    font: 800 0.78rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .result-panel[data-tone="warn"] .result-head span {
    background: #fff5e8;
    border-color: #f1d4aa;
    color: #a35c00;
  }
  .result-panel[data-tone="bad"] .result-head span {
    background: #fff0ef;
    border-color: #efc4c0;
    color: #aa2e2e;
  }
  .result-head p {
    margin: 0;
    color: rgba(246, 251, 248, 0.64);
    font: 800 0.9rem/1.3 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    text-align: right;
  }
  [data-result-primary] {
    display: block;
    font: 950 clamp(1.8rem, 3.3vw, 3rem)/1.08 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
    margin-bottom: 20px;
    color: #8ef2bc;
    word-break: keep-all;
  }
  .result-panel[data-tone="warn"] [data-result-primary] { color: #ffd89a; }
  .result-panel[data-tone="bad"] [data-result-primary] { color: #ffb2a9; }
  .metric-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  :global(.calculator-tool .metric-row) {
    display: grid;
    gap: 5px;
    padding: 12px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.065);
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  :global(.calculator-tool .metric-row span) {
    color: rgba(246, 251, 248, 0.64);
    font-size: 0.8rem;
    font-weight: 800;
  }
  :global(.calculator-tool .metric-row strong) {
    color: #f6fbf8;
    font-size: 0.98rem;
    line-height: 1.25;
  }
  .schedule-wrap {
    margin-top: 18px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.06);
    overflow-x: auto;
  }
  :global(.calculator-tool .schedule-wrap h3) {
    margin: 0;
    padding: 14px 14px 0;
    color: #f6fbf8;
    font: 900 0.95rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    position: sticky;
    left: 0;
  }
  :global(.calculator-tool .schedule-table) {
    width: 100%;
    min-width: 520px;
    border-collapse: collapse;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.8rem;
  }
  :global(.calculator-tool .schedule-table th),
  :global(.calculator-tool .schedule-table td) {
    padding: 10px 12px;
    border-bottom: 1px solid #e7eeea;
    text-align: right;
    white-space: nowrap;
  }
  :global(.calculator-tool .schedule-table th:first-child),
  :global(.calculator-tool .schedule-table td:first-child) {
    text-align: left;
  }
  :global(.calculator-tool .schedule-table th) {
    color: rgba(246, 251, 248, 0.7);
    font-weight: 900;
    background: rgba(255, 255, 255, 0.08);
    position: sticky;
    top: 0;
  }
  :global(.calculator-tool .schedule-table td) {
    color: #f6fbf8;
    font-weight: 800;
  }
  :global(.calculator-tool .schedule-note) {
    margin: 0;
    padding: 10px 14px 14px;
    color: rgba(246, 251, 248, 0.68);
    font: 700 0.78rem/1.45 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .result-note {
    margin: 18px 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 20px;
    color: rgba(246, 251, 248, 0.72);
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .result-caption {
    margin: 12px 0 0;
    color: rgba(246, 251, 248, 0.56);
    font: 700 0.78rem/1.45 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .result-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 16px;
  }
  .result-actions button {
    min-height: 36px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.09);
    color: #f6fbf8;
    padding: 0 12px;
    font: 900 0.84rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    cursor: pointer;
  }
  .result-actions button:hover {
    border-color: rgba(142, 242, 188, 0.42);
    background: rgba(142, 242, 188, 0.14);
    color: #b7ffd3;
  }
  .result-actions button[aria-pressed="true"] {
    border-color: #8ef2bc;
    background: #8ef2bc;
    color: #0e2119;
  }
  .result-actions span {
    color: rgba(246, 251, 248, 0.68);
    font: 800 0.78rem/1.35 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .compact-tool {
    grid-template-columns: 1fr;
  }
  @media (max-width: 860px) {
    .calculator-tool {
      grid-template-columns: 1fr;
    }
    .result-panel {
      position: static;
    }
  }
  @media (max-width: 620px) {
    .tool-form,
    .result-panel {
      padding: 16px;
    }
    .tool-heading {
      display: grid;
    }
    .input-grid {
      grid-template-columns: 1fr;
    }
    .metric-list {
      grid-template-columns: 1fr;
    }
  }
</style>
