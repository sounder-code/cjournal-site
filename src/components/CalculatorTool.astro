---
import type { Calculator } from '@/data/calculators';

interface Props {
  calculator: Calculator;
  compact?: boolean;
}

const { calculator, compact = false } = Astro.props;
---
<section class={`calculator-tool ${compact ? 'compact-tool' : ''}`} data-calculator={calculator.slug}>
  <div class="tool-form">
    <div class="tool-heading">
      <div>
        <h2>{calculator.title}</h2>
        <p>{calculator.description}</p>
      </div>
      <button type="button" data-reset>초기값</button>
    </div>
    <div class="input-grid">
      {calculator.inputs.map((input) => (
        <label>
          <span>{input.label}</span>
          <div class="input-wrap">
            {input.type === 'select' ? (
              <select data-calc-input data-default={input.value} name={input.key}>
                {(input.options ?? []).map((option) => (
                  <option value={option.value} selected={option.value === input.value}>{option.label}</option>
                ))}
              </select>
            ) : (
              <input
                data-calc-input
                data-default={input.value}
                name={input.key}
                type="number"
                value={input.value}
                min={input.min}
                max={input.max}
                step={input.step ?? 1}
              />
            )}
            {input.suffix && <em>{input.suffix}</em>}
          </div>
        </label>
      ))}
    </div>
  </div>
  <aside class="result-panel" aria-live="polite">
    <div class="result-head">
      <span data-result-status>계산 중</span>
      <p data-result-primary-label>결과</p>
    </div>
    <strong data-result-primary>0원</strong>
    <div class="metric-list" data-result-metrics></div>
    <div class="schedule-wrap" data-result-schedule hidden></div>
    <p class="result-note" data-result-note></p>
  </aside>
</section>

<style>
  .calculator-tool {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.82fr);
    gap: 18px;
    align-items: start;
  }
  .tool-form,
  .result-panel {
    border: 1px solid #d6ddd9;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .tool-form { padding: 24px; }
  .tool-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 22px;
    padding-bottom: 18px;
    border-bottom: 1px solid #edf1ef;
  }
  .tool-heading h2 {
    margin: 0 0 6px;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: clamp(1.18rem, 1.6vw, 1.55rem);
    line-height: 1.28;
    letter-spacing: 0;
    color: #1c2a23;
  }
  .tool-heading p {
    margin: 0;
    max-width: 620px;
    color: #66736d;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.94rem;
    line-height: 1.6;
  }
  .tool-heading button {
    min-width: 72px;
    border: 1px solid #cfd8d3;
    border-radius: 8px;
    background: #fff;
    color: #2e4239;
    font-weight: 800;
    font-size: 0.82rem;
    padding: 8px 10px;
    cursor: pointer;
  }
  .tool-heading button:hover {
    border-color: #91b8a4;
    background: #f3faf6;
  }
  .input-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 12px;
  }
  label {
    display: grid;
    gap: 8px;
    min-width: 0;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    color: #33443c;
  }
  .input-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    min-height: 48px;
    border: 1px solid #ccd6d1;
    border-radius: 8px;
    background: #fff;
    overflow: hidden;
  }
  input,
  select {
    width: 100%;
    min-width: 0;
    border: 0;
    background: transparent;
    color: #1c2a23;
    font: 800 1rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 14px 12px;
    outline: none;
  }
  select {
    appearance: none;
    cursor: pointer;
  }
  .input-wrap:focus-within {
    border-color: #16824f;
    box-shadow: 0 0 0 3px rgba(22, 130, 79, 0.12);
  }
  em {
    padding-right: 12px;
    color: #74817b;
    font-style: normal;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .result-panel {
    padding: 24px;
    color: #1c2a23;
    display: flex;
    flex-direction: column;
    min-height: 100%;
    position: sticky;
    top: 96px;
  }
  .result-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 12px;
  }
  .result-head span {
    border-radius: 999px;
    background: #edf8f2;
    color: #137047;
    border: 1px solid #cce8d8;
    padding: 6px 10px;
    font: 800 0.78rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .result-head p {
    margin: 0;
    color: #66736d;
    font: 800 0.9rem/1.3 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    text-align: right;
  }
  [data-result-primary] {
    display: block;
    font: 950 clamp(1.8rem, 3.3vw, 3rem)/1.08 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
    margin-bottom: 20px;
    color: #0f6c43;
    word-break: keep-all;
  }
  .metric-list {
    display: grid;
    gap: 0;
    border-top: 1px solid #edf1ef;
  }
  .metric-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid #edf1ef;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .metric-row span { color: #66736d; }
  .metric-row strong {
    color: #1c2a23;
    text-align: right;
  }
  .schedule-wrap {
    margin-top: 18px;
    border: 1px solid #dce5e0;
    border-radius: 8px;
    background: #fbfdfc;
    overflow-x: auto;
  }
  .schedule-wrap h3 {
    margin: 0;
    padding: 14px 14px 0;
    color: #1c2a23;
    font: 900 0.95rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .schedule-table {
    width: 100%;
    min-width: 520px;
    border-collapse: collapse;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.8rem;
  }
  .schedule-table th,
  .schedule-table td {
    padding: 10px 12px;
    border-bottom: 1px solid #e7eeea;
    text-align: right;
    white-space: nowrap;
  }
  .schedule-table th:first-child,
  .schedule-table td:first-child {
    text-align: left;
  }
  .schedule-table th {
    color: #66736d;
    font-weight: 900;
    background: #f4f8f6;
  }
  .schedule-table td {
    color: #26372f;
    font-weight: 800;
  }
  .schedule-note {
    margin: 0;
    padding: 10px 14px 14px;
    color: #66736d;
    font: 700 0.78rem/1.45 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .result-note {
    margin: auto 0 0;
    padding-top: 20px;
    color: #66736d;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .compact-tool {
    grid-template-columns: 1fr;
  }
  @media (max-width: 860px) {
    .calculator-tool {
      grid-template-columns: 1fr;
    }
    .result-panel {
      position: static;
    }
  }
  @media (max-width: 620px) {
    .tool-form,
    .result-panel {
      padding: 16px;
    }
    .tool-heading {
      display: grid;
    }
    .input-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
