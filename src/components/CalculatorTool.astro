---
import type { Calculator } from '@/data/calculators';

interface Props {
  calculator: Calculator;
  compact?: boolean;
}

const { calculator, compact = false } = Astro.props;
---
<section class={`calculator-tool ${compact ? 'compact-tool' : ''}`} data-calculator={calculator.slug}>
  <div class="tool-form">
    <div class="tool-heading">
      <div>
        <h2>{calculator.title}</h2>
        <p>{calculator.description}</p>
      </div>
      <button type="button" data-reset>초기값</button>
    </div>
    <div class="input-grid">
      {calculator.inputs.map((input) => (
        <label>
          <span>{input.label}</span>
          <div class="input-wrap">
            <input
              data-calc-input
              data-default={input.value}
              name={input.key}
              type="number"
              value={input.value}
              min={input.min}
              max={input.max}
              step={input.step ?? 1}
            />
            <em>{input.suffix}</em>
          </div>
        </label>
      ))}
    </div>
  </div>
  <aside class="result-panel">
    <div class="status-line">
      <span data-result-status>계산 중</span>
    </div>
    <p data-result-primary-label>결과</p>
    <strong data-result-primary>0원</strong>
    <div class="metric-list" data-result-metrics></div>
    <p class="result-note" data-result-note></p>
  </aside>
</section>

<style>
  .calculator-tool {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(300px, 0.75fr);
    gap: 16px;
    align-items: stretch;
  }
  .tool-form,
  .result-panel {
    border: 1px solid #d8e2dc;
    border-radius: 8px;
    background: #fff;
  }
  .tool-form { padding: 22px; }
  .tool-heading {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
    margin-bottom: 20px;
  }
  .tool-heading h2 {
    margin: 0 0 6px;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: clamp(1.25rem, 2vw, 1.85rem);
    line-height: 1.25;
    letter-spacing: 0;
    color: #10221c;
  }
  .tool-heading p {
    margin: 0;
    max-width: 620px;
    color: #5d6964;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    line-height: 1.55;
  }
  .tool-heading button {
    min-width: 72px;
    border: 1px solid #cbd8d2;
    border-radius: 8px;
    background: #f8fbf9;
    color: #223a31;
    font-weight: 800;
    font-size: 0.82rem;
    padding: 8px 10px;
    cursor: pointer;
  }
  .input-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }
  label {
    display: grid;
    gap: 7px;
    min-width: 0;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-size: 0.88rem;
    font-weight: 800;
    color: #2c3a35;
  }
  .input-wrap {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    border: 1px solid #cfdbd5;
    border-radius: 8px;
    background: #fbfdfc;
    overflow: hidden;
  }
  input {
    width: 100%;
    min-width: 0;
    border: 0;
    background: transparent;
    color: #10221c;
    font: 800 1rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 13px 12px;
    outline: none;
  }
  .input-wrap:focus-within {
    border-color: #1e7a55;
    box-shadow: 0 0 0 3px rgba(30, 122, 85, 0.1);
  }
  em {
    padding-right: 12px;
    color: #6b7772;
    font-style: normal;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  .result-panel {
    padding: 22px;
    background: #10221c;
    color: #fff;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }
  .status-line {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 28px;
  }
  .status-line span {
    border-radius: 999px;
    background: rgba(127, 221, 168, 0.13);
    color: #9bf0be;
    border: 1px solid rgba(155, 240, 190, 0.28);
    padding: 5px 10px;
    font: 800 0.78rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .result-panel > p:first-of-type {
    margin: 0 0 8px;
    color: #a8bbb3;
    font: 800 0.9rem/1.3 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  [data-result-primary] {
    display: block;
    font: 900 clamp(2rem, 4vw, 3.4rem)/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
    margin-bottom: 26px;
  }
  .metric-list {
    display: grid;
    gap: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.14);
  }
  .metric-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .metric-row span { color: #a8bbb3; }
  .metric-row strong {
    color: #fff;
    text-align: right;
  }
  .result-note {
    margin: auto 0 0;
    padding-top: 20px;
    color: #d5e2dc;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    line-height: 1.55;
  }
  .compact-tool {
    grid-template-columns: 1fr;
  }
  @media (max-width: 860px) {
    .calculator-tool {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 620px) {
    .tool-form,
    .result-panel {
      padding: 16px;
    }
    .tool-heading {
      display: grid;
    }
    .input-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
