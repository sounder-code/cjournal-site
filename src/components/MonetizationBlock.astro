---
import { getOffersForPost } from '@/lib/monetization';

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      tags: string[];
      category?: string;
    };
  };
}

const { post } = Astro.props;
const offers = getOffersForPost(post, 2);
---
{
  offers.length > 0 && (
    <section class="monetization-block" aria-label="추천 도구">
      <h2>추천 도구</h2>
      <p class="notice">아래 링크는 제휴 링크일 수 있으며, 운영에 도움이 되는 수수료를 받을 수 있습니다.</p>
      <div class="offer-list">
        {offers.map((offer) => (
          <a
            class="offer-item"
            href={offer.url}
            target="_blank"
            rel="noopener sponsored nofollow"
            data-affiliate-link="true"
            data-offer-id={offer.id}
            data-offer-title={offer.title}
            data-post-slug={post.slug}
          >
            <strong>{offer.title}</strong>
            <span>{offer.description}</span>
          </a>
        ))}
      </div>
    </section>
  )
}

<style>
  .monetization-block {
    margin: 20px 0;
    padding: 16px;
    border: 1px solid #dadad6;
    background: #fff;
  }

  .monetization-block h2 {
    margin: 0 0 6px;
    font-size: 1.05rem;
  }

  .notice {
    margin: 0 0 10px;
    font-size: 0.88rem;
    color: #525252;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }

  .offer-list {
    display: grid;
    gap: 10px;
  }

  .offer-item {
    display: grid;
    gap: 4px;
    text-decoration: none;
    border: 1px solid #cfd8e4;
    padding: 10px 12px;
    color: #1c2d45;
    background: #f8fbff;
  }

  .offer-item strong {
    color: #11375f;
    font-size: 0.96rem;
  }

  .offer-item span {
    color: #33475f;
    font-size: 0.9rem;
  }

  .offer-item:hover {
    border-color: #9fb6d2;
    background: #f0f6fd;
  }
</style>
