---
const today = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'short'
}).format(new Date());
---
<header class="site-header">
  <div class="container header-inner">
    <div class="masthead">
      <a href="/" class="logo"><span aria-hidden="true"></span>바로계산</a>
      <p class="edition">생활 계산기 모음</p>
    </div>
    <nav aria-label="주요 계산기">
      <a href="/calculators/">계산기 찾기</a>
      <a href="/#seller">마진·판매</a>
      <a href="/#living">생활비</a>
      <a href="/#utility">금융·시간</a>
      <a href="/#housing">주거</a>
      <a href="/#work">급여·세금</a>
      <a href="/#health">건강</a>
      <a href="/news">계산 가이드</a>
      <a href="/editorial-policy">운영 원칙</a>
      <a href="/contact">문의</a>
      <a href="/about">소개</a>
    </nav>
    <div class="today">{today}</div>
    </div>
</header>

<style>
  .header-inner {
    min-height: 68px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
  }
  .masthead { display: grid; gap: 3px; }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
  }
  .logo span {
    display: inline-grid;
    place-items: center;
    width: 27px;
    height: 27px;
    border-radius: 8px;
    background: var(--green-strong);
    color: #ffffff;
    box-shadow: 0 10px 22px rgba(16, 21, 19, 0.14);
  }
  .logo span::before,
  .logo span::after {
    content: "";
    width: 12px;
    height: 2px;
    border-radius: 999px;
    background: #ffffff;
    grid-area: 1 / 1;
  }
  .logo span::before { transform: translateY(-4px); }
  .logo span::after { transform: translateY(4px); }
  .edition {
    margin: 0;
    color: #75837d;
    font-size: 0.75rem;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-weight: 700;
  }
  nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
    justify-content: flex-end;
    min-width: 0;
  }
  nav a {
    border-radius: 8px;
    padding: 8px 10px;
    font-size: 0.82rem;
    white-space: nowrap;
  }
  nav a:hover {
    background: var(--blue-soft);
    color: var(--blue);
  }
  .today {
    color: #7c8882;
    font: 800 0.76rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    white-space: nowrap;
  }
  @media (max-width: 1120px) {
    .today { display: none; }
    .header-inner {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }
  @media (max-width: 768px) {
    .header-inner {
      display: grid;
      grid-template-columns: 1fr;
      gap: 8px;
      padding-bottom: 10px;
    }
    nav {
      justify-content: flex-start;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-bottom: 2px;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    nav::-webkit-scrollbar {
      display: none;
    }
    nav a {
      flex: 0 0 auto;
      border: 1px solid var(--line);
      background: #fff;
      padding: 8px 10px;
    }
  }
</style>
