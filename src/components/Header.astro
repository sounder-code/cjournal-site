---
const pathname = Astro.url.pathname;
const navItems = [
  ['관리비 지도', '/map/'],
  ['단지 찾기', '/apartments/'],
  ['생활 계산기', '/calculators/'],
  ['관리비 가이드', '/management-fee-guide/']
];

const isActive = (href: string) =>
  href === '/map/' ? pathname === '/' || pathname.startsWith('/map') : pathname.startsWith(href);
---
<header class="site-header">
  <div class="app-header">
    <a href="/map/" class="brand" aria-label="바로계산 관리비 지도">
      <span class="brand-mark" aria-hidden="true"><i></i></span>
      <span class="brand-name">바로계산</span>
      <span class="brand-product">관리비</span>
    </a>

    <nav class="primary-nav" aria-label="주요 메뉴">
      {navItems.map(([label, href]) => (
        <a href={href} class={isActive(href) ? 'active' : ''}>{label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <a href="/methodology">산정 기준</a>
      <a href="/contact">문의</a>
    </div>
  </div>
</header>

<style>
  :global(.site-header) {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid #e4e7e5;
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: blur(12px);
  }
  .app-header {
    width: min(1480px, calc(100vw - 40px));
    min-height: 60px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    align-items: center;
    gap: 38px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: #151917;
    text-decoration: none;
    white-space: nowrap;
  }
  .brand-mark {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 7px;
    background: #13795b;
  }
  .brand-mark i {
    width: 12px;
    height: 12px;
    border: 3px solid #fff;
    border-radius: 50%;
  }
  .brand-name {
    font-size: 1.08rem;
    font-weight: 800;
  }
  .brand-product {
    color: #6a726e;
    font-size: 0.78rem;
    font-weight: 650;
  }
  .primary-nav {
    display: flex;
    align-items: center;
    gap: 30px;
    height: 60px;
  }
  .primary-nav a {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 60px;
    color: #59615d;
    text-decoration: none;
    font-size: 0.86rem;
    font-weight: 650;
  }
  .primary-nav a:hover,
  .primary-nav a.active {
    color: #111513;
  }
  .primary-nav a.active::after {
    content: '';
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 2px;
    background: #13795b;
  }
  .header-actions {
    display: flex;
    gap: 18px;
  }
  .header-actions a {
    color: #707873;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
  }
  @media (max-width: 760px) {
    .app-header {
      width: calc(100vw - 24px);
      grid-template-columns: 1fr auto;
      gap: 10px;
    }
    .brand-product,
    .header-actions {
      display: none;
    }
    .primary-nav {
      justify-content: flex-end;
      gap: 16px;
      overflow-x: auto;
    }
    .primary-nav a {
      font-size: 0.78rem;
      white-space: nowrap;
    }
    .primary-nav { scrollbar-width: none; }
    .primary-nav::-webkit-scrollbar { display: none; }
  }
  @media (max-width: 480px) {
    .app-header {
      min-height: 94px;
      grid-template-columns: 1fr;
      grid-template-rows: 44px 50px;
      gap: 0;
    }
    .brand { justify-self: start; }
    .brand-mark { width: 26px; height: 26px; }
    .brand-name { font-size: 1rem; }
    .primary-nav {
      width: 100%;
      height: 50px;
      justify-content: flex-start;
      gap: 24px;
    }
    .primary-nav a { height: 50px; }
  }
</style>
