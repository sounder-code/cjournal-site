---
const today = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  weekday: 'short'
}).format(new Date());
---
<header class="site-header">
  <div class="container header-inner">
    <div class="masthead">
      <a href="/" class="logo">마진계산소</a>
      <p class="edition">판매·생활·대출 계산기</p>
    </div>
    <nav aria-label="주요 도구">
      <a href="/#finder">계산기 찾기</a>
      <a href="/#seller">판매자 계산기</a>
      <a href="/#living">생활비 계산기</a>
      <a href="/#utility">금융·운영 계산기</a>
      <a href="/about">소개</a>
    </nav>
    <div class="today">{today}</div>
    </div>
</header>

<style>
  .header-inner {
    min-height: 64px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18px;
  }
  .masthead { display: grid; gap: 2px; }
  .edition {
    margin: 0;
    color: #74817b;
    font-size: 0.78rem;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-weight: 700;
  }
  nav {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  nav a {
    border-radius: 8px;
    padding: 7px 9px;
    font-size: 0.88rem;
  }
  nav a:hover {
    background: #edf8f2;
    color: #1c2a23;
  }
  .today {
    color: #7c8882;
    font: 800 0.76rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    white-space: nowrap;
  }
  @media (max-width: 768px) {
    .header-inner {
      display: grid;
      gap: 10px;
    }
    .today { display: none; }
  }
</style>
