---
const adsEnabled = import.meta.env.PUBLIC_ADS_ENABLED === 'true';
interface Props {
  slot: 'top' | 'mid' | 'bottom';
}
const { slot } = Astro.props;
---
{adsEnabled ? (
  <div class="ad-slot" data-slot={slot}>
    {/* Insert AdSense script and ad unit here when ads are activated. */}
    {/* Keep this area minimal to preserve CLS and Core Web Vitals. */}
  </div>
) : null}
