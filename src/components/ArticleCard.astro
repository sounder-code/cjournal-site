---
import { formatDate } from '@/lib/date';

interface Props {
  post: {
    data: {
      title: string;
      description: string;
      publishedAt: string | Date;
      tags: string[];
      category?: string;
      readingTimeMinutes: number;
    };
    slug: string;
  };
  compact?: boolean;
}

const { post } = Astro.props;
const compact = Astro.props.compact ?? false;
const thumb = `/assets/posts/${post.slug}-1.png`;
const thumbFallback = `/assets/posts/${post.slug}.png`;
---
<article class={`article-card ${compact ? 'compact' : ''}`}>
  <a class="thumb" href={`/posts/${post.slug}/`}>
    <img src={thumb} alt={`${post.data.title} 썸네일`} loading="lazy" onerror={`this.onerror=null;this.src='${thumbFallback}'`} />
  </a>
  <div>
  <p class="category">{post.data.category ?? '종합'}</p>
  <h3><a href={`/posts/${post.slug}/`}>{post.data.title}</a></h3>
  <p class="desc">{post.data.description}</p>
  <p class="meta">
    {formatDate(post.data.publishedAt)} · 읽는 시간 {post.data.readingTimeMinutes}분
  </p>
  <div class="tags">
    {post.data.tags.slice(0, 3).map((tag) => <a href={`/tags/${encodeURIComponent(tag)}/`}>#{tag}</a>)}
  </div>
  </div>
</article>

<style>
  .article-card {
    display: grid;
    gap: 12px;
    grid-template-columns: 180px 1fr;
    align-items: start;
  }
  .article-card.compact {
    grid-template-columns: 104px 1fr;
    padding: 10px;
    gap: 10px;
  }
  .thumb {
    display: block;
    overflow: hidden;
    border: 1px solid #d8d8d4;
    background: #f8f8f6;
  }
  .thumb img {
    width: 100%;
    height: 120px;
    object-fit: cover;
    display: block;
  }
  .article-card.compact .thumb img { height: 74px; }
  .category {
    margin: 0 0 6px;
    font-size: 0.78rem;
    color: #415d7e;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .article-card h3 {
    margin: 0 0 8px;
    font-size: 1.08rem;
    line-height: 1.45;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    font-weight: 900;
  }
  .article-card h3 a {
    color: #111;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .article-card h3 a:hover { text-decoration: underline; }
  .article-card.compact h3 {
    margin-bottom: 4px;
    font-size: 1.02rem;
    line-height: 1.38;
  }
  .desc {
    margin: 0 0 6px;
    color: #2a2a2a;
  }
  .article-card.compact .desc {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 5px;
    font-size: 0.92rem;
    line-height: 1.4;
  }
  .article-card .meta {
    margin: 0 0 6px;
    font-size: 0.82rem;
    color: #666;
    line-height: 1.35;
  }
  .article-card.compact .meta {
    font-size: 0.78rem;
    margin-bottom: 4px;
  }
  .article-card.compact .tags a {
    font-size: 0.74rem;
    padding: 2px 6px;
  }
  @media (max-width: 768px) {
    .article-card,
    .article-card.compact {
      grid-template-columns: 1fr;
    }
    .thumb img { height: 180px; }
  }
</style>
