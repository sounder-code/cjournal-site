---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { calculators, groupLabels } from '@/data/calculators';
import { guides } from '@/data/guides';

const guideGroups = [
  {
    group: 'seller',
    title: '판매 전 손익 점검',
    description: '판매가를 정하기 전에 원가, 수수료, 광고비, 반품 손실을 먼저 보는 흐름입니다.',
    steps: ['판매자 순이익 보기', '손익분기 판매가 역산', '광고비 허용 한도 점검', '반품률 손실 반영']
  },
  {
    group: 'living',
    title: '생활비 계약 총액 비교',
    description: '월요금만 보고 결정하기 쉬운 렌탈, 인터넷, 할부, 이사 비용을 총액 기준으로 비교합니다.',
    steps: ['월 고정비 줄이기', '인터넷 갈아타기 손익', '렌탈 약정 총액', '카드 할부 월부담']
  },
  {
    group: 'utility',
    title: '금융·시간 부담 계산',
    description: '대출 상환, 예적금 만기, 투자 회수기간, 시간당 수익처럼 장기 부담을 숫자로 정리합니다.',
    steps: ['대출 상환 방식 비교', '예금·적금 이자 계산', '투자 회수기간 계산', '시간당 수익 환산']
  },
  {
    group: 'housing',
    title: '주거비 계약 전 총부담 계산',
    description: '월세, 관리비, 중개보수처럼 계약 전 반드시 한 번 더 봐야 하는 비용을 정리합니다.',
    steps: ['월세 총부담 계산', '중개보수 예상', '관리비 분담', '거주 기간별 비교']
  },
  {
    group: 'work',
    title: '일한 뒤 실제 남는 돈 계산',
    description: '월급, 외주 계약, 연차수당처럼 세전 금액과 실제 수령액이 다른 항목을 계산합니다.',
    steps: ['급여 실수령액', '프리랜서 원천징수', '플랫폼 수수료', '연차수당 환산']
  },
  {
    group: 'health',
    title: '생활 건강 기준 계산',
    description: 'BMI, 칼로리 목표, 물 섭취량처럼 매일 확인하는 기준값을 간단히 계산합니다.',
    steps: ['BMI 확인', '하루 칼로리 목표', '단백질 기준', '물 섭취량']
  }
] as const;
---
<BaseLayout
  title="계산 가이드"
  description="돈, 계약, 쇼핑, 주거, 급여, 건강 기준을 계산기와 함께 점검하는 가이드"
  canonical="/news"
>
  <section class="guide-index">
    <div class="guide-hero">
      <p class="kicker">Guide</p>
      <h1>계산 순서만 잡아도 판단이 훨씬 빨라집니다.</h1>
      <p>
        바로계산의 가이드는 긴 설명보다 입력 순서와 비교 기준에 집중합니다.
        아래 흐름대로 계산하면 돈, 계약, 쇼핑, 주거, 급여 판단에서 빠지는 숫자를 줄일 수 있습니다.
      </p>
    </div>

    <div class="guide-grid">
      {guideGroups.map((guide) => {
        const items = calculators.filter((calculator) => calculator.group === guide.group).slice(0, 5);
        return (
          <article>
            <p class="group-label">{groupLabels[guide.group]}</p>
            <h2>{guide.title}</h2>
            <p class="desc">{guide.description}</p>
            <ol>
              {guide.steps.map((step) => <li>{step}</li>)}
            </ol>
            <div class="tool-links">
              {items.map((calculator) => (
                <a href={`/calculators/${calculator.slug}/`}>
                  <span>{calculator.shortTitle}</span>
                  <small>{calculator.intent}</small>
                </a>
              ))}
            </div>
          </article>
        );
      })}
    </div>

    <section class="article-guides">
      <div class="section-title">
        <h2>상황별 자세히 보기</h2>
        <p>{guides.length}개 가이드</p>
      </div>
      <div class="article-list">
        {guides.map((guide) => (
          <a href={`/guides/${guide.slug}/`}>
            <span>{guide.category} · {guide.readMinutes}분</span>
            <strong>{guide.title}</strong>
            <p>{guide.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="review-note">
      <h2>결과를 볼 때 놓치기 쉬운 것</h2>
      <p>
        기본값은 예시일 뿐입니다. 실제 판단에는 본인의 수수료율, 계약 기간, 세금 처리, 배송비, 위약금, 이자율을 넣어야 합니다.
        결과가 애매하면 낙관값과 보수값을 각각 저장해 비교하는 편이 안전합니다.
      </p>
    </section>
  </section>
</BaseLayout>

<style>
  .guide-index {
    display: grid;
    gap: 22px;
  }
  .guide-hero {
    max-width: 900px;
    display: grid;
    gap: 10px;
  }
  .kicker,
  .group-label {
    margin: 0;
    color: var(--green-strong);
    font: 950 0.82rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    text-transform: uppercase;
  }
  h1 {
    margin: 0;
    color: var(--ink);
    font: 950 clamp(2.1rem, 5vw, 4rem)/1.08 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  .guide-hero p:last-child,
  .desc,
  .review-note p {
    margin: 0;
    color: var(--muted);
    font: 700 1.02rem/1.75 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .guide-hero p:last-child { max-width: 760px; }
  .guide-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  article,
  .review-note,
  .article-guides {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: 18px;
    box-shadow: var(--shadow-sm);
  }
  h2 {
    margin: 8px 0 8px;
    color: var(--ink);
    font: 950 1.35rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .section-title {
    display: flex;
    justify-content: space-between;
    gap: 14px;
    align-items: end;
    margin-bottom: 14px;
  }
  .section-title h2 {
    margin: 0;
  }
  .section-title p {
    margin: 0;
    color: var(--subtle);
    font: 850 0.88rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .article-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }
  .article-list a {
    display: grid;
    gap: 8px;
    min-height: 154px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface-soft);
    color: inherit;
    padding: 16px;
    text-decoration: none;
  }
  .article-list a:hover {
    border-color: #9bb7d8;
    box-shadow: var(--shadow-sm);
  }
  .article-list span {
    color: var(--blue);
    font: 900 0.78rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .article-list strong {
    color: var(--ink);
    font: 950 1.1rem/1.3 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .article-list p {
    margin: 0;
    color: var(--muted);
    font: 700 0.94rem/1.58 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  ol {
    margin: 16px 0;
    padding-left: 1.25rem;
    color: var(--ink);
    font-weight: 850;
  }
  li + li { margin-top: 6px; }
  .tool-links {
    display: grid;
    gap: 8px;
  }
  .tool-links a {
    display: grid;
    gap: 2px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 10px;
    color: var(--ink);
    background: var(--surface-soft);
    text-decoration: none;
  }
  .tool-links a:hover {
    border-color: var(--line-strong);
    box-shadow: var(--shadow-sm);
    transform: translateY(-1px);
  }
  .tool-links span {
    font-weight: 950;
  }
  .tool-links small {
    color: var(--muted);
    font-weight: 750;
  }
  @media (max-width: 960px) {
    .guide-grid {
      grid-template-columns: 1fr;
    }
    .article-list {
      grid-template-columns: 1fr;
    }
  }
</style>
