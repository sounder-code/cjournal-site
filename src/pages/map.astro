---
import BaseLayout from '@/layouts/BaseLayout.astro';
import 'leaflet/dist/leaflet.css';
import { loadApartmentManifest } from '@/lib/apartmentBulk';
import apartmentCoordinates from '@/data/apartment-coordinates.json';

const manifest = await loadApartmentManifest();
const metrics = [
  { key: 'tf', label: '총 관리비', shortLabel: '총액' },
  { key: 'cf', label: '공용관리비', shortLabel: '공용' },
  { key: 'rf', label: '장기수선충당금', shortLabel: '충당금' }
];
---
<BaseLayout
  title="전국 아파트 관리비 지도 | 바로계산"
  description="전국 공동주택을 검색하고 총 관리비, 공용관리비, 장기수선충당금을 지도에서 비교합니다."
  canonical="/map/"
  robots={manifest.stats.complexes > 0 ? 'index, follow' : 'noindex, nofollow'}
>
  <section class="map-shell" data-map-app>
    <header class="product-header">
      <div>
        <span>K-apt 전국 공개자료</span>
        <h1>아파트 관리비 지도</h1>
        <p>전국 단지를 찾고 공개 주소와 ㎡당 관리비를 한 화면에서 확인합니다.</p>
      </div>
      <a href="/apartments/">표로 자세히 보기</a>
    </header>

    <div class="filter-bar" aria-label="관리비 지도 필터">
      <label class="search-field">
        <span>검색</span>
        <input type="search" data-search placeholder="단지명, 주소, 동 검색" autocomplete="off" enterkeyhint="search" />
        <output data-search-feedback aria-live="polite" hidden></output>
      </label>

      <div class="metric-control" role="list" aria-label="비교 항목">
        {metrics.map((metric) => (
          <button type="button" data-metric={metric.key} class={metric.key === 'tf' ? 'active' : ''}>{metric.shortLabel}</button>
        ))}
      </div>

      <label class="select-field">
        <span>지역</span>
        <select data-region>
          <option value="all">전국</option>
          {manifest.regions.map((region) => <option value={region.name}>{region.name}</option>)}
        </select>
      </label>

      <label class="select-field">
        <span>세대수</span>
        <select data-households>
          <option value="all">전체</option>
          <option value="under-300">300 미만</option>
          <option value="300-499">300~499</option>
          <option value="500-999">500~999</option>
          <option value="1000-1499">1,000~1,499</option>
          <option value="over-1500">1,500 이상</option>
        </select>
      </label>

      <button type="button" class="reset-button" data-reset>초기화</button>
    </div>

    <div class="workspace">
      <section class="map-pane">
        <div class="map-status">
          <div><strong data-count>전국 데이터를 불러오는 중</strong><span data-metric-label>총 관리비 기준</span></div>
          <div class="legend" aria-label="비교 수준 범례">
            <span><i class="low"></i>낮음</span>
            <span><i class="average"></i>평균권</span>
            <span><i class="high"></i>높음</span>
            <span><i class="very-high"></i>매우 높음</span>
          </div>
        </div>
        <div id="apartment-map" class="map-canvas" aria-label="전국 아파트 관리비 지도"></div>
        <div class="result-area">
          <div class="result-heading"><strong>검색 결과</strong><span>조건에 맞는 단지 중 최대 6개</span></div>
          <div class="result-list" data-results aria-live="polite"></div>
        </div>
      </section>

      <aside class="detail-pane" data-detail aria-label="선택 단지 정보">
        <div class="empty-detail">
          <span>단지 선택</span>
          <strong>지역을 고르거나 단지를 검색하세요</strong>
          <p>시도 마커를 누르면 해당 지역으로 좁혀집니다. 검색 결과에서 단지를 선택하면 공개 주소 기준 위치와 관리비를 표시합니다.</p>
        </div>
      </aside>
    </div>

    <footer class="source-note">
      <strong>데이터 기준</strong>
      <p>국토교통부 공동주택관리정보시스템(K-apt) 일괄 공개자료 · 원본 {manifest.sourceDate} · 최신 관리비 {manifest.latestMonth}</p>
    </footer>
  </section>

  <script is:inline type="application/json" id="map-payload" set:html={JSON.stringify({
    indexUrl: manifest.index,
    metrics,
    coordinates: apartmentCoordinates
  })} />

  <script>
    // @ts-nocheck
    import L from 'leaflet';

    const payload = JSON.parse(document.querySelector('#map-payload')?.textContent || '{}');
    const app = document.querySelector('[data-map-app]');
    const search = app?.querySelector('[data-search]');
    const searchFeedback = app?.querySelector('[data-search-feedback]');
    const region = app?.querySelector('[data-region]');
    const households = app?.querySelector('[data-households]');
    const reset = app?.querySelector('[data-reset]');
    const count = app?.querySelector('[data-count]');
    const metricLabelNode = app?.querySelector('[data-metric-label]');
    const results = app?.querySelector('[data-results]');
    const detail = app?.querySelector('[data-detail]');
    const metricButtons = [...(app?.querySelectorAll('[data-metric]') || [])];
    const initialSlug = new URLSearchParams(window.location.search).get('apt') || '';

    const provinceCenters = {
      '서울특별시': [37.5665, 126.978],
      '부산광역시': [35.1796, 129.0756],
      '대구광역시': [35.8714, 128.6014],
      '인천광역시': [37.4563, 126.7052],
      '광주광역시': [35.1595, 126.8526],
      '대전광역시': [36.3504, 127.3845],
      '울산광역시': [35.5384, 129.3114],
      '세종특별자치시': [36.48, 127.289],
      '경기도': [37.4138, 127.5183],
      '강원특별자치도': [37.8228, 128.1555],
      '충청북도': [36.6357, 127.4917],
      '충청남도': [36.5184, 126.8],
      '전북특별자치도': [35.7175, 127.153],
      '전라남도': [34.8679, 126.991],
      '경상북도': [36.4919, 128.8889],
      '경상남도': [35.4606, 128.2132],
      '제주특별자치도': [33.4996, 126.5312]
    };

    const map = L.map('apartment-map', { zoomControl: true, attributionControl: true }).setView([36.35, 127.85], 7);
    L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
    }).addTo(map);
    const markerLayer = L.layerGroup().addTo(map);

    let apartments = [];
    let activeMetric = 'tf';
    let selectedSlug = initialSlug;
    let inputTimer;

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
    const formatNumber = (value) => Number(value || 0).toLocaleString('ko-KR');
    const formatWon = (value) => Number(value) > 0 ? `${formatNumber(value)}원` : '미공개';
    const metricLabel = () => payload.metrics.find((metric) => metric.key === activeMetric)?.label || '총 관리비';
    const householdBand = (value) => value < 300 ? 'under-300' : value < 500 ? '300-499' : value < 1000 ? '500-999' : value < 1500 ? '1000-1499' : 'over-1500';
    const bandFor = (percentile) => percentile >= 85 ? 'very-high' : percentile >= 65 ? 'high' : percentile <= 35 ? 'low' : 'average';
    const bandLabel = (band) => ({ low: '낮은 편', average: '평균권', high: '높은 편', 'very-high': '매우 높음' })[band];

    const filteredApartments = () => {
      const query = (search?.value || '').trim().toLowerCase();
      const selectedRegion = region?.value || 'all';
      const selectedHouseholds = households?.value || 'all';
      return apartments.filter((item) => {
        const text = `${item.n} ${item.sd} ${item.sg} ${item.d} ${item.a}`.toLowerCase();
        return (!query || text.includes(query))
          && (selectedRegion === 'all' || item.sd === selectedRegion)
          && (selectedHouseholds === 'all' || householdBand(Number(item.h || 0)) === selectedHouseholds);
      });
    };

    const percentileFor = (items, apartment) => {
      const values = items.map((item) => Number(item[activeMetric] || 0)).filter((value) => value > 0).sort((a, b) => a - b);
      const value = Number(apartment?.[activeMetric] || 0);
      if (!value || values.length < 2) return 50;
      let low = 0;
      let high = values.length;
      while (low < high) {
        const middle = Math.floor((low + high) / 2);
        if (values[middle] <= value) low = middle + 1;
        else high = middle;
      }
      return Math.max(1, Math.min(99, Math.round((low / values.length) * 100)));
    };

    const renderRegionMarkers = (items) => {
      markerLayer.clearLayers();
      const regionCounts = new Map();
      items.forEach((item) => regionCounts.set(item.sd, (regionCounts.get(item.sd) || 0) + 1));
      const bounds = [];
      for (const [name, regionCount] of regionCounts) {
        const coordinate = provinceCenters[name];
        if (!coordinate) continue;
        const icon = L.divIcon({
          className: 'province-marker-wrap',
          html: `<div class="province-marker"><strong>${formatNumber(regionCount)}</strong><span>${escapeHtml(name)}</span></div>`,
          iconSize: [64, 64],
          iconAnchor: [32, 32]
        });
        L.marker(coordinate, { icon, title: `${name} ${formatNumber(regionCount)}개 단지`, keyboard: true })
          .on('click', () => {
            region.value = name;
            selectedSlug = '';
            render();
          })
          .addTo(markerLayer);
        bounds.push(coordinate);
      }
      if (bounds.length > 1) map.fitBounds(bounds, { padding: [38, 38], maxZoom: 8 });
      else if (bounds.length === 1) map.setView(bounds[0], 10);
    };

    const locateApartment = async (apartment, comparison) => {
      markerLayer.clearLayers();
      const cacheKey = `cjournal-coordinate:${apartment.c}`;
      let coordinate = payload.coordinates?.[apartment.c];
      if (!coordinate) {
        try { coordinate = JSON.parse(localStorage.getItem(cacheKey) || 'null'); } catch {}
      }
      if (!coordinate) {
        const status = detail?.querySelector('[data-location-status]');
        if (status) status.textContent = '공개 주소로 지도 위치 확인 중';
        try {
          const url = new URL('https://nominatim.openstreetmap.org/search');
          url.searchParams.set('q', apartment.a);
          url.searchParams.set('format', 'jsonv2');
          url.searchParams.set('limit', '1');
          url.searchParams.set('countrycodes', 'kr');
          const response = await fetch(url);
          const [found] = response.ok ? await response.json() : [];
          if (found) {
            coordinate = { latitude: Number(found.lat), longitude: Number(found.lon) };
            localStorage.setItem(cacheKey, JSON.stringify(coordinate));
          }
        } catch {}
      }
      if (selectedSlug !== apartment.s) return;
      const status = detail?.querySelector('[data-location-status]');
      if (!coordinate) {
        if (status) status.textContent = '주소 좌표를 찾지 못했습니다';
        const center = provinceCenters[apartment.sd];
        if (center) map.setView(center, 10);
        return;
      }
      if (status) status.textContent = '공개 주소 기준 위치';
      const percentile = percentileFor(comparison, apartment);
      const band = bandFor(percentile);
      const icon = L.divIcon({
        className: 'apartment-marker-wrap',
        html: `<div class="apartment-marker ${band}"><strong>${percentile}</strong><span>${escapeHtml(apartment.n)}</span></div>`,
        iconSize: [42, 42],
        iconAnchor: [21, 21]
      });
      L.marker([coordinate.latitude, coordinate.longitude], { icon, title: apartment.n, keyboard: true }).addTo(markerLayer);
      map.setView([coordinate.latitude, coordinate.longitude], 16);
    };

    const renderResults = (items) => {
      if (!results) return;
      const hasQuery = Boolean((search?.value || '').trim());
      const rows = items.slice().sort((a, b) => hasQuery
        ? a.n.localeCompare(b.n, 'ko')
        : Number(b.q || 0) - Number(a.q || 0) || Number(b.h || 0) - Number(a.h || 0) || a.n.localeCompare(b.n, 'ko'))
        .slice(0, 6);
      if (!rows.length) {
        results.innerHTML = '<p class="empty-result">조건에 맞는 단지가 없습니다.</p>';
        return;
      }
      results.innerHTML = rows.map((item) => {
        const percentile = percentileFor(items, item);
        const band = bandFor(percentile);
        return `<button type="button" class="result-card ${band}${item.s === selectedSlug ? ' selected' : ''}" data-slug="${escapeHtml(item.s)}">
          <i aria-hidden="true"></i>
          <span>${escapeHtml(item.sd)} ${escapeHtml(item.sg)}</span>
          <strong>${escapeHtml(item.n)}</strong>
          <small>${escapeHtml(item.ht || '난방 미확인')} · ${formatNumber(item.h)}세대</small>
          <b>${percentile}p</b>
          <em>${formatWon(item[activeMetric])}/㎡</em>
        </button>`;
      }).join('');
      results.querySelectorAll('[data-slug]').forEach((button) => {
        button.addEventListener('click', () => selectApartment(button.dataset.slug));
      });
    };

    const renderDetail = (apartment, comparison) => {
      if (!detail) return;
      const percentile = percentileFor(comparison, apartment);
      const band = bandFor(percentile);
      detail.innerHTML = `
        <div class="detail-head">
          <span>${escapeHtml(apartment.sd)} ${escapeHtml(apartment.sg)} · ${escapeHtml(apartment.ht || '난방 미확인')}</span>
          <h2>${escapeHtml(apartment.n)}</h2>
          <p>${escapeHtml(apartment.a)}</p>
          <small data-location-status>지도 위치 준비 중</small>
        </div>
        <div class="score-box ${band}">
          <section><span>${metricLabel()} 수준</span><strong>${bandLabel(band)}</strong><p>현재 검색 조건에서 백분위 ${percentile}</p></section>
          <section><span>기준월 금액</span><strong>${formatWon(apartment[activeMetric])}</strong><p>관리비부과면적 ㎡당</p></section>
        </div>
        <p class="comparison-note">${escapeHtml(apartment.sg)} 공개 단지와 비교한 참고값입니다. 세대별 실제 청구액은 전용면적과 사용량에 따라 달라집니다.</p>
        <dl class="facts">
          <div><dt>세대수</dt><dd>${formatNumber(apartment.h)}세대</dd></div>
          <div><dt>사용승인</dt><dd>${apartment.y ? `${apartment.y}년` : '미확인'}</dd></div>
          <div><dt>관리방식</dt><dd>${escapeHtml(apartment.mt || '미확인')}</dd></div>
          <div><dt>기준월</dt><dd>${escapeHtml(apartment.lm || '미공개')}</dd></div>
          <div><dt>총 관리비</dt><dd>${formatWon(apartment.tf)}/㎡</dd></div>
          <div><dt>공용관리비</dt><dd>${formatWon(apartment.cf)}/㎡</dd></div>
          <div><dt>장기수선충당금</dt><dd>${formatWon(apartment.rf)}/㎡</dd></div>
          <div><dt>관리비 부과면적</dt><dd>${formatNumber(apartment.ma)}㎡</dd></div>
        </dl>
        ${apartment.q === 1
          ? `<a class="report-link" href="/apartments/${encodeURIComponent(apartment.s)}/">월별 관리비 리포트</a>`
          : '<p class="report-unavailable">공개월이 부족해 상세 리포트는 제공하지 않습니다.</p>'}
      `;
      locateApartment(apartment, comparison);
    };

    const selectApartment = (slug) => {
      selectedSlug = slug;
      const url = new URL(window.location.href);
      url.searchParams.set('apt', slug);
      history.replaceState({}, '', url);
      render();
    };

    const render = () => {
      const filtered = filteredApartments();
      const hasQuery = Boolean((search?.value || '').trim());
      const selected = apartments.find((item) => item.s === selectedSlug);
      if (selected) renderDetail(selected, filtered.length ? filtered : apartments);
      else renderRegionMarkers(filtered);
      renderResults(filtered);
      if (count) count.textContent = `${formatNumber(filtered.length)}개 단지`;
      if (searchFeedback) {
        searchFeedback.hidden = !hasQuery;
        searchFeedback.textContent = hasQuery ? `${formatNumber(filtered.length)}개 찾음` : '';
      }
      if (metricLabelNode) metricLabelNode.textContent = `${metricLabel()} 기준`;
      app?.classList.toggle('empty', filtered.length === 0);
    };

    search?.addEventListener('input', () => {
      window.clearTimeout(inputTimer);
      if (searchFeedback) {
        searchFeedback.hidden = !(search.value || '').trim();
        searchFeedback.textContent = (search.value || '').trim() ? '검색 중' : '';
      }
      inputTimer = window.setTimeout(() => { selectedSlug = ''; render(); }, 120);
    });
    search?.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter') return;
      event.preventDefault();
      window.clearTimeout(inputTimer);
      selectedSlug = '';
      render();
      search.blur();
      window.setTimeout(() => document.querySelector('.result-area')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 180);
    });
    region?.addEventListener('change', () => { selectedSlug = ''; render(); });
    households?.addEventListener('change', () => { selectedSlug = ''; render(); });
    metricButtons.forEach((button) => button.addEventListener('click', () => {
      activeMetric = button.dataset.metric || 'tf';
      metricButtons.forEach((item) => item.classList.toggle('active', item === button));
      render();
    }));
    reset?.addEventListener('click', () => {
      search.value = '';
      region.value = 'all';
      households.value = 'all';
      selectedSlug = '';
      activeMetric = 'tf';
      metricButtons.forEach((item) => item.classList.toggle('active', item.dataset.metric === 'tf'));
      history.replaceState({}, '', window.location.pathname);
      render();
    });

    fetch(payload.indexUrl)
      .then((response) => {
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        return response.json();
      })
      .then((data) => {
        apartments = Array.isArray(data) ? data : [];
        if (selectedSlug && !apartments.some((item) => item.s === selectedSlug)) selectedSlug = '';
        render();
      })
      .catch(() => {
        if (count) count.textContent = '전국 데이터를 불러오지 못했습니다';
        if (results) results.innerHTML = '<p class="empty-result">잠시 후 다시 시도해 주세요.</p>';
      });
  </script>
</BaseLayout>

<style is:global>
  .main-content:has(.map-shell) { width: min(1540px, calc(100vw - 28px)); padding-top: 14px; }
  .map-shell { --line: #dce4df; --ink: #17211d; --green: #08765c; display: grid; gap: 12px; }
  .product-header { min-height: 66px; display: flex; align-items: center; justify-content: space-between; gap: 24px; }
  .product-header span { color: #08765c; font-size: .72rem; font-weight: 850; }
  .product-header h1 { margin: 3px 0 0; color: var(--ink); font-size: 1.65rem; line-height: 1.16; font-weight: 780; letter-spacing: 0; }
  .product-header p { margin: 5px 0 0; color: #68736e; font-size: .84rem; font-weight: 680; }
  .product-header > a, .report-link { min-height: 38px; display: inline-flex; align-items: center; justify-content: center; border-radius: 7px; background: var(--green); color: #fff; text-decoration: none; padding: 0 14px; font-size: .8rem; font-weight: 850; }
  .filter-bar { display: grid; grid-template-columns: minmax(260px, 1fr) 230px 180px 170px auto; gap: 8px; padding: 10px; border: 1px solid var(--line); border-radius: 8px; background: #fff; box-shadow: 0 8px 24px rgba(23, 33, 29, .05); }
  .search-field, .select-field { min-height: 44px; display: grid; align-items: center; gap: 10px; border: 1px solid #d9e1dc; border-radius: 7px; padding: 0 12px; }
  .search-field { grid-template-columns: auto minmax(0, 1fr) auto; }
  .select-field { grid-template-columns: auto minmax(0, 1fr); }
  .search-field:focus-within { border-color: #70bba6; box-shadow: 0 0 0 3px rgba(8, 118, 92, .09); }
  .search-field span, .select-field span { color: #7a847f; font-size: .68rem; font-weight: 850; }
  .search-field input, .select-field select { width: 100%; border: 0; outline: 0; background: transparent; color: var(--ink); font-size: .82rem; font-weight: 730; }
  .search-field output { border-radius: 5px; background: #e8f5f1; color: #006c55; padding: 5px 7px; font-size: .68rem; font-weight: 850; white-space: nowrap; }
  .metric-control { display: grid; grid-template-columns: repeat(3, 1fr); gap: 5px; }
  .metric-control button, .reset-button { border: 1px solid #d9e1dc; border-radius: 7px; background: #fff; color: #45514b; font-size: .76rem; font-weight: 850; cursor: pointer; }
  .metric-control button.active { border-color: #8ac8b7; background: #e8f5f1; color: #006c55; }
  .reset-button { padding: 0 14px; }
  .workspace { min-height: 680px; display: grid; grid-template-columns: minmax(0, 1fr) 380px; gap: 12px; }
  .map-pane, .detail-pane, .source-note { border: 1px solid var(--line); border-radius: 8px; background: #fff; box-shadow: 0 10px 28px rgba(23, 33, 29, .06); }
  .map-pane { min-width: 0; display: grid; grid-template-rows: auto minmax(500px, 1fr) auto; overflow: hidden; }
