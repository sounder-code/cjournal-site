---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadApartmentManifest } from '@/lib/apartmentBulk';
import adminCenters from '@/data/admin-centers.json';

const manifest = await loadApartmentManifest();
const naverMapClientId = import.meta.env.PUBLIC_NAVER_MAP_CLIENT_ID || '8qq4ptrbjt';
const metrics = [
  { key: 'tf', label: '총 관리비', shortLabel: '총액' },
  { key: 'cf', label: '공용관리비', shortLabel: '공용' },
  { key: 'rf', label: '장기수선충당금', shortLabel: '충당금' }
];
---
<BaseLayout
  title="전국 아파트 관리비 지도·단지 비교 | 단지표"
  description="전국 공동주택을 검색하고 총 관리비, 공용관리비, 장기수선충당금을 지도에서 비교합니다."
  canonical="/"
  robots={manifest.stats.complexes > 0 ? 'index, follow' : 'noindex, nofollow'}
  fullBleed
  hideHeader
>
  <section class="map-shell" data-map-app>
    <h1 class="map-title">전국 아파트 관리비 지도</h1>
    <div class="filter-bar" aria-label="관리비 지도 필터">
      <a href="/" class="map-brand" aria-label="단지표 아파트 관리비 지도 홈">
        <span aria-hidden="true"><i></i></span>
        <strong>단지표</strong>
      </a>

      <label class="search-field">
        <span>단지 찾기</span>
        <input type="search" data-search placeholder="아파트 단지명 또는 주소 검색" autocomplete="off" enterkeyhint="search" />
        <output data-search-feedback aria-live="polite" hidden></output>
      </label>

      <div class="mobile-suggestions" data-mobile-suggestions hidden></div>

      <div class="metric-control" role="list" aria-label="비교 항목">
        {metrics.map((metric) => (
          <button type="button" data-metric={metric.key} class={metric.key === 'tf' ? 'active' : ''}>{metric.shortLabel}</button>
        ))}
      </div>

      <label class="select-field">
        <span>지역</span>
        <select data-region>
          <option value="all">전국</option>
          {manifest.regions.map((region) => <option value={region.name}>{region.name}</option>)}
        </select>
      </label>

      <label class="select-field">
        <span>세대수</span>
        <select data-households>
          <option value="all">전체</option>
          <option value="under-300">300 미만</option>
          <option value="300-499">300~499</option>
          <option value="500-999">500~999</option>
          <option value="1000-1499">1,000~1,499</option>
          <option value="over-1500">1,500 이상</option>
        </select>
      </label>

      <button type="button" class="reset-button" data-reset>초기화</button>
    </div>

    <div class="workspace">
      <section class="map-pane">
        <div class="map-status">
          <div class="map-summary">
            <button type="button" data-map-back hidden></button>
            <strong data-count>전국 데이터를 불러오는 중</strong><span data-metric-label>총 관리비 기준</span>
          </div>
          <div class="legend" aria-label="비교 수준 범례">
            <span><i class="low"></i>낮음</span>
            <span><i class="average"></i>평균권</span>
            <span><i class="high"></i>높음</span>
            <span><i class="very-high"></i>매우 높음</span>
          </div>
        </div>
        <div id="apartment-map" class="map-canvas" aria-label="전국 아파트 관리비 지도"></div>
        <div class="result-area">
          <div class="result-heading"><strong>단지 목록</strong><span>최대 6개 표시</span></div>
          <div class="result-list" data-results aria-live="polite"></div>
        </div>
      </section>

      <aside class="detail-pane" data-detail aria-label="선택 단지 정보">
        <div class="empty-detail">
          <span>단지 정보</span>
          <strong>단지를 선택하세요</strong>
          <p>관리비, 세대수, 난방방식과 지역 내 비교값을 확인합니다.</p>
        </div>
      </aside>
    </div>

    <aside class="compare-tray" data-compare-tray aria-label="비교할 단지" hidden>
      <div class="compare-tray-heading">
        <strong><span data-compare-count>0</span>개 단지 비교</strong>
        <button type="button" data-compare-clear>전체 해제</button>
      </div>
      <div class="compare-chips" data-compare-chips></div>
      <button type="button" class="compare-open" data-compare-open disabled>2개부터 비교</button>
    </aside>

    <section class="compare-dialog" data-compare-dialog role="dialog" aria-modal="true" aria-labelledby="compare-title" hidden>
      <button type="button" class="compare-backdrop" data-compare-close aria-label="비교 화면 닫기"></button>
      <div class="compare-sheet">
        <header class="compare-sheet-head">
          <div class="compare-title-block">
            <a href="/" class="map-brand compare-brand" aria-label="단지표 아파트 관리비 지도 홈">
              <span aria-hidden="true"><i></i></span>
              <strong>단지표</strong>
            </a>
            <div class="compare-title-copy">
              <span>선택 단지</span>
              <h2 id="compare-title">단지 관리비 비교</h2>
              <p data-compare-subtitle></p>
            </div>
          </div>
          <div class="compare-sheet-actions">
            <button type="button" data-compare-share>비교 결과 공유</button>
            <button type="button" class="compare-sheet-close" data-compare-close aria-label="비교 화면 닫기">&#215;</button>
          </div>
        </header>
        <div class="compare-content" data-compare-content></div>
      </div>
    </section>

    <output class="map-toast" data-map-toast aria-live="polite" hidden></output>

    <footer class="source-note">
      <strong>데이터 기준</strong>
      <div>
        <p>국토교통부 공동주택관리정보시스템(K-apt) 일괄 공개자료 · 원본 {manifest.sourceDate} · 최신 관리비 {manifest.latestMonth} · K-apt 지도 좌표 · 행정경계 {adminCenters.sourceDate}</p>
        <small>배경지도는 네이버 Dynamic Map을 사용합니다. 행정경계는 <a href="https://sgis.kostat.go.kr" target="_blank" rel="noopener noreferrer">통계청 SGIS</a> 공공누리 제1유형 자료를 <a href="https://github.com/vuski/admdongkor" target="_blank" rel="noopener noreferrer">vuski/admdongkor</a>가 가공한 CC BY 4.0 데이터입니다.</small>
      </div>
    </footer>
  </section>

  <script is:inline type="application/json" id="map-payload" set:html={JSON.stringify({
    indexUrl: manifest.index,
    metrics,
    adminCenters
  })} />

  <script is:inline src={`https://oapi.map.naver.com/openapi/v3/maps.js?ncpKeyId=${naverMapClientId}&submodules=geocoder`}></script>

  <script>
    // @ts-nocheck
    const payload = JSON.parse(document.querySelector('#map-payload')?.textContent || '{}');
    const app = document.querySelector('[data-map-app]');
    const search = app?.querySelector('[data-search]');
    const searchFeedback = app?.querySelector('[data-search-feedback]');
    const mobileSuggestions = app?.querySelector('[data-mobile-suggestions]');
    const region = app?.querySelector('[data-region]');
    const households = app?.querySelector('[data-households]');
    const reset = app?.querySelector('[data-reset]');
    const mapBack = app?.querySelector('[data-map-back]');
    const count = app?.querySelector('[data-count]');
    const metricLabelNode = app?.querySelector('[data-metric-label]');
    const results = app?.querySelector('[data-results]');
    const detail = app?.querySelector('[data-detail]');
    const compareTray = app?.querySelector('[data-compare-tray]');
    const compareCount = app?.querySelector('[data-compare-count]');
    const compareChips = app?.querySelector('[data-compare-chips]');
    const compareOpen = app?.querySelector('[data-compare-open]');
    const compareClear = app?.querySelector('[data-compare-clear]');
    const compareDialog = app?.querySelector('[data-compare-dialog]');
    const compareSubtitle = app?.querySelector('[data-compare-subtitle]');
    const compareContent = app?.querySelector('[data-compare-content]');
    const compareShare = app?.querySelector('[data-compare-share]');
    const mapToast = app?.querySelector('[data-map-toast]');
    const metricButtons = [...(app?.querySelectorAll('[data-metric]') || [])];
    const initialParams = new URLSearchParams(window.location.search);
    const initialSlug = initialParams.get('apt') || '';
    const initialCompareSlugs = (initialParams.get('compare') || '').split(',').map((slug) => slug.trim()).filter(Boolean).slice(0, 4);
    const initialCompareOpen = initialParams.get('view') === 'compare';

    const provinceCenters = {
      '서울특별시': [37.5665, 126.978],
      '부산광역시': [35.1796, 129.0756],
      '대구광역시': [35.8714, 128.6014],
      '인천광역시': [37.4563, 126.7052],
      '광주광역시': [35.1595, 126.8526],
      '대전광역시': [36.3504, 127.3845],
      '울산광역시': [35.5384, 129.3114],
      '세종특별자치시': [36.48, 127.289],
      '경기도': [37.4138, 127.5183],
      '강원특별자치도': [37.8228, 128.1555],
      '충청북도': [36.6357, 127.4917],
      '충청남도': [36.5184, 126.8],
      '전북특별자치도': [35.7175, 127.153],
      '전라남도': [34.8679, 126.991],
      '경상북도': [36.4919, 128.8889],
      '경상남도': [35.4606, 128.2132],
      '제주특별자치도': [33.4996, 126.5312]
    };

    const mapElement = document.querySelector('#apartment-map');
    if (!window.naver?.maps || !mapElement) {
      if (count) count.textContent = '지도를 불러오지 못했습니다';
      throw new Error('NAVER Maps SDK를 불러오지 못했습니다.');
    }
    const compactMap = window.matchMedia('(max-width: 720px)').matches;

    const toLatLng = (coordinate) => Array.isArray(coordinate)
      ? new naver.maps.LatLng(Number(coordinate[0]), Number(coordinate[1]))
      : coordinate;
    const rawMap = new naver.maps.Map(mapElement, {
      center: toLatLng([36.35, 127.85]),
      zoom: 7,
      minZoom: 6,
      maxZoom: 19,
      zoomControl: !compactMap,
      zoomControlOptions: { position: naver.maps.Position.RIGHT_CENTER },
      scaleControl: false,
      logoControlOptions: { position: naver.maps.Position.BOTTOM_LEFT },
      mapDataControlOptions: { position: naver.maps.Position.BOTTOM_LEFT }
    });

    const map = {
      getZoom: () => rawMap.getZoom(),
      getCenter: () => rawMap.getCenter(),
      getBounds: () => rawMap.getBounds(),
      getContainer: () => mapElement,
      setView: (coordinate, zoom) => {
        rawMap.setCenter(toLatLng(coordinate));
        rawMap.setZoom(zoom);
      },
      fitBounds: (coordinates, options = {}) => {
        const bounds = new naver.maps.LatLngBounds();
        coordinates.forEach((coordinate) => bounds.extend(toLatLng(coordinate)));
        const padding = Number(options.padding?.[0] || 40);
        const listener = naver.maps.Event.addListener(rawMap, 'idle', () => {
          naver.maps.Event.removeListener(listener);
          if (Number.isFinite(options.maxZoom) && rawMap.getZoom() > options.maxZoom) rawMap.setZoom(options.maxZoom);
        });
        rawMap.fitBounds(bounds, { top: padding, right: padding, bottom: padding, left: padding });
      },
      latLngToContainerPoint: (coordinate) => rawMap.getProjection().fromCoordToOffset(toLatLng(coordinate)),
      on: (event, handler) => naver.maps.Event.addListener(
        rawMap,
        event === 'zoomend' ? 'zoom_changed' : event === 'moveend' ? 'idle' : event,
        handler
      )
    };

    const markerLayer = {
      markers: [],
      clearLayers() {
        this.markers.forEach((marker) => marker.raw.setMap(null));
        this.markers = [];
      }
    };

    const L = {
      divIcon: (options) => options,
      marker: (coordinate, options = {}) => {
        const root = document.createElement('div');
        const icon = options.icon || {};
        root.className = icon.className || '';
        root.innerHTML = icon.html || '';
        root.style.position = 'relative';
        root.style.width = `${Number(icon.iconSize?.[0] || 20)}px`;
        root.style.height = `${Number(icon.iconSize?.[1] || 20)}px`;
        root.setAttribute('role', 'button');
        root.setAttribute('aria-label', options.title || '지도 마커');
        root.title = options.title || '';
        if (options.keyboard !== false) root.tabIndex = 0;
        const raw = new naver.maps.Marker({
          position: toLatLng(coordinate),
          icon: {
            content: root,
            anchor: new naver.maps.Point(
              Number(icon.iconAnchor?.[0] || 0),
              Number(icon.iconAnchor?.[1] || 0)
            )
          },
          zIndex: Number(options.zIndexOffset || 0)
        });
        const marker = {
          raw,
          clickHandler: null,
          on(event, handler) {
            if (event === 'click') this.clickHandler = handler;
            naver.maps.Event.addListener(raw, event, handler);
            return this;
          },
          addTo(layer) {
            raw.setMap(rawMap);
            layer.markers.push(this);
            if (options.keyboard !== false) {
              root.addEventListener('keydown', (event) => {
                if ((event.key === 'Enter' || event.key === ' ') && this.clickHandler) {
                  event.preventDefault();
                  this.clickHandler();
                }
              });
            }
            return this;
          },
          bindTooltip(html) {
            root.title = String(html).replace(/<br\s*\/?>/gi, ' · ').replace(/<[^>]+>/g, '').trim();
            return this;
          },
          getElement: () => root,
          getLatLng: () => raw.getPosition()
        };
        return marker;
      }
    };
    let complexMarkerEntries = [];

    const updateComplexLabels = () => {
      const zoom = map.getZoom();
      const container = map.getContainer();
      const fixedApartmentMode = app?.classList.contains('apartment-mode');
      const showNames = fixedApartmentMode || zoom >= 14;
      const showValues = fixedApartmentMode || zoom >= 16;
      container.classList.toggle('show-complex-names', showNames);
      container.classList.toggle('show-complex-values', showValues);
      const labelWidth = showValues ? 124 : 108;
      const labelHeight = showValues ? 44 : 34;
      const occupied = [];
      complexMarkerEntries
        .slice()
        .sort((a, b) => Number(b.selected) - Number(a.selected) || Number(b.compared) - Number(a.compared) || Number(b.apartment.h || 0) - Number(a.apartment.h || 0))
        .forEach((entry) => {
          const element = entry.marker.getElement();
          if (!element) return;
          const point = map.latLngToContainerPoint(entry.marker.getLatLng());
          const rect = {
            left: point.x - labelWidth / 2,
            right: point.x + labelWidth / 2,
            top: point.y - labelHeight / 2,
            bottom: point.y + labelHeight / 2
          };
          const visible = showNames && (entry.selected || !occupied.some((placed) => !(
            rect.right + 4 < placed.left
            || rect.left - 4 > placed.right
            || rect.bottom + 4 < placed.top
            || rect.top - 4 > placed.bottom
          )));
          element.classList.toggle('label-visible', visible);
          if (visible) occupied.push(rect);
        });
    };
    updateComplexLabels();

    let apartments = [];
    let activeMetric = 'tf';
    let selectedSlug = initialSlug;
    let activeProvince = '';
    let activeDistrict = '';
    let activeDong = '';
    let mapCoordinateStatus = '';
    let inputTimer;
    let suggestionsDismissed = Boolean(initialSlug);
    let locatingSelection = false;
    let apartmentMode = Boolean(initialSlug);
    let selectionNeedsCenter = Boolean(initialSlug);
    let compareSlugs = [...new Set(initialCompareSlugs)];
    let compareDialogOpen = initialCompareOpen && compareSlugs.length >= 2;
    let toastTimer = 0;

    const escapeHtml = (value) => String(value ?? '')
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#039;');
    const formatNumber = (value) => Number(value || 0).toLocaleString('ko-KR');
    const formatWon = (value) => Number(value) > 0 ? `${formatNumber(value)}원` : '미공개';
    const showToast = (message) => {
      if (!mapToast) return;
      window.clearTimeout(toastTimer);
      mapToast.textContent = message;
      mapToast.hidden = false;
      toastTimer = window.setTimeout(() => {
        mapToast.hidden = true;
      }, 2200);
    };
    const copyText = async (text) => {
      if (navigator.clipboard?.writeText) {
        try {
          await navigator.clipboard.writeText(text);
          return;
        } catch {}
      }
      const area = document.createElement('textarea');
      area.value = text;
      area.setAttribute('readonly', '');
      area.style.position = 'fixed';
      area.style.opacity = '0';
      document.body.append(area);
      area.select();
      document.execCommand('copy');
      area.remove();
    };
    const shareLink = async ({ title, text, url }) => {
      if (navigator.share) {
        try {
          await navigator.share({ title, text, url });
          return;
        } catch (error) {
          if (error?.name === 'AbortError') return;
        }
      }
      try {
        await copyText(url);
        showToast('공유 링크를 복사했습니다');
      } catch {
        showToast('링크를 복사하지 못했습니다');
      }
    };
    const apartmentShareUrl = (slug) => {
      const url = new URL(window.location.pathname, window.location.origin);
      url.searchParams.set('apt', slug);
      return url.toString();
    };
    const comparisonShareUrl = () => {
      const url = new URL(window.location.pathname, window.location.origin);
      url.searchParams.set('compare', compareSlugs.join(','));
      url.searchParams.set('view', 'compare');
      return url.toString();
    };
    const syncComparisonUrl = () => {
      const url = new URL(window.location.href);
      if (compareSlugs.length) url.searchParams.set('compare', compareSlugs.join(','));
      else url.searchParams.delete('compare');
      if (compareDialogOpen && compareSlugs.length >= 2) url.searchParams.set('view', 'compare');
      else url.searchParams.delete('view');
      history.replaceState({}, '', url);
    };
    const distanceBetween = (origin, destination) => {
      const [originLatitude, originLongitude] = Array.isArray(origin)
        ? origin.map(Number)
        : [Number(origin.lat()), Number(origin.lng())];
      const [destinationLatitude, destinationLongitude] = Array.isArray(destination)
        ? destination.map(Number)
        : [Number(destination.lat()), Number(destination.lng())];
      const radians = (degrees) => degrees * Math.PI / 180;
      const latitudeDelta = radians(destinationLatitude - originLatitude);
      const longitudeDelta = radians(destinationLongitude - originLongitude);
      const latitudeArc = Math.sin(latitudeDelta / 2);
      const longitudeArc = Math.sin(longitudeDelta / 2);
      const haversine = latitudeArc * latitudeArc
        + Math.cos(radians(originLatitude)) * Math.cos(radians(destinationLatitude))
        * longitudeArc * longitudeArc;
      return 12742000 * Math.asin(Math.sqrt(haversine));
    };
    const metricLabel = () => payload.metrics.find((metric) => metric.key === activeMetric)?.label || '총 관리비';
    const householdBand = (value) => value < 300 ? 'under-300' : value < 500 ? '300-499' : value < 1000 ? '500-999' : value < 1500 ? '1000-1499' : 'over-1500';
    const bandFor = (percentile) => percentile >= 85 ? 'very-high' : percentile >= 65 ? 'high' : percentile <= 35 ? 'low' : 'average';
    const bandLabel = (band) => ({ low: '낮은 편', average: '평균권', high: '높은 편', 'very-high': '매우 높음' })[band];
    const normalizeDistrict = (value) => String(value || '').replaceAll('시', '');
    const normalizeDong = (value) => String(value || '').replace(/제?\d+(?=동$)/g, '');
    const districtKey = (province, district) => `${province}|${normalizeDistrict(district)}`;
    const districtCenters = new Map(payload.adminCenters.districts.map((item) => [districtKey(item.province, item.district), item]));

    const filteredApartments = () => {
      const query = (search?.value || '').trim().toLowerCase();
      const selectedRegion = region?.value || 'all';
      const selectedHouseholds = households?.value || 'all';
      return apartments.filter((item) => {
        const text = `${item.n} ${item.sd} ${item.sg} ${item.d} ${item.a}`.toLowerCase();
        return (!query || text.includes(query))
          && (selectedRegion === 'all' || item.sd === selectedRegion)
          && (selectedHouseholds === 'all' || householdBand(Number(item.h || 0)) === selectedHouseholds);
      });
    };

    const mapEligibleApartments = () => {
      const selectedHouseholds = households?.value || 'all';
      return apartments.filter((item) => selectedHouseholds === 'all'
        || householdBand(Number(item.h || 0)) === selectedHouseholds);
    };

    const comparisonForApartment = (apartment) => {
      const districtItems = apartments.filter((item) => item.sd === apartment.sd && item.sg === apartment.sg);
      const sameScale = districtItems.filter((item) => householdBand(Number(item.h || 0)) === householdBand(Number(apartment.h || 0)));
      return sameScale.length >= 10 ? sameScale : districtItems.length >= 2 ? districtItems : apartments;
    };

    const apartmentsInCurrentView = (selected = null) => {
      const bounds = map.getBounds();
      const southWest = bounds?.getSW?.();
      const northEast = bounds?.getNE?.();
      if (!southWest || !northEast) return selected ? [selected] : [];
      const south = Number(southWest.lat());
      const west = Number(southWest.lng());
      const north = Number(northEast.lat());
      const east = Number(northEast.lng());
      const latitudePadding = Math.max((north - south) * .65, .0025);
      const longitudePadding = Math.max((east - west) * .65, .0025);
      const center = map.getCenter();
      const limit = window.matchMedia('(max-width: 720px)').matches ? 90 : 160;
      const visible = mapEligibleApartments()
        .filter((item) => {
          const latitude = Number(item.la);
          const longitude = Number(item.lo);
          return Number.isFinite(latitude) && Number.isFinite(longitude)
            && latitude >= south - latitudePadding
            && latitude <= north + latitudePadding
            && longitude >= west - longitudePadding
            && longitude <= east + longitudePadding;
        })
        .sort((a, b) => Number(b.s === selected?.s) - Number(a.s === selected?.s)
          || distanceBetween(center, [Number(a.la), Number(a.lo)]) - distanceBetween(center, [Number(b.la), Number(b.lo)]))
        .slice(0, limit);
      if (selected && !visible.some((item) => item.s === selected.s)) visible.unshift(selected);
      return visible;
    };

    const comparedApartments = () => compareSlugs
      .map((slug) => apartments.find((item) => item.s === slug))
      .filter(Boolean);

    const comparisonRows = [
      { key: 'tf', label: '총 관리비', note: '㎡당', kind: 'won', lowerIsBetter: true },
      { key: 'cf', label: '공용관리비', note: '㎡당', kind: 'won', lowerIsBetter: true },
      { key: 'rf', label: '장기수선충당금', note: '㎡당', kind: 'won', lowerIsBetter: true },
      { key: 'h', label: '세대수', kind: 'households' },
      { key: 'y', label: '사용승인', kind: 'year' },
      { key: 'ht', label: '난방방식', kind: 'text' },
      { key: 'mt', label: '관리방식', kind: 'text' },
      { key: 'ma', label: '관리비 부과면적', kind: 'area' },
      { key: 'lm', label: '관리비 기준월', kind: 'text' }
    ];

    const feeComparisonRows = comparisonRows.filter((row) => row.lowerIsBetter);

    const rankedMetric = (row, items) => {
      const ranked = items
        .filter((item) => Number(item[row.key] || 0) > 0)
        .slice()
        .sort((a, b) => Number(a[row.key]) - Number(b[row.key]));
      const values = ranked.map((item) => Number(item[row.key]));
      return {
        ranked,
        lowest: values[0] || 0,
        highest: values.at(-1) || 0,
        average: values.length ? Math.round(values.reduce((sum, value) => sum + value, 0) / values.length) : 0,
        rankFor: (item) => {
          const value = Number(item[row.key] || 0);
          return value > 0 ? ranked.filter((candidate) => Number(candidate[row.key]) < value).length + 1 : 0;
        }
      };
    };

    const signedAmount = (value) => `${value > 0 ? '+' : value < 0 ? '-' : ''}${formatNumber(Math.abs(value))}원`;
    const signedPercent = (value) => `${value > 0 ? '+' : value < 0 ? '-' : ''}${Math.abs(value).toFixed(1)}%`;
    const withSubjectParticle = (value) => {
      const text = String(value || '');
      const lastCode = text.charCodeAt(text.length - 1);
      const hasFinalConsonant = lastCode >= 0xac00 && lastCode <= 0xd7a3 && (lastCode - 0xac00) % 28 !== 0;
      return `${text}${hasFinalConsonant ? '이' : '가'}`;
    };

    const formatComparisonValue = (row, apartment) => {
      const value = apartment[row.key];
      if (row.kind === 'won') return `${formatWon(value)}/㎡`;
      if (row.kind === 'households') return Number(value) > 0 ? `${formatNumber(value)}세대` : '미확인';
      if (row.kind === 'year') return value ? `${escapeHtml(value)}년` : '미확인';
      if (row.kind === 'area') return Number(value) > 0 ? `${formatNumber(value)}㎡` : '미공개';
      return escapeHtml(value || '미확인');
    };

    const renderComparisonDialog = () => {
      if (!compareDialog || !compareContent) return;
      const items = comparedApartments();
      compareDialog.hidden = !compareDialogOpen || items.length < 2;
      document.body.classList.toggle('compare-dialog-open', !compareDialog.hidden);
      if (compareDialog.hidden) return;
      if (compareSubtitle) compareSubtitle.textContent = `${formatNumber(items.length)}개 단지 · K-apt 월별 공개금액 기준`;
      const metricStats = new Map(feeComparisonRows.map((row) => [row.key, rankedMetric(row, items)]));
      const totalStats = metricStats.get('tf');
      const lowestApartment = totalStats?.ranked[0];
      const highestApartment = totalStats?.ranked.at(-1);
      const difference = totalStats && totalStats.highest > totalStats.lowest ? totalStats.highest - totalStats.lowest : 0;
      const differenceRate = totalStats?.highest ? difference / totalStats.highest * 100 : 0;
      const insightCards = feeComparisonRows.map((row) => {
        const stats = metricStats.get(row.key);
        const low = stats?.ranked[0];
        const high = stats?.ranked.at(-1);
        if (!stats || !low || !high) return '';
        const gap = stats.highest - stats.lowest;
        const gapRate = stats.highest ? gap / stats.highest * 100 : 0;
        return `<article class="compare-insight-card">
          <span>${escapeHtml(row.label)}</span>
          <strong>${escapeHtml(withSubjectParticle(low.n))} 가장 낮음</strong>
          <p>${escapeHtml(high.n)}보다 ${formatNumber(gap)}원/㎡ 낮습니다${gap ? ` (${gapRate.toFixed(1)}%)` : ''}.</p>
        </article>`;
      }).join('');
      const totalRanking = totalStats?.ranked.map((item, index) => {
        const value = Number(item.tf || 0);
        const averageDelta = value - totalStats.average;
        const averageRate = totalStats.average ? averageDelta / totalStats.average * 100 : 0;
        const lowestMetrics = feeComparisonRows
          .filter((row) => metricStats.get(row.key)?.rankFor(item) === 1)
          .map((row) => row.label);
        const rank = totalStats.rankFor(item);
        return `<article class="compare-rank-card${rank === 1 ? ' first' : ''}">
          <span class="rank-number">${rank}위</span>
          <div><strong>${escapeHtml(item.n)}</strong><small>총 관리비 낮은 순</small></div>
          <b>${formatWon(value)}/㎡</b>
          <p>선택 평균보다 <em class="${averageDelta > 0 ? 'cost-up' : averageDelta < 0 ? 'cost-down' : ''}">${signedAmount(averageDelta)} · ${signedPercent(averageRate)}</em></p>
          ${lowestMetrics.length ? `<small class="rank-strength">${lowestMetrics.join(' · ')} 최저</small>` : ''}
        </article>`;
      }).join('') || '';
      compareContent.innerHTML = `
        ${lowestApartment ? `<div class="compare-summary">
          <span>비교 요약</span>
          <strong>${escapeHtml(lowestApartment.n)}의 총 관리비가 가장 낮습니다</strong>
          <p>${highestApartment && difference ? `${escapeHtml(highestApartment.n)}보다 ${formatNumber(difference)}원/㎡, ${differenceRate.toFixed(1)}% 낮습니다.` : '선택 단지의 공개금액이 같습니다.'} 금액이 낮다는 의미이며 관리 품질 순위는 아닙니다.</p>
        </div>` : ''}
        <section class="compare-analysis" aria-label="비교 결과 핵심 분석">
          <div class="compare-section-head"><strong>항목별 차이</strong><span>선택한 단지 안에서 비교</span></div>
          <div class="compare-insights">${insightCards}</div>
        </section>
        <section class="compare-ranking" aria-label="총 관리비 순위">
          <div class="compare-section-head"><strong>총 관리비 순위</strong><span>낮은 금액 순 · 선택 평균 대비</span></div>
          <div class="compare-rank-list">${totalRanking}</div>
        </section>
        <div class="compare-table-wrap">
          <table class="compare-table">
            <thead>
              <tr>
                <th scope="col">비교 항목</th>
                ${items.map((item) => `<th scope="col">
                  <button type="button" class="compare-apartment" data-compare-select="${escapeHtml(item.s)}">
                    <span>${escapeHtml(item.sd)} ${escapeHtml(item.sg)}</span>
                    <strong>${escapeHtml(item.n)}</strong>
                    <small>${escapeHtml(item.a)}</small>
                  </button>
                  <button type="button" class="compare-remove" data-compare-remove="${escapeHtml(item.s)}" aria-label="${escapeHtml(item.n)} 비교에서 빼기">빼기</button>
                </th>`).join('')}
              </tr>
            </thead>
            <tbody>
              ${comparisonRows.map((row) => {
                const stats = row.lowerIsBetter ? metricStats.get(row.key) : null;
                return `<tr>
                  <th scope="row"><strong>${row.label}</strong>${row.note ? `<span>${row.note}</span>` : ''}</th>
                  ${items.map((item) => {
                    const value = Number(item[row.key] || 0);
                    const rank = stats?.rankFor(item) || 0;
                    const isBest = row.lowerIsBetter && rank === 1;
                    const delta = stats && value > 0 ? value - stats.lowest : 0;
                    const deltaRate = stats?.lowest && delta ? delta / stats.lowest * 100 : 0;
                    return `<td class="${isBest ? 'best-value' : ''}">
                      <strong>${formatComparisonValue(row, item)}</strong>
                      ${row.lowerIsBetter && value > 0 ? `<small>${rank}위${isBest ? ' · 최저' : ` · 최저보다 ${formatNumber(delta)}원 (${deltaRate.toFixed(1)}%) 높음`}</small>` : ''}
                    </td>`;
                  }).join('')}
                </tr>`;
              }).join('')}
            </tbody>
          </table>
        </div>
        <p class="compare-caption">순위와 차이는 선택한 단지 안에서만 계산합니다. 관리비는 관리비부과면적 ㎡당 공개금액이며, 세대별 실제 청구액은 전용면적과 사용량에 따라 달라질 수 있습니다.</p>
      `;
      compareContent.querySelectorAll('[data-compare-remove]').forEach((button) => {
        button.addEventListener('click', () => toggleCompare(button.dataset.compareRemove));
      });
      compareContent.querySelectorAll('[data-compare-select]').forEach((button) => {
        button.addEventListener('click', () => {
          closeComparison();
          selectApartment(button.dataset.compareSelect, { center: true });
        });
      });
    };

    const renderCompareTray = () => {
      if (!compareTray || !compareChips || !compareOpen) return;
      const items = comparedApartments();
      compareTray.hidden = items.length === 0;
      if (compareCount) compareCount.textContent = String(items.length);
      compareChips.innerHTML = items.map((item) => `<span class="compare-chip">
        <button type="button" data-compare-select="${escapeHtml(item.s)}">${escapeHtml(item.n)}</button>
        <button type="button" data-compare-remove="${escapeHtml(item.s)}" aria-label="${escapeHtml(item.n)} 비교에서 빼기">&#215;</button>
      </span>`).join('');
      compareOpen.disabled = items.length < 2;
      compareOpen.textContent = items.length < 2 ? '1개 더 선택' : `${items.length}개 상세 비교`;
      compareChips.querySelectorAll('[data-compare-remove]').forEach((button) => {
        button.addEventListener('click', () => toggleCompare(button.dataset.compareRemove));
      });
      compareChips.querySelectorAll('[data-compare-select]').forEach((button) => {
        button.addEventListener('click', () => selectApartment(button.dataset.compareSelect, { center: true }));
      });
      renderComparisonDialog();
    };

    const toggleCompare = (slug) => {
      if (!slug) return;
      if (compareSlugs.includes(slug)) {
        compareSlugs = compareSlugs.filter((item) => item !== slug);
        if (compareSlugs.length < 2) compareDialogOpen = false;
      } else {
        if (compareSlugs.length >= 4) {
          showToast('비교는 최대 4개 단지까지 가능합니다');
          render();
          return;
        }
        compareSlugs.push(slug);
        showToast(compareSlugs.length === 1 ? '비교할 단지를 1개 더 선택하세요' : '비교 목록에 담았습니다');
      }
      syncComparisonUrl();
      render();
    };

    const openComparison = () => {
      if (compareSlugs.length < 2) {
        showToast('비교할 단지를 2개 이상 선택하세요');
        return;
      }
      compareDialogOpen = true;
      syncComparisonUrl();
      renderComparisonDialog();
    };

    const closeComparison = () => {
      compareDialogOpen = false;
      syncComparisonUrl();
      renderComparisonDialog();
    };

    const percentileFor = (items, apartment) => {
      const values = items.map((item) => Number(item[activeMetric] || 0)).filter((value) => value > 0).sort((a, b) => a - b);
      const value = Number(apartment?.[activeMetric] || 0);
      if (!value || values.length < 2) return 50;
      let low = 0;
      let high = values.length;
      while (low < high) {
        const middle = Math.floor((low + high) / 2);
        if (values[middle] <= value) low = middle + 1;
        else high = middle;
      }
      return Math.max(1, Math.min(99, Math.round((low / values.length) * 100)));
    };

    const representativeValue = (items) => {
      const values = items.map((item) => Number(item[activeMetric] || 0)).filter((value) => value > 0).sort((a, b) => a - b);
      if (!values.length) return 0;
      const middle = Math.floor(values.length / 2);
      return values.length % 2 ? values[middle] : Math.round((values[middle - 1] + values[middle]) / 2);
    };
    const centerOfApartments = (items) => {
      const coordinates = items
        .map((item) => [Number(item.la), Number(item.lo)])
        .filter(([latitude, longitude]) => Number.isFinite(latitude) && Number.isFinite(longitude));
      if (!coordinates.length) return null;
      return [
        coordinates.reduce((sum, [latitude]) => sum + latitude, 0) / coordinates.length,
        coordinates.reduce((sum, [, longitude]) => sum + longitude, 0) / coordinates.length
      ];
    };

    const addAreaMarker = ({ coordinate, name, items, kind, onClick, selected = false }) => {
      const value = representativeValue(items);
      const compactProvinceMarker = kind === 'province' && window.matchMedia('(max-width: 720px)').matches;
      const provinceSize = compactProvinceMarker ? 48 : 64;
      const icon = L.divIcon({
        className: `${kind}-marker-wrap`,
        html: kind === 'province'
          ? `<div class="province-marker"><strong>${formatNumber(items.length)}</strong><span>${escapeHtml(name)}</span></div>`
          : `<div class="area-marker ${kind}${selected ? ' selected' : ''}"><strong>${escapeHtml(name)}</strong><span>${formatNumber(items.length)}개${kind !== 'district' && value ? ` · ${formatNumber(value)}원` : ''}</span></div>`,
        iconSize: kind === 'province' ? [provinceSize, provinceSize] : kind === 'district' ? [62, 58] : [88, 44],
        iconAnchor: kind === 'province' ? [provinceSize / 2, provinceSize / 2] : kind === 'district' ? [31, 29] : [44, 22]
      });
      return L.marker(coordinate, {
        icon,
        title: `${name} ${formatNumber(items.length)}개 단지`,
        keyboard: true,
        riseOnHover: true,
        zIndexOffset: kind === 'province'
          ? ({ '서울특별시': 500, '인천광역시': 400, '세종특별자치시': 300 }[name] || 0)
          : 0
      }).on('click', onClick).addTo(markerLayer);
    };

    const renderProvinceMarkers = (items, fitMap = false) => {
      markerLayer.clearLayers();
      complexMarkerEntries = [];
      mapCoordinateStatus = '';
      const regionCounts = new Map();
      items.forEach((item) => {
        const group = regionCounts.get(item.sd) || [];
        group.push(item);
        regionCounts.set(item.sd, group);
      });
      const bounds = [];
      for (const [name, regionItems] of regionCounts) {
        const coordinate = provinceCenters[name];
        if (!coordinate) continue;
        addAreaMarker({ coordinate, name, items: regionItems, kind: 'province', onClick: () => openProvince(name) });
        bounds.push(coordinate);
      }
      if (fitMap && bounds.length > 1) map.fitBounds(bounds, {
        padding: [38, 38],
        maxZoom: window.matchMedia('(max-width: 720px)').matches ? 6 : 7,
        animate: true
      });
      else if (fitMap && bounds.length === 1) map.setView(bounds[0], 8, { animate: true });
    };

    const renderDistrictMarkers = (items, fitMap = false) => {
      markerLayer.clearLayers();
      complexMarkerEntries = [];
      mapCoordinateStatus = '';
      const groups = new Map();
      items.forEach((item) => {
        const key = districtKey(item.sd, item.sg);
        const group = groups.get(key) || { name: item.sg, items: [] };
        group.items.push(item);
        groups.set(key, group);
      });
      const bounds = [];
      for (const [key, group] of groups) {
        const center = districtCenters.get(key);
        const coordinate = centerOfApartments(group.items)
          || (center ? [center.latitude, center.longitude] : null);
        if (!coordinate) continue;
        addAreaMarker({
          coordinate,
          name: group.name,
          items: group.items,
          kind: 'district',
          selected: key === activeDistrict,
          onClick: () => openDistrict(key, coordinate)
        });
        bounds.push(coordinate);
      }
      if (fitMap && bounds.length > 1) map.fitBounds(bounds, { padding: [50, 50], maxZoom: 11, animate: true });
      else if (fitMap && bounds.length === 1) map.setView(bounds[0], 12, { animate: true });
    };

    const renderDongMarkers = (items, fitMap = false) => {
      markerLayer.clearLayers();
      complexMarkerEntries = [];
      mapCoordinateStatus = '';
      const district = districtCenters.get(activeDistrict);
      if (!district) return;
      const dongCenters = new Map();
      district.dongs.forEach((dong) => {
        const key = normalizeDong(dong.name);
        const matches = dongCenters.get(key) || [];
        matches.push(dong);
        dongCenters.set(key, matches);
      });
      const groups = new Map();
      items.forEach((item) => {
        const group = groups.get(item.d) || [];
        group.push(item);
        groups.set(item.d, group);
      });
      const bounds = [];
      const unmatched = [];
      for (const [name, group] of groups) {
        const centers = dongCenters.get(normalizeDong(name));
        const coordinate = centerOfApartments(group) || (centers?.length ? [
          centers.reduce((sum, center) => sum + center.latitude, 0) / centers.length,
          centers.reduce((sum, center) => sum + center.longitude, 0) / centers.length
        ] : null);
        if (!coordinate) {
          unmatched.push(...group);
          continue;
        }
        addAreaMarker({
          coordinate,
          name,
          items: group,
          kind: 'dong',
          selected: name === activeDong,
          onClick: () => openDong(name, coordinate)
        });
        bounds.push(coordinate);
      }
      if (unmatched.length) {
        const coordinate = [district.latitude, district.longitude];
        addAreaMarker({
          coordinate,
          name: '그 외 지역',
          items: unmatched,
          kind: 'unmatched',
          onClick: () => {
            activeDong = '';
            map.setView(coordinate, Math.max(map.getZoom(), 13), { animate: true });
            render();
          }
        });
        bounds.push(coordinate);
      }
      if (fitMap && bounds.length > 1) map.fitBounds(bounds, { padding: [55, 55], maxZoom: 12, animate: true });
      else if (fitMap && bounds.length === 1) map.setView(bounds[0], 13, { animate: true });
    };

    const renderApartmentMarkers = (items, fitMap = false, selectedApartmentSlug = '') => {
      markerLayer.clearLayers();
      complexMarkerEntries = [];
      const bounds = [];
      let missingCoordinates = 0;
      items.forEach((apartment) => {
        const latitude = Number(apartment.la);
        const longitude = Number(apartment.lo);
        if (!Number.isFinite(latitude) || !Number.isFinite(longitude)) {
          missingCoordinates += 1;
          return;
        }
        const percentile = percentileFor(items, apartment);
        const band = bandFor(percentile);
        const value = Number(apartment[activeMetric] || 0);
        const isSelected = apartment.s === selectedApartmentSlug;
        const isCompared = compareSlugs.includes(apartment.s);
        const icon = L.divIcon({
          className: `complex-marker-wrap${isSelected ? ' selected-complex' : ''}${isCompared ? ' compared-complex' : ''}`,
          html: `<div class="complex-marker ${band}${isSelected ? ' selected' : ''}${isCompared ? ' compared' : ''}"><span>${escapeHtml(apartment.n)}</span><strong>${value ? `${formatNumber(value)}원/㎡` : '관리비 미공개'}</strong></div>`,
          iconSize: [20, 20],
          iconAnchor: [10, 10]
        });
        const marker = L.marker([latitude, longitude], {
          icon,
          title: `${apartment.n} · ${formatWon(value)}/㎡`,
          keyboard: true,
          riseOnHover: true,
          zIndexOffset: isSelected ? 1000 : 0
        })
          .on('click', () => selectApartment(apartment.s, { center: false }))
          .on('mouseover', () => marker.getElement()?.classList.add('label-hover'))
          .on('mouseout', () => marker.getElement()?.classList.remove('label-hover'))
          .addTo(markerLayer);
        complexMarkerEntries.push({ marker, apartment, selected: isSelected, compared: isCompared });
        marker.bindTooltip(
          `<strong>${escapeHtml(apartment.n)}</strong><br>${escapeHtml(apartment.a)}`,
          { direction: 'top', offset: [0, -13], className: 'complex-tooltip' }
        );
        bounds.push([latitude, longitude]);
      });
      if (fitMap && bounds.length > 1) map.fitBounds(bounds, { padding: [52, 52], maxZoom: 16, animate: true });
      else if (fitMap && bounds.length === 1) map.setView(bounds[0], 16, { animate: true });
      mapCoordinateStatus = missingCoordinates ? `지도 ${bounds.length}개 · 좌표 확인 ${missingCoordinates}개` : `지도 ${bounds.length}개`;
      window.requestAnimationFrame(updateComplexLabels);
    };

    const refreshApartmentMode = (selected = null) => {
      const nearby = apartmentsInCurrentView(selected);
      renderApartmentMarkers(nearby, false, selected?.s || '');
      renderResults(nearby);
      if (count) count.textContent = `${formatNumber(nearby.length)}개 주변 단지`;
      if (metricLabelNode) metricLabelNode.textContent = `${metricLabel()} 기준 · 지도 이동 시 자동 갱신`;
      return nearby;
    };

    const centerApartment = (apartment) => {
      const coordinate = Number.isFinite(Number(apartment.la)) && Number.isFinite(Number(apartment.lo))
        ? { latitude: Number(apartment.la), longitude: Number(apartment.lo) }
        : null;
      if (selectedSlug !== apartment.s) return;
      const status = detail?.querySelector('[data-location-status]');
      if (!coordinate) {
        if (status) status.textContent = 'K-apt 지도 좌표 확인 중';
        const center = provinceCenters[apartment.sd];
        if (center) map.setView(center, 10);
        refreshApartmentMode(apartment);
        return;
      }
      if (status) status.textContent = '공개 주소 기준 위치';
      locatingSelection = true;
      let finished = false;
      let fallbackTimer = 0;
      const finishCentering = () => {
        if (finished) return;
        finished = true;
        window.clearTimeout(fallbackTimer);
        naver.maps.Event.removeListener(idleListener);
        locatingSelection = false;
        if (selectedSlug === apartment.s) refreshApartmentMode(apartment);
      };
      const idleListener = naver.maps.Event.addListener(rawMap, 'idle', () => {
        finishCentering();
      });
      map.setView([coordinate.latitude, coordinate.longitude], 16);
      window.requestAnimationFrame(() => {
        if (selectedSlug === apartment.s) refreshApartmentMode(apartment);
      });
      fallbackTimer = window.setTimeout(finishCentering, 500);
    };

    const renderResults = (items) => {
      if (!results) return;
      const hasQuery = Boolean((search?.value || '').trim());
      const rows = items.slice().sort((a, b) => hasQuery
        ? a.n.localeCompare(b.n, 'ko')
        : Number(b.q || 0) - Number(a.q || 0) || Number(b.h || 0) - Number(a.h || 0) || a.n.localeCompare(b.n, 'ko'))
        .slice(0, 6);
      if (!rows.length) {
        results.innerHTML = '<p class="empty-result">조건에 맞는 단지가 없습니다.</p>';
        return;
      }
      results.innerHTML = rows.map((item) => {
        const percentile = percentileFor(items, item);
        const band = bandFor(percentile);
        const isCompared = compareSlugs.includes(item.s);
        return `<article class="result-card ${band}${item.s === selectedSlug ? ' selected' : ''}${isCompared ? ' compared' : ''}">
          <button type="button" class="result-card-main" data-slug="${escapeHtml(item.s)}">
            <i aria-hidden="true"></i>
            <span>${escapeHtml(item.sd)} ${escapeHtml(item.sg)}</span>
            <strong>${escapeHtml(item.n)}</strong>
            <small>${escapeHtml(item.ht || '난방 미확인')} · ${formatNumber(item.h)}세대</small>
            <b>${percentile}p</b>
            <em>${formatWon(item[activeMetric])}/㎡</em>
          </button>
          <button type="button" class="result-compare${isCompared ? ' active' : ''}" data-compare-slug="${escapeHtml(item.s)}" aria-pressed="${isCompared}"><i aria-hidden="true"></i><span>${isCompared ? '선택됨' : '비교'}</span></button>
        </article>`;
      }).join('');
      results.querySelectorAll('[data-slug]').forEach((button) => {
        button.addEventListener('click', () => selectApartment(button.dataset.slug, { center: !apartmentMode }));
      });
      results.querySelectorAll('[data-compare-slug]').forEach((button) => {
        button.addEventListener('click', () => toggleCompare(button.dataset.compareSlug));
      });
    };

    const renderMobileSuggestions = (items) => {
      if (!mobileSuggestions) return;
      const query = (search?.value || '').trim().toLowerCase();
      if (!query || suggestionsDismissed) {
        mobileSuggestions.hidden = true;
        if (!query) mobileSuggestions.replaceChildren();
        app?.classList.remove('mobile-searching');
        return;
      }
      const relevance = (item) => {
        const name = String(item.n || '').toLowerCase();
        const area = `${item.sg} ${item.d}`.toLowerCase();
        if (name === query) return 0;
        if (name.startsWith(query)) return 1;
        if (name.includes(query)) return 2;
        if (area.includes(query)) return 3;
        return 4;
      };
      const rows = items.slice().sort((a, b) => relevance(a) - relevance(b) || a.n.localeCompare(b.n, 'ko')).slice(0, 4);
      mobileSuggestions.hidden = false;
      mobileSuggestions.innerHTML = `
        <div class="suggestion-heading"><strong>${formatNumber(items.length)}개 검색 결과</strong><button type="button" data-mobile-close>필터 보기</button></div>
        ${rows.map((item) => `<button type="button" class="suggestion-row" data-mobile-slug="${escapeHtml(item.s)}">
          <span><strong>${escapeHtml(item.n)}</strong><small>${escapeHtml(item.sd)} ${escapeHtml(item.sg)} · ${formatNumber(item.h)}세대</small></span>
          <em>${formatWon(item.tf)}/㎡</em>
        </button>`).join('')}
        ${rows.length ? '' : '<p>조건에 맞는 단지가 없습니다.</p>'}
      `;
      mobileSuggestions.querySelectorAll('[data-mobile-slug]').forEach((button) => {
        button.addEventListener('click', () => {
          app?.classList.remove('mobile-searching');
          search?.blur();
          selectApartment(button.dataset.mobileSlug);
          window.setTimeout(() => detail?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 180);
        });
      });
      mobileSuggestions.querySelector('[data-mobile-close]')?.addEventListener('click', () => {
        suggestionsDismissed = true;
        mobileSuggestions.hidden = true;
        app?.classList.remove('mobile-searching');
        search?.blur();
      });
    };

    const renderDetail = (apartment, comparison) => {
      if (!detail) return;
      const percentile = percentileFor(comparison, apartment);
      const band = bandFor(percentile);
      const isCompared = compareSlugs.includes(apartment.s);
      detail.innerHTML = `
        <button type="button" class="detail-close" data-detail-close aria-label="단지 정보 닫기">&#215;</button>
        <div class="detail-head">
          <span>${escapeHtml(apartment.sd)} ${escapeHtml(apartment.sg)} · ${escapeHtml(apartment.ht || '난방 미확인')}</span>
          <h2>${escapeHtml(apartment.n)}</h2>
          <p>${escapeHtml(apartment.a)}</p>
          <small data-location-status>지도 위치 준비 중</small>
        </div>
        <div class="detail-actions">
          <button type="button" class="detail-compare${isCompared ? ' active' : ''}" data-detail-compare aria-pressed="${isCompared}">${isCompared ? '비교에서 빼기' : '비교 담기'}</button>
          <button type="button" data-detail-share>단지 공유</button>
        </div>
        <div class="score-box ${band}">
          <section><span>${metricLabel()} 수준</span><strong>${bandLabel(band)}</strong><p>비슷한 규모 ${formatNumber(comparison.length)}개 단지 중 백분위 ${percentile}</p></section>
          <section><span>기준월 금액</span><strong>${formatWon(apartment[activeMetric])}</strong><p>관리비부과면적 ㎡당</p></section>
        </div>
        <p class="comparison-note">${escapeHtml(apartment.sg)} 공개 단지와 비교한 참고값입니다. 세대별 실제 청구액은 전용면적과 사용량에 따라 달라집니다.</p>
        <dl class="facts">
          <div><dt>세대수</dt><dd>${formatNumber(apartment.h)}세대</dd></div>
          <div><dt>사용승인</dt><dd>${apartment.y ? `${apartment.y}년` : '미확인'}</dd></div>
          <div><dt>관리방식</dt><dd>${escapeHtml(apartment.mt || '미확인')}</dd></div>
          <div><dt>기준월</dt><dd>${escapeHtml(apartment.lm || '미공개')}</dd></div>
          <div><dt>총 관리비</dt><dd>${formatWon(apartment.tf)}/㎡</dd></div>
          <div><dt>공용관리비</dt><dd>${formatWon(apartment.cf)}/㎡</dd></div>
          <div><dt>장기수선충당금</dt><dd>${formatWon(apartment.rf)}/㎡</dd></div>
          <div><dt>관리비 부과면적</dt><dd>${formatNumber(apartment.ma)}㎡</dd></div>
        </dl>
        ${apartment.q === 1
          ? `<a class="report-link" href="/apartments/${encodeURIComponent(apartment.s)}/">월별 관리비 리포트</a>`
          : '<p class="report-unavailable">최근 관리비 공개 이력이 5개월 미만입니다.</p>'}
      `;
      detail.querySelector('[data-detail-compare]')?.addEventListener('click', () => toggleCompare(apartment.s));
      detail.querySelector('[data-detail-share]')?.addEventListener('click', () => shareLink({
        title: `${apartment.n} 관리비`,
        text: `${apartment.n}의 공개 관리비와 단지 정보를 확인해 보세요.`,
        url: apartmentShareUrl(apartment.s)
      }));
      detail.querySelector('[data-detail-close]')?.addEventListener('click', () => {
        selectedSlug = '';
        selectionNeedsCenter = false;
        const url = new URL(window.location.href);
        url.searchParams.delete('apt');
        history.replaceState({}, '', url);
        render();
      });
      const shouldCenter = selectionNeedsCenter;
      selectionNeedsCenter = false;
      if (shouldCenter) centerApartment(apartment);
      else {
        const status = detail.querySelector('[data-location-status]');
        if (status) status.textContent = '공개 주소 기준 위치';
        refreshApartmentMode(apartment);
      }
    };

    const selectApartment = (slug, { center = true } = {}) => {
      selectedSlug = slug;
      apartmentMode = true;
      selectionNeedsCenter = center;
      suggestionsDismissed = true;
      const apartment = apartments.find((item) => item.s === slug);
      if (apartment) {
        activeProvince = apartment.sd;
        activeDistrict = districtKey(apartment.sd, apartment.sg);
        activeDong = apartment.d;
        if (region) region.value = apartment.sd;
      }
      const url = new URL(window.location.href);
      url.searchParams.set('apt', slug);
      history.replaceState({}, '', url);
      render();
    };

    const openProvince = (name) => {
      apartmentMode = false;
      activeProvince = name;
      activeDistrict = '';
      activeDong = '';
      selectedSlug = '';
      region.value = name;
      map.setView(provinceCenters[name], 11, { animate: true });
      render();
    };

    const openDistrict = (key, coordinate) => {
      apartmentMode = false;
      activeDistrict = key;
      activeDong = '';
      selectedSlug = '';
      map.setView(coordinate, 13, { animate: true });
      render();
    };

    const openDong = (name, coordinate) => {
      apartmentMode = true;
      selectionNeedsCenter = false;
      activeDong = name;
      selectedSlug = '';
      map.setView(coordinate, 15, { animate: true });
      render({ fitMap: true });
    };

    const updateMapNavigation = () => {
      if (!mapBack) return;
      const district = districtCenters.get(activeDistrict);
      mapBack.hidden = !activeProvince;
      mapBack.textContent = activeDistrict
        ? `${activeProvince} · ${district?.district || ''}`
        : activeProvince || '';
      mapBack.setAttribute('aria-label', activeDistrict ? '시도 단계로 돌아가기' : '전국 단계로 돌아가기');
    };

    const render = ({ fitMap = false } = {}) => {
      const filtered = filteredApartments();
      const navigated = filtered.filter((item) =>
        (!activeDistrict || districtKey(item.sd, item.sg) === activeDistrict)
        && (!activeDong || item.d === activeDong));
      const hasQuery = Boolean((search?.value || '').trim());
      const selected = apartments.find((item) => item.s === selectedSlug);
      app?.classList.toggle('has-detail', Boolean(selected));
      app?.classList.toggle('apartment-mode', apartmentMode);
      if (selected) renderDetail(selected, comparisonForApartment(selected));
      else if (apartmentMode) refreshApartmentMode();
      else if (activeDistrict) renderDongMarkers(navigated, fitMap);
      else if (activeProvince) renderDistrictMarkers(filtered, fitMap);
      else renderProvinceMarkers(filtered, fitMap);
      renderResults(apartmentMode ? apartmentsInCurrentView(selected || null) : navigated);
      renderMobileSuggestions(navigated);
      updateMapNavigation();
      renderCompareTray();
      if (count && !apartmentMode) count.textContent = `${formatNumber(navigated.length)}개 단지`;
      if (searchFeedback) {
        searchFeedback.hidden = !hasQuery;
        searchFeedback.textContent = hasQuery ? `${formatNumber(filtered.length)}개 찾음` : '';
      }
      if (metricLabelNode && !apartmentMode) metricLabelNode.textContent = `${metricLabel()} 기준${mapCoordinateStatus ? ` · ${mapCoordinateStatus}` : ''}`;
      app?.classList.toggle('empty', navigated.length === 0);
    };

    search?.addEventListener('input', () => {
      window.clearTimeout(inputTimer);
      suggestionsDismissed = false;
      if ((search.value || '').trim()) app?.classList.add('mobile-searching');
      else app?.classList.remove('mobile-searching');
      if (searchFeedback) {
        searchFeedback.hidden = !(search.value || '').trim();
        searchFeedback.textContent = (search.value || '').trim() ? '검색 중' : '';
      }
      inputTimer = window.setTimeout(() => {
        selectedSlug = '';
        activeDong = '';
        apartmentMode = false;
        render();
      }, 120);
    });
    search?.addEventListener('focus', () => {
      if ((search.value || '').trim()) {
        suggestionsDismissed = false;
        app?.classList.add('mobile-searching');
        render();
      }
    });
    search?.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter') return;
      event.preventDefault();
      window.clearTimeout(inputTimer);
      selectedSlug = '';
      activeDong = '';
      apartmentMode = false;
      render();
      search.blur();
      window.setTimeout(() => document.querySelector('.search-field')?.scrollIntoView({ behavior: 'smooth', block: 'start' }), 120);
    });
    region?.addEventListener('change', () => {
      selectedSlug = '';
      apartmentMode = false;
      activeProvince = region.value === 'all' ? '' : region.value;
      activeDistrict = '';
      activeDong = '';
      render({ fitMap: true });
    });
    households?.addEventListener('change', () => {
      selectedSlug = '';
      activeDong = '';
      apartmentMode = false;
      render();
    });
    metricButtons.forEach((button) => button.addEventListener('click', () => {
      activeMetric = button.dataset.metric || 'tf';
      metricButtons.forEach((item) => item.classList.toggle('active', item === button));
      render();
    }));
    reset?.addEventListener('click', () => {
      search.value = '';
      region.value = 'all';
      households.value = 'all';
      selectedSlug = '';
      activeProvince = '';
      activeDistrict = '';
      activeDong = '';
      apartmentMode = false;
      selectionNeedsCenter = false;
      compareSlugs = [];
      compareDialogOpen = false;
      document.body.classList.remove('compare-dialog-open');
      app?.classList.remove('mobile-searching');
      activeMetric = 'tf';
      metricButtons.forEach((item) => item.classList.toggle('active', item.dataset.metric === 'tf'));
      history.replaceState({}, '', window.location.pathname);
      map.setView([36.35, 127.85], window.matchMedia('(max-width: 720px)').matches ? 6 : 7, { animate: true });
      render();
    });

    mapBack?.addEventListener('click', () => {
      selectedSlug = '';
      apartmentMode = false;
      selectionNeedsCenter = false;
      if (activeDistrict) {
        activeDistrict = '';
        activeDong = '';
        map.setView(provinceCenters[activeProvince], 11, { animate: true });
      } else {
        activeProvince = '';
        region.value = 'all';
        map.setView([36.35, 127.85], window.matchMedia('(max-width: 720px)').matches ? 6 : 7, { animate: true });
      }
      render();
    });

    compareOpen?.addEventListener('click', openComparison);
    compareClear?.addEventListener('click', () => {
      compareSlugs = [];
      compareDialogOpen = false;
      syncComparisonUrl();
      render();
    });
    app?.querySelectorAll('[data-compare-close]').forEach((button) => {
      button.addEventListener('click', closeComparison);
    });
    compareShare?.addEventListener('click', () => {
      const items = comparedApartments();
      shareLink({
        title: '단지표 아파트 관리비 비교',
        text: `${items.map((item) => item.n).join(', ')} 관리비 비교 결과입니다.`,
        url: comparisonShareUrl()
      });
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && compareDialogOpen) closeComparison();
    });

    map.on('zoomend', () => {
      const zoom = map.getZoom();
      updateComplexLabels();
      if (apartmentMode) return;
      let changed = false;
      if (selectedSlug && zoom < 14 && !locatingSelection) {
        selectedSlug = '';
        const url = new URL(window.location.href);
        url.searchParams.delete('apt');
        history.replaceState({}, '', url);
        changed = true;
      }
      if (zoom <= 8 && activeProvince) {
        activeProvince = '';
        activeDistrict = '';
        activeDong = '';
        region.value = 'all';
        changed = true;
      } else if (zoom <= 11 && activeDistrict) {
        activeDistrict = '';
        activeDong = '';
        changed = true;
      } else if (zoom <= 13 && activeDong) {
        activeDong = '';
        changed = true;
      }
      if (!activeProvince && zoom >= 9) {
        const center = map.getCenter();
        const available = [...new Set(filteredApartments().map((item) => item.sd))].filter((name) => provinceCenters[name]);
        const nearest = available.sort((a, b) => distanceBetween(center, provinceCenters[a]) - distanceBetween(center, provinceCenters[b]))[0];
        if (nearest) {
          activeProvince = nearest;
          region.value = nearest;
          changed = true;
        }
      }
      if (activeProvince && !activeDistrict && zoom >= 12) {
        const center = map.getCenter();
        const available = [...new Set(filteredApartments().map((item) => districtKey(item.sd, item.sg)))]
          .map((key) => [key, districtCenters.get(key)])
          .filter((entry) => entry[1]);
        const nearest = available.sort((a, b) => distanceBetween(center, [a[1].latitude, a[1].longitude]) - distanceBetween(center, [b[1].latitude, b[1].longitude]))[0];
        if (nearest) {
          activeDistrict = nearest[0];
          changed = true;
        }
      }
      if (changed) render();
    });
    map.on('moveend', () => {
      updateComplexLabels();
      if (!apartmentMode || locatingSelection) return;
      const selected = apartments.find((item) => item.s === selectedSlug) || null;
      refreshApartmentMode(selected);
    });

    fetch(payload.indexUrl)
      .then((response) => {
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        return response.json();
      })
      .then((data) => {
        apartments = Array.isArray(data) ? data : [];
        compareSlugs = compareSlugs.filter((slug) => apartments.some((item) => item.s === slug)).slice(0, 4);
        if (compareSlugs.length < 2) compareDialogOpen = false;
        if (selectedSlug && !apartments.some((item) => item.s === selectedSlug)) {
          selectedSlug = '';
          apartmentMode = false;
          selectionNeedsCenter = false;
        }
        render({ fitMap: true });
      })
      .catch(() => {
        if (count) count.textContent = '전국 데이터를 불러오지 못했습니다';
        if (results) results.innerHTML = '<p class="empty-result">잠시 후 다시 시도해 주세요.</p>';
      });
  </script>
</BaseLayout>

<style is:global>
