---
import BaseLayout from '@/layouts/BaseLayout.astro';
import 'leaflet/dist/leaflet.css';
import {
  apartmentComplexes,
  apartmentMetrics,
  apartmentRegions,
  feeBandLabels,
  getHouseholdBand,
  getLatestFee,
  getTopInsightMetrics
} from '@/data/apartments';
import { generatedApartmentComplexes } from '@/data/apartments.generated';

const isRealData = generatedApartmentComplexes.length > 0;

const mapApartments = apartmentComplexes.map((apartment) => ({
  slug: apartment.slug,
  name: apartment.name,
  region: `${apartment.sido} ${apartment.sigungu}`,
  sigungu: apartment.sigungu,
  dong: apartment.dong,
  address: apartment.address,
  households: apartment.households,
  householdBand: getHouseholdBand(apartment.households),
  approvalYear: apartment.approvalYear,
  heatingType: apartment.heatingType,
  managementType: apartment.managementType,
  latitude: apartment.latitude,
  longitude: apartment.longitude,
  peerGroup: apartment.peerGroup,
  headline: apartment.headline,
  summary: apartment.summary,
  percentileByMetric: apartment.percentileByMetric,
  latestFee: getLatestFee(apartment),
  topDrivers: getTopInsightMetrics(apartment, 3),
  monthlyFees: apartment.monthlyFees.map((fee) => ({
    month: fee.month,
    totalFeePerM2: fee.totalFeePerM2,
    commonFeePerM2: fee.commonFeePerM2,
    securityFee: fee.securityFee,
    heatingFee: fee.heatingFee,
    reserveFee: fee.reserveFee
  })),
  nearbySlugs: apartment.nearbySlugs
}));
---
<BaseLayout
  title="우리 단지 관리비 지도 | 바로계산"
  description="단지명을 찾아 관리비가 비슷한 단지 대비 어느 수준인지 확인합니다."
  canonical="/map/"
  robots={isRealData ? 'index, follow' : 'noindex, nofollow'}
>
  <section class="fee-map-shell" data-apartment-app>
    <header class="map-product-head">
      <div>
        <h1>우리 단지 관리비, 어디쯤일까?</h1>
        <p>총액, 경비비, 난방비, 장기수선충당금을 바꿔보며 주변 단지와 비교합니다.</p>
      </div>
      <div class="head-actions">
        <a href="/apartments/">단지 리포트</a>
      </div>
    </header>

    <div class="map-filterbar" aria-label="관리비 지도 필터">
      <label class="global-search">
        <span aria-hidden="true">⌕</span>
        <input type="search" data-apartment-search placeholder="단지명이나 동네를 입력하세요" autocomplete="off" />
      </label>

      <div class="metric-tabs" role="list" aria-label="분석 항목">
        {apartmentMetrics.map((metric) => (
          <button type="button" data-metric={metric.key} class={metric.key === 'totalFeePerM2' ? 'active' : ''}>
            {metric.shortLabel}
          </button>
        ))}
      </div>

      <label class="select-filter">
        <span>지역</span>
        <select data-region-filter>
          <option value="all">전체</option>
          {apartmentRegions.map((region) => <option value={region}>{region}</option>)}
        </select>
      </label>

      <label class="select-filter">
        <span>세대수</span>
        <select data-household-filter>
          <option value="all">전체</option>
          <option value="300~499세대">300~499</option>
          <option value="500~999세대">500~999</option>
          <option value="1000~1499세대">1000~1499</option>
          <option value="1500세대 이상">1500+</option>
        </select>
      </label>

      <button type="button" class="reset-button" data-map-reset>초기화</button>
    </div>

    <section class="map-app">
      <div class="map-stage">
        <div class="map-toolbar">
          <div>
            <strong data-map-count>{apartmentComplexes.length}개 단지</strong>
            <span data-active-metric>총 관리비 기준</span>
          </div>
          <div class="legend" aria-label="마커 색상 설명">
            <span><i class="low"></i>낮음</span>
            <span><i class="average"></i>평균권</span>
            <span><i class="high"></i>높음</span>
            <span><i class="very-high"></i>매우 높음</span>
          </div>
        </div>

        <div class="map-canvas" id="apartment-real-map" aria-label="종로구 아파트 관리비 지도"></div>

        <div class="nearby-table">
          <div class="table-head">
            <strong>비슷한 단지</strong>
            <span>선택한 항목이 높은 순</span>
          </div>
          <div class="nearby-strip" data-result-list aria-label="검색 결과 단지"></div>
        </div>
      </div>

      <aside class="detail-panel" data-detail-panel aria-label="선택 단지 요약"></aside>
    </section>

    <section class="next-build">
      <strong>데이터 기준</strong>
      <p>{isRealData ? '국토교통부 공동주택관리정보 공개자료를 ㎡당 금액으로 환산해 비교합니다.' : '현재 화면은 기능 검증용 데이터입니다.'}</p>
    </section>
  </section>

  <script is:inline type="application/json" id="apartment-map-data" set:html={JSON.stringify({
    apartments: mapApartments,
    metrics: apartmentMetrics,
    bandLabels: feeBandLabels
  })} />

  <script>
    // @ts-nocheck
    import L from 'leaflet';
    {
      const dataNode = document.getElementById('apartment-map-data');
      const payload = JSON.parse(dataNode?.textContent || '{"apartments":[],"metrics":[]}');
      const apartments = payload.apartments;
      const metrics = payload.metrics;
      const bandLabels = payload.bandLabels;

      const app = document.querySelector('[data-apartment-app]');
      const mapNode = document.querySelector('#apartment-real-map');
      const detailPanel = document.querySelector('[data-detail-panel]');
      const resultList = document.querySelector('[data-result-list]');
      const searchInput = document.querySelector('[data-apartment-search]');
      const metricButtons = [...document.querySelectorAll('[data-metric]')];
      const regionFilter = document.querySelector('[data-region-filter]');
      const householdFilter = document.querySelector('[data-household-filter]');
      const resetButton = document.querySelector('[data-map-reset]');
      const countNode = document.querySelector('[data-map-count]');
      const activeMetricNode = document.querySelector('[data-active-metric]');
      const initialSlug = new URLSearchParams(window.location.search).get('apt');

      const locatedApartments = apartments.filter((apartment) =>
        Number.isFinite(apartment.latitude) && Number.isFinite(apartment.longitude)
      );
      const initialCenter = locatedApartments.length
        ? [
            locatedApartments.reduce((sum, apartment) => sum + apartment.latitude, 0) / locatedApartments.length,
            locatedApartments.reduce((sum, apartment) => sum + apartment.longitude, 0) / locatedApartments.length
          ]
        : [37.573, 126.989];
      const realMap = L.map(mapNode, { zoomControl: true, attributionControl: true }).setView(initialCenter, 14);
      L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19,
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(realMap);
      const markerLayer = L.layerGroup().addTo(realMap);

      let activeMetric = 'totalFeePerM2';
      let selectedSlug = apartments.some((apartment) => apartment.slug === initialSlug)
        ? initialSlug
        : apartments[0]?.slug;

      const metricLabel = (key) => metrics.find((metric) => metric.key === key)?.label || '총 관리비';
      const formatWon = (value) => `${Number(value || 0).toLocaleString('ko-KR')}원`;
      const bandFor = (percentile) => {
        if (percentile >= 85) return 'very-high';
        if (percentile >= 65) return 'high';
        if (percentile <= 35) return 'low';
        return 'average';
      };

      const getFilteredApartments = () => {
        const query = (searchInput?.value || '').trim().toLowerCase();
        const region = regionFilter?.value || 'all';
        const household = householdFilter?.value || 'all';

        return apartments.filter((apartment) => {
          const haystack = [
            apartment.name,
            apartment.region,
            apartment.sigungu,
            apartment.dong,
            apartment.address,
            apartment.heatingType,
            apartment.headline
          ]
            .join(' ')
            .toLowerCase();
          return (
            (!query || haystack.includes(query)) &&
            (region === 'all' || apartment.region === region) &&
            (household === 'all' || apartment.householdBand === household)
          );
        });
      };

      const sparkline = (fees) => {
        const values = fees.map((fee) => fee.totalFeePerM2);
        const min = Math.min(...values);
        const max = Math.max(...values);
        const width = 240;
        const height = 70;
        const points = values
          .map((value, index) => {
            const x = (index / Math.max(values.length - 1, 1)) * width;
            const y = height - ((value - min) / Math.max(max - min, 1)) * (height - 8) - 4;
            return `${x.toFixed(1)},${y.toFixed(1)}`;
          })
          .join(' ');
        return `<svg viewBox="0 0 ${width} ${height}" role="img" aria-label="최근 12개월 총 관리비 추이"><polyline points="${points}" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" /></svg>`;
      };

      const selectApartment = (slug) => {
        selectedSlug = slug;
        render();
      };

      const renderMarkers = (filtered) => {
        markerLayer.clearLayers();
        const bounds = [];
        filtered
          .filter((apartment) => Number.isFinite(apartment.latitude) && Number.isFinite(apartment.longitude))
          .forEach((apartment) => {
          const percentile = apartment.percentileByMetric[activeMetric];
          const band = bandFor(percentile);
          const selected = apartment.slug === selectedSlug ? ' selected' : '';
          const icon = L.divIcon({
            className: 'apartment-marker-wrap',
            html: `<div class="map-marker ${band}${selected}"><strong>${percentile}</strong><span>${apartment.name}</span></div>`,
            iconSize: [38, 38],
            iconAnchor: [19, 19]
          });
          const coordinate = [apartment.latitude, apartment.longitude];
          L.marker(coordinate, {
            icon,
            title: `${apartment.name} · ${metricLabel(activeMetric)} 백분위 ${percentile}`,
            keyboard: true
          }).on('click', () => selectApartment(apartment.slug)).addTo(markerLayer);
          bounds.push(coordinate);
        });
        if (bounds.length > 1) realMap.fitBounds(bounds, { padding: [42, 42], maxZoom: 15 });
        else if (bounds.length === 1) realMap.setView(bounds[0], 16);
      };

      const renderResultList = (filtered) => {
        resultList.replaceChildren();
        filtered
          .slice()
          .sort((a, b) => b.percentileByMetric[activeMetric] - a.percentileByMetric[activeMetric])
          .forEach((apartment) => {
            const button = document.createElement('button');
            const percentile = apartment.percentileByMetric[activeMetric];
            const band = bandFor(percentile);
            const fee = apartment.latestFee[activeMetric] || apartment.latestFee.totalFeePerM2;
            button.type = 'button';
            button.className = `result-card ${band}`;
            button.classList.toggle('selected', apartment.slug === selectedSlug);
            button.innerHTML = `
              <i aria-hidden="true"></i>
              <span>${apartment.region}</span>
              <strong>${apartment.name}</strong>
              <small>${apartment.heatingType} · ${apartment.households.toLocaleString('ko-KR')}세대</small>
              <b>${percentile}p</b>
              <em>${formatWon(fee)}/m2</em>
            `;
            button.addEventListener('click', () => selectApartment(apartment.slug));
            resultList.append(button);
          });
      };

      const renderDetail = () => {
        const apartment = apartments.find((item) => item.slug === selectedSlug) || apartments[0];
        if (!apartment) return;
        const percentile = apartment.percentileByMetric[activeMetric];
        const band = bandFor(percentile);
        const latest = apartment.latestFee;
        const activeFee = latest[activeMetric] || latest.totalFeePerM2;
        const drivers = apartment.topDrivers
          .map(
            (driver) => `<li><span>${driver.label}</span><strong>백분위 ${driver.percentile}</strong><i style="width:${driver.percentile}%"></i></li>`
          )
          .join('');
        const nearby = apartment.nearbySlugs
          .map((slug) => apartments.find((item) => item.slug === slug))
          .filter(Boolean)
          .map(
            (item) => `<button type="button" data-nearby="${item.slug}"><span>${item.sigungu}</span><strong>${item.name}</strong></button>`
          )
          .join('');

        detailPanel.innerHTML = `
          <div class="detail-title-row">
            <button type="button" aria-label="즐겨찾기">☆</button>
            <div>
              <span>${apartment.region} · ${apartment.heatingType}</span>
              <h2>${apartment.name}</h2>
              <p>${apartment.address}</p>
            </div>
          </div>

          <div class="score-card ${band}">
            <section>
              <span>${metricLabel(activeMetric)} 수준</span>
              <strong>${bandLabels[band]}</strong>
              <p>비슷한 단지 중 백분위 ${percentile}</p>
            </section>
            <section>
              <span>기준월 금액</span>
              <strong>${formatWon(activeFee)}</strong>
              <p>m2당 기준 금액</p>
            </section>
          </div>

          <div class="summary-box">
            <strong>${apartment.headline}</strong>
            <p>${apartment.summary}</p>
          </div>
          <dl class="fact-grid">
            <div><dt>세대수</dt><dd>${apartment.households.toLocaleString('ko-KR')}세대</dd></div>
            <div><dt>준공</dt><dd>${apartment.approvalYear}년</dd></div>
            <div><dt>관리방식</dt><dd>${apartment.managementType}</dd></div>
            <div><dt>기준월 총액</dt><dd>${formatWon(latest.totalFeePerM2)}/m2</dd></div>
          </dl>
          <div class="trend-box">
            <div><strong>최근 12개월</strong><span>${formatWon(apartment.monthlyFees[0].totalFeePerM2)} → ${formatWon(latest.totalFeePerM2)}</span></div>
            ${sparkline(apartment.monthlyFees)}
          </div>
          <div class="driver-box">
            <strong>높게 보는 항목</strong>
            <ul>${drivers}</ul>
          </div>
          <div class="nearby-box">
            <strong>가까운 비교 단지</strong>
            ${nearby}
          </div>
          <a class="report-link" href="/apartments/${apartment.slug}/">리포트 자세히 보기</a>
        `;
        detailPanel.querySelectorAll('[data-nearby]').forEach((button) => {
          button.addEventListener('click', () => selectApartment(button.dataset.nearby));
        });
      };

      const render = () => {
        const filtered = getFilteredApartments();
        if (!filtered.some((apartment) => apartment.slug === selectedSlug)) {
          selectedSlug = filtered[0]?.slug || apartments[0]?.slug;
        }
        renderMarkers(filtered);
        renderResultList(filtered);
        renderDetail();
        if (countNode) countNode.textContent = `${filtered.length}개 단지`;
        if (activeMetricNode) activeMetricNode.textContent = `${metricLabel(activeMetric)} 기준`;
        app?.classList.toggle('is-empty', filtered.length === 0);
      };

      searchInput?.addEventListener('input', render);
      regionFilter?.addEventListener('change', render);
      householdFilter?.addEventListener('change', render);
      metricButtons.forEach((button) => {
        button.addEventListener('click', () => {
          activeMetric = button.dataset.metric || 'totalFeePerM2';
          metricButtons.forEach((item) => item.classList.toggle('active', item === button));
          render();
        });
      });
      resetButton?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        if (regionFilter) regionFilter.value = 'all';
        if (householdFilter) householdFilter.value = 'all';
        activeMetric = 'totalFeePerM2';
        metricButtons.forEach((item) => item.classList.toggle('active', item.dataset.metric === activeMetric));
        render();
      });

      render();
    }
  </script>
</BaseLayout>

<style is:global>
  .main-content:has(.fee-map-shell) {
    width: min(1540px, calc(100vw - 28px));
    padding-top: 14px;
  }
  .fee-map-shell {
    --map-line: #dfe7e3;
    --map-soft: #f4f8f6;
    --map-green: #008f73;
    --map-ink: #17211d;
    display: grid;
    gap: 12px;
  }
  .map-product-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 56px;
  }
  .map-product-head h1 {
    margin: 0;
    color: var(--map-ink);
    font: 750 1.65rem/1.1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  .map-product-head p {
    margin: 5px 0 0;
    color: #5d6964;
    font: 750 0.9rem/1.35 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .head-actions {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #6a7771;
    font: 650 0.78rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    white-space: nowrap;
  }
  .head-actions a,
  .report-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    border-radius: 8px;
    background: #08765c;
    color: #fff;
    text-decoration: none;
    padding: 0 14px;
    font: 750 0.86rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .map-filterbar {
    display: grid;
    grid-template-columns: minmax(260px, 1.5fr) minmax(340px, 2.2fr) 145px 126px auto;
    gap: 8px;
    align-items: center;
    border: 1px solid var(--map-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.98);
    padding: 10px;
    box-shadow: 0 10px 26px rgba(23, 33, 29, 0.06);
  }
  .global-search {
    display: flex;
    align-items: center;
    gap: 8px;
    min-height: 42px;
    border: 1px solid #d7e2dd;
    border-radius: 8px;
    background: #fff;
    padding: 0 12px;
  }
  .global-search span {
    color: #6b7772;
    font: 750 1.25rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .global-search input,
  .select-filter select {
    width: 100%;
    border: 0;
    background: transparent;
    color: var(--map-ink);
    font: 650 0.9rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    outline: 0;
  }
  .metric-tabs {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 5px;
  }
  .metric-tabs button,
  .reset-button,
  .result-card,
  .nearby-box button,
  .detail-title-row button {
    border: 1px solid #d8e3de;
    border-radius: 8px;
    background: #fff;
    color: var(--map-ink);
    cursor: pointer;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .metric-tabs button {
    min-height: 42px;
    padding: 0 6px;
    font: 750 0.78rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .metric-tabs button.active {
    border-color: rgba(0, 143, 115, 0.42);
    background: #e8f7f2;
    color: #006d58;
    box-shadow: inset 0 0 0 1px rgba(0, 143, 115, 0.08);
  }
  .select-filter {
    display: grid;
    gap: 3px;
    min-height: 42px;
    border: 1px solid #d8e3de;
    border-radius: 8px;
    background: #fff;
    padding: 6px 10px;
  }
  .select-filter span {
    color: #7a8781;
    font: 700 0.66rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .reset-button {
    min-height: 42px;
    padding: 0 12px;
    color: #4f5d57;
    font: 750 0.82rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .map-app {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 384px;
    gap: 12px;
    align-items: stretch;
  }
  .map-stage,
  .detail-panel,
  .next-build {
    border: 1px solid var(--map-line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 12px 30px rgba(23, 33, 29, 0.07);
  }
  .map-stage {
    display: grid;
    grid-template-rows: auto minmax(545px, 1fr) auto;
    overflow: hidden;
    min-width: 0;
  }
  .map-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    min-height: 54px;
    border-bottom: 1px solid #e0e8e4;
    padding: 0 14px;
  }
  .map-toolbar strong,
  .table-head strong,
  .driver-box > strong,
  .nearby-box > strong,
  .trend-box strong {
    color: var(--map-ink);
    font: 750 0.95rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .map-toolbar span,
  .table-head span {
    color: #66736e;
    font: 800 0.76rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .legend {
    display: flex;
    align-items: center;
    gap: 11px;
    flex-wrap: wrap;
  }
  .legend span {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .legend i {
    width: 10px;
    height: 10px;
    border-radius: 999px;
  }
  .legend .low { background: #16a172; }
  .legend .average { background: #75827c; }
  .legend .high { background: #d38a19; }
  .legend .very-high { background: #cf4438; }
  .map-canvas {
    position: relative;
    min-height: 545px;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(132, 146, 138, 0.15) 1px, transparent 1px),
      linear-gradient(0deg, rgba(132, 146, 138, 0.15) 1px, transparent 1px),
      linear-gradient(135deg, rgba(212, 224, 218, 0.38), transparent 42%),
      #eef4f1;
    background-size: 48px 48px, 48px 48px, auto, auto;
  }
  .map-canvas::before,
  .map-canvas::after {
    content: "";
    position: absolute;
    inset: auto;
    pointer-events: none;
  }
  .map-canvas::before {
    left: -10%;
    top: 22%;
    width: 120%;
    height: 16px;
    transform: rotate(24deg);
    border-radius: 999px;
    background: rgba(248, 251, 249, 0.96);
    box-shadow:
      0 86px 0 rgba(248, 251, 249, 0.9),
      0 172px 0 rgba(248, 251, 249, 0.82);
  }
