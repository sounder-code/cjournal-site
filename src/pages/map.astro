  .mobile-suggestions { display: none; }
  .mobile-suggestions:not([hidden]) { position: absolute; top: calc(100% + 6px); left: 112px; z-index: 4; width: min(460px, calc(100% - 126px)); display: grid; overflow: hidden; border: 1px solid #d5dfda; border-radius: 7px; background: #fff; box-shadow: 0 14px 34px rgba(25, 46, 37, .18); }
  .suggestion-heading { min-height: 36px; display: flex; align-items: center; justify-content: space-between; gap: 10px; padding: 0 11px; background: #f5f8f6; }
  .suggestion-heading strong { color: #4e5a54; font-size: .7rem; }
  .suggestion-heading button { border: 0; background: transparent; color: #08765c; font-size: .68rem; font-weight: 850; cursor: pointer; }
  .suggestion-row { min-width: 0; min-height: 58px; display: grid; grid-template-columns: minmax(0, 1fr) auto; align-items: center; gap: 10px; border: 0; border-top: 1px solid #e7ece9; background: #fff; padding: 9px 11px; text-align: left; cursor: pointer; }
  .suggestion-row:hover { background: #f1f7f4; }
  .suggestion-row > span { min-width: 0; display: grid; gap: 4px; }
  .suggestion-row strong { overflow: hidden; color: var(--ink); font-size: .8rem; text-overflow: ellipsis; white-space: nowrap; }
  .suggestion-row small { overflow: hidden; color: #75807a; font-size: .65rem; font-weight: 720; text-overflow: ellipsis; white-space: nowrap; }
  .suggestion-row em { color: #08765c; font-size: .7rem; font-style: normal; font-weight: 850; white-space: nowrap; }
  .mobile-suggestions > p { margin: 0; padding: 18px 11px; color: #707b75; font-size: .75rem; }
  .metric-control { display: grid; grid-template-columns: repeat(3, 1fr); gap: 5px; }
  .metric-control button, .reset-button { border: 1px solid #d9e1dc; border-radius: 7px; background: #fff; color: #45514b; font-size: .76rem; font-weight: 850; cursor: pointer; }
  .metric-control button.active { border-color: #8ac8b7; background: #e8f5f1; color: #006c55; }
  .reset-button { padding: 0 14px; }
  .workspace { min-height: 680px; display: grid; grid-template-columns: minmax(0, 1fr) 380px; gap: 12px; }
  .map-pane, .detail-pane, .source-note { border: 1px solid var(--line); border-radius: 8px; background: #fff; box-shadow: 0 10px 28px rgba(23, 33, 29, .06); }
  .map-pane { min-width: 0; display: grid; grid-template-rows: auto minmax(500px, 1fr) auto; overflow: hidden; }
  .map-status { min-height: 52px; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 0 14px; border-bottom: 1px solid #e4e9e6; }
  .map-status > div:first-child { display: flex; align-items: center; gap: 9px; }
  .map-summary button { min-height: 30px; border: 1px solid #cddbd4; border-radius: 6px; background: #f5f9f7; color: #076e57; padding: 0 9px; font-size: .68rem; font-weight: 850; cursor: pointer; }
  .map-summary button::before { content: '\2190'; margin-right: 5px; }
  .map-status strong { color: var(--ink); font-size: .9rem; }
  .map-status span, .result-heading span { color: #6e7973; font-size: .7rem; font-weight: 750; }
  .legend { display: flex; gap: 10px; }
  .legend span { display: inline-flex; align-items: center; gap: 5px; }
