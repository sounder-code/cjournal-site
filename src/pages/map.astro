  .area-marker strong { max-width: 78px; overflow: hidden; font-size: .7rem; line-height: 1.15; text-overflow: ellipsis; white-space: nowrap; }
  .area-marker span { color: rgba(255, 255, 255, .86); font-size: .59rem; font-weight: 760; white-space: nowrap; }
  .area-marker.dong { border-color: #08765c; background: #fff; color: #075f4c; box-shadow: 0 6px 16px rgba(23, 33, 29, .2); }
