  .filter-bar { display: grid; grid-template-columns: auto minmax(260px, 1fr) 230px 180px 170px auto; gap: 8px; padding: 10px; border: 1px solid var(--line); border-radius: 8px; background: #fff; box-shadow: 0 8px 24px rgba(23, 33, 29, .05); }
  .map-brand { min-height: 44px; display: inline-flex; align-items: center; gap: 8px; color: var(--ink); text-decoration: none; white-space: nowrap; }
  .map-brand > span { width: 28px; height: 28px; display: grid; place-items: center; border-radius: 7px; background: #08765c; }
  .map-brand i { width: 12px; height: 12px; border: 3px solid #fff; border-radius: 50%; }
  .map-brand strong { font-size: .88rem; font-weight: 850; }
  .search-field, .select-field { min-height: 44px; display: grid; align-items: center; gap: 10px; border: 1px solid #d9e1dc; border-radius: 7px; padding: 0 12px; }
  .search-field { grid-template-columns: auto minmax(0, 1fr) auto; }
  .select-field { grid-template-columns: auto minmax(0, 1fr); }
  .search-field:focus-within { border-color: #70bba6; box-shadow: 0 0 0 3px rgba(8, 118, 92, .09); }
  .search-field span, .select-field span { color: #7a847f; font-size: .68rem; font-weight: 850; }
  .search-field input, .select-field select { width: 100%; border: 0; outline: 0; background: transparent; color: var(--ink); font-size: .82rem; font-weight: 730; }
