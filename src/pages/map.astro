  .area-marker.unmatched { border-color: #fff; background: #66736d; }
  .area-marker.selected { outline: 3px solid rgba(8, 118, 92, .2); transform: translateY(-2px); }
  .apartment-marker { position: relative; width: 28px; height: 28px; border: 3px solid #fff; border-radius: 50%; background: #08765c; box-shadow: 0 7px 18px rgba(23, 33, 29, .3); }
