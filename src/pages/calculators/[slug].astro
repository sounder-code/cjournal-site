---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalculatorTool from '@/components/CalculatorTool.astro';
import { calculators, groupLabels } from '@/data/calculators';
import { calculatorDetails } from '@/data/calculatorDetails';
import { guides } from '@/data/guides';

export function getStaticPaths() {
  return calculators.map((calculator) => ({
    params: { slug: calculator.slug },
    props: { calculator }
  }));
}

const { calculator } = Astro.props;
const calculatorScriptVersion = calculators.length;
const seoTitle = `${calculator.title} - 무료 계산 | 단지표`;
const inputKeywords = calculator.inputs
  .map((input) => input.label.replace(/[·/]/g, ' '))
  .slice(0, 6)
  .join(', ');
const seoDescription = `${calculator.description} ${inputKeywords}을 입력해 바로 계산하고 결과를 복사·공유할 수 있습니다.`;
const related = calculators
  .filter((item) => item.slug !== calculator.slug && item.group === calculator.group)
  .slice(0, 5);
const relatedGuides = guides.filter((guide) => guide.calculators.includes(calculator.slug)).slice(0, 3);
const currentIndex = calculators.findIndex((item) => item.slug === calculator.slug);
const previousCalculator = calculators[(currentIndex - 1 + calculators.length) % calculators.length];
const nextCalculator = calculators[(currentIndex + 1) % calculators.length];
const groupedCalculators = Object.entries(groupLabels).map(([group, label]) => ({
  group,
  label,
  items: calculators.filter((item) => item.group === group)
}));
const guideByGroup = {
  seller: [
    ['1. 비용을 빠짐없이 입력', '판매가만 보지 말고 수수료, 결제비, 배송비, 광고비, 반품 손실까지 함께 넣으세요.'],
    ['2. 주문 1건과 월 기준을 분리', '주문당 이익이 남아도 월 고정비와 광고비가 커지면 전체 손익은 달라질 수 있습니다.'],
    ['3. 플랫폼 조건 대조', '카테고리별 수수료, 정산 방식, 배송 정책은 플랫폼마다 다르므로 최종 판매 전 공식 안내와 맞춰보세요.']
  ],
  living: [
    ['1. 월요금보다 총액', '렌탈료나 통신비는 월 납입액보다 약정 기간 전체 비용으로 비교해야 조건이 보입니다.'],
    ['2. 할인과 위약금을 같이 계산', '사은품, 설치비, 위약금, 기존 할인 해지 여부를 함께 넣어야 실제 이득을 볼 수 있습니다.'],
    ['3. 계약 조건 대조', '프로모션과 약정 조건은 바뀔 수 있으니 신청 전 사업자 안내와 다시 맞춰보세요.']
  ],
  utility: [
    ['1. 월 현금흐름', '대출이나 사업 손익은 총액뿐 아니라 매월 빠져나가는 금액을 먼저 봐야 합니다.'],
    ['2. 기간이 길수록 총비용', '월 납입액이 작아도 기간이 길면 총이자나 기회비용이 크게 늘어날 수 있습니다.'],
    ['3. 실제 조건으로 재계산', '금리, 상환방식, 세금, 보험료 같은 조건이 달라지면 결과도 달라집니다.']
  ],
  housing: [
    ['1. 월평균 부담부터 확인', '월세와 관리비처럼 매달 나가는 돈에 보증금 기회비용, 중개보수 같은 일회성 비용을 더해보세요.'],
    ['2. 계약 기간을 맞춰 비교', '조건이 다른 집은 같은 거주 기간으로 환산해야 실제 부담 차이가 보입니다.'],
    ['3. 계약서 기준으로 재확인', '관리비 포함 범위, 중개보수 요율, 보증금 조건은 계약 전 실제 안내와 맞춰보세요.']
  ],
  health: [
    ['1. 기준값을 먼저 입력', '키, 몸무게, 기초대사량처럼 변하지 않는 값을 먼저 넣고 목표 조절량을 바꿔보세요.'],
    ['2. 무리한 목표를 피하기', '칼로리나 수분 목표는 생활 패턴과 건강 상태에 따라 달라질 수 있습니다.'],
    ['3. 참고값으로만 사용', '건강 계산은 진단이 아니라 생활 기준을 잡기 위한 참고값입니다.']
  ],
  work: [
    ['1. 세전 금액과 공제 분리', '월급이나 외주비는 세전 금액만 보지 말고 공제율, 세금, 플랫폼 비용을 따로 넣으세요.'],
    ['2. 실제 입금액으로 판단', '계약금액이 커도 원천징수와 비용을 빼면 남는 돈이 달라질 수 있습니다.'],
    ['3. 회사·계약 조건 확인', '수당, 공제, 세금 처리 방식은 회사와 계약별로 달라질 수 있으니 실제 자료와 대조하세요.']
  ]
};
const guideItems = guideByGroup[calculator.group];
const detail = calculatorDetails[calculator.slug];
function formatInputDefault(input: (typeof calculator.inputs)[number]) {
  if (input.type === 'select') {
    return input.options?.find((option) => option.value === input.value)?.label ?? String(input.value);
  }
  const value = typeof input.value === 'number' ? input.value.toLocaleString('ko-KR') : String(input.value);
  return `${value}${input.suffix ?? ''}`;
}
const interpretationByGroup = {
  seller: {
    title: '결과를 해석하는 순서',
    body: '먼저 주문당 순이익이 0보다 큰지 보고, 다음으로 마진율과 광고비 한도를 봅니다. 마진율이 낮으면 반품률이나 광고비가 조금만 올라가도 손실로 바뀔 수 있습니다.',
    checks: ['순이익이 0원 아래로 내려가는 입력값 찾기', '수수료율과 배송비를 실제 정산 기준으로 교체', '광고비를 보수적으로 올려 다시 계산']
  },
  living: {
    title: '총액 기준으로 비교하기',
    body: '월 부담이 작아 보여도 약정 기간이 길면 총액 차이가 커집니다. 사은품, 위약금, 설치비처럼 한 번만 발생하는 금액까지 넣어야 실제 부담을 볼 수 있습니다.',
    checks: ['약정 기간 전체 비용 보기', '할인 종료 후 월요금 반영', '해지 위약금과 설치비 누락 여부 점검']
  },
  utility: {
    title: '월 부담과 총비용을 같이 보기',
    body: '대출, 예금, 투자 회수기간은 월 금액과 전체 기간의 총액이 동시에 중요합니다. 월 납입액이 낮아도 기간이 길어지면 총이자나 기회비용이 커질 수 있습니다.',
    checks: ['월 현금흐름이 감당 가능한지 보기', '기간을 바꿔 총비용 차이 비교', '금리와 세후 기준을 실제 조건으로 교체']
  },
  housing: {
    title: '계약 기간 전체 비용으로 보기',
    body: '주거비는 월세만 비교하면 보증금 기회비용, 관리비, 중개보수처럼 한 번에 나가는 돈을 놓치기 쉽습니다. 같은 기간으로 환산해 월평균 부담을 봐야 합니다.',
    checks: ['월세와 관리비를 분리해서 입력', '보증금 기회비용과 일회성 비용 반영', '계약 기간을 바꿔 총부담 비교']
  },
  health: {
    title: '생활 기준으로만 해석하기',
    body: '건강 계산기는 BMI, 칼로리, 수분처럼 기준을 잡기 위한 간편 계산입니다. 개인의 질환, 운동량, 약물, 식단 조건에 따라 실제 목표는 달라질 수 있습니다.',
    checks: ['무리한 목표값을 넣지 않았는지 확인', '운동량과 생활 패턴을 보수적으로 입력', '건강 이상이 있으면 전문가 기준 우선']
  },
  work: {
    title: '실제 입금액과 남는 돈 보기',
    body: '급여와 외주비는 세전 금액보다 공제 후 입금액이 중요합니다. 세금, 보험, 플랫폼 수수료, 작업 비용을 분리하면 실제 남는 돈이 더 선명해집니다.',
    checks: ['공제율과 세금을 실제 자료로 교체', '비용을 뺀 뒤 남는 돈 확인', '계약서와 급여명세서 기준으로 재계산']
  }
};
const interpretation = interpretationByGroup[calculator.group];
const faqItems = [
  {
    question: `${calculator.shortTitle} 결과는 어디까지 믿어도 되나요?`,
    answer: '입력한 값과 화면에 표시된 계산식으로 나온 참고용 결과입니다. 실제 계약, 정산, 세금, 금융 조건은 사업자와 기관의 공식 안내를 함께 봐야 합니다.'
  },
  {
    question: '입력한 값이 서버로 저장되나요?',
    answer: '계산은 브라우저에서 처리됩니다. 저장 기능을 사용하면 값이 사용자의 브라우저 저장소에 남을 수 있지만 별도 회원 DB로 전송하지 않습니다.'
  },
  {
    question: '비교할 때 어떤 값을 바꿔봐야 하나요?',
    answer: '가장 불확실한 값을 보수적으로 바꿔보는 것이 좋습니다. 판매자는 반품률과 광고비, 생활비 계약은 약정 기간과 위약금, 금융 계산은 금리와 기간을 먼저 바꿔보세요.'
  }
];
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: calculator.title,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  isAccessibleForFree: true,
  description: calculator.description,
  url: `${Astro.site}calculators/${calculator.slug}/`,
  publisher: {
    '@type': 'Organization',
    name: '단지표'
  }
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: '단지표',
      item: `${Astro.site}`
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: groupLabels[calculator.group],
      item: `${Astro.site}calculators/`
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: calculator.title,
      item: `${Astro.site}calculators/${calculator.slug}/`
    }
  ]
};
---
<BaseLayout
  title={seoTitle}
  description={seoDescription}
  canonical={`/calculators/${calculator.slug}/`}
  robots="noindex, follow"
>
  <nav class="crumb" aria-label="현재 위치">
    <a href="/">홈</a>
    <span>/</span>
    <a href={`/#${calculator.group}`}>{groupLabels[calculator.group]}</a>
  </nav>

  <section class="page-head">
    <div>
      <h1>{calculator.title}</h1>
      <p>{calculator.description}</p>
    </div>
    <a class="back-link" href="/">전체 계산기 보기</a>
  </section>

  <section class="switcher" aria-label="계산기 이동">
    <label>
      <span>다른 계산기 바로가기</span>
      <select data-calculator-jump>
        {groupedCalculators.map(({ label, items }) => (
          <optgroup label={label}>
            {items.map((item) => (
              <option value={`/calculators/${item.slug}/`} selected={item.slug === calculator.slug}>
                {item.shortTitle}
              </option>
            ))}
          </optgroup>
        ))}
      </select>
    </label>
    <div class="pager">
      <a href={`/calculators/${previousCalculator.slug}/`}>이전: {previousCalculator.shortTitle}</a>
      <a href={`/calculators/${nextCalculator.slug}/`}>다음: {nextCalculator.shortTitle}</a>
    </div>
  </section>

  <CalculatorTool calculator={calculator} />

  <section class="seo-summary" aria-labelledby="seo-summary-title">
    <div>
      <p class="section-eyebrow">무료 계산기</p>
      <h2 id="seo-summary-title">{calculator.title}로 확인할 수 있는 것</h2>
      <p>
        {calculator.title}는 {calculator.inputs.map((input) => input.label).join(', ')} 값을 바꿔가며
        {calculator.intent} 상황을 빠르게 비교하도록 만든 계산기입니다.
      </p>
    </div>
    <div class="seo-summary-grid">
      <article>
        <strong>입력값</strong>
        <p>{inputKeywords}처럼 결과를 크게 바꾸는 조건을 직접 조정합니다.</p>
      </article>
      <article>
        <strong>결과 해석</strong>
        <p>{detail.review}</p>
      </article>
      <article>
        <strong>주의사항</strong>
        <p>{detail.caution}</p>
      </article>
    </div>
  </section>

  <section class="guide">
      <h2>입력 순서</h2>
    <div class="guide-grid">
      {guideItems.map(([title, body]) => (
        <article>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="interpretation">
    <div>
      <h2>{interpretation.title}</h2>
      <p>{interpretation.body}</p>
    </div>
    <ul>
      {interpretation.checks.map((check) => <li>{check}</li>)}
    </ul>
  </section>

  <section class="detail-guide">
    <div class="detail-copy">
      <p class="section-eyebrow">계산 공식</p>
      <h2>{calculator.shortTitle} 계산식</h2>
      <p>{detail.formula}</p>
      <div class="detail-note">
        <strong>예시</strong>
        <span>{detail.example}</span>
      </div>
      <a class="audit-link" href="/calculator-audit/">전체 계산기 검산 기록 보기</a>
    </div>
    <div class="input-reference">
      <h3>처음 들어가는 값</h3>
      <dl>
        {calculator.inputs.map((input) => (
          <>
            <dt>{input.label}</dt>
            <dd>기본값 {formatInputDefault(input)}</dd>
          </>
        ))}
      </dl>
    </div>
  </section>

  <section class="quality-guide">
    <article>
      <h2>놓치기 쉬운 항목</h2>
      <p>{detail.caution}</p>
    </article>
    <article>
      <h2>마지막 점검</h2>
      <p>{detail.review}</p>
    </article>
  </section>

  <section class="faq">
    <h2>자주 묻는 질문</h2>
    <div class="faq-list">
      {faqItems.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  {relatedGuides.length > 0 && (
    <section class="guide-links">
      <div class="section-title">
        <h2>계산 전에 읽어볼 글</h2>
        <p>{groupLabels[calculator.group]}</p>
      </div>
      <div class="guide-link-list">
        {relatedGuides.map((guide) => (
          <a href={`/guides/${guide.slug}/`}>
            <span>{guide.category} · {guide.readMinutes}분</span>
            <strong>{guide.title}</strong>
            <p>{guide.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="related">
    <div class="section-title">
      <h2>같이 보면 좋은 계산기</h2>
      <p>{groupLabels[calculator.group]}</p>
    </div>
    <div class="related-list">
      {related.map((item) => (
        <a href={`/calculators/${item.slug}/`}>
          <span>{item.intent}</span>
          <strong>{item.shortTitle}</strong>
          <p>{item.description}</p>
        </a>
      ))}
    </div>
  </section>

  <script is:inline src={`/calculators.js?v=${calculatorScriptVersion}`} defer></script>
  <script
    is:inline
    define:vars={{
      recentCalculator: {
        slug: calculator.slug,
        title: calculator.shortTitle,
        href: `/calculators/${calculator.slug}/`,
        group: groupLabels[calculator.group]
      }
    }}
  >
    document.querySelector('[data-calculator-jump]')?.addEventListener('change', (event) => {
      const select = event.currentTarget;
      if (select instanceof HTMLSelectElement && select.value) {
        window.location.href = select.value;
      }
    });

    try {
      const key = 'margin-calculator-recent';
      const previous = JSON.parse(localStorage.getItem(key) || '[]');
      const next = [recentCalculator, ...previous.filter((item) => item.slug !== recentCalculator.slug)].slice(0, 5);
      localStorage.setItem(key, JSON.stringify(next));
    } catch {}
  </script>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(appJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
</BaseLayout>

<style>
  .crumb {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 16px;
    color: var(--subtle);
    font: 800 0.86rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .crumb a {
    color: var(--green-strong);
    text-decoration: none;
  }
  .page-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    margin-bottom: 20px;
    padding-top: 6px;
  }
  h1 {
    margin: 0;
    color: var(--ink);
    font: 950 clamp(1.9rem, 3.8vw, 3.4rem)/1.08 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
    word-break: keep-all;
  }
  .page-head p {
    margin: 12px 0 0;
    max-width: 760px;
    color: var(--muted);
    font: 700 1rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }
