---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalculatorTool from '@/components/CalculatorTool.astro';
import { calculators, groupLabels } from '@/data/calculators';

export function getStaticPaths() {
  return calculators.map((calculator) => ({
    params: { slug: calculator.slug },
    props: { calculator }
  }));
}

const { calculator } = Astro.props;
const related = calculators
  .filter((item) => item.slug !== calculator.slug && item.group === calculator.group)
  .slice(0, 5);
---
<BaseLayout
  title={`${calculator.title} | 마진계산소`}
  description={calculator.description}
  canonical={`/calculators/${calculator.slug}/`}
>
  <nav class="crumb" aria-label="현재 위치">
    <a href="/">홈</a>
    <span>/</span>
    <a href={`/#${calculator.group}`}>{groupLabels[calculator.group]}</a>
  </nav>

  <section class="page-head">
    <div>
      <h1>{calculator.title}</h1>
      <p>{calculator.description}</p>
    </div>
    <a class="back-link" href="/">전체 계산기 보기</a>
  </section>

  <CalculatorTool calculator={calculator} />

  <section class="guide">
    <h2>이 계산기를 쓰는 기준</h2>
    <div class="guide-grid">
      <article>
        <h3>1. 보수적으로 입력</h3>
        <p>비용은 낮게 보지 말고, 광고비·반품률·수수료처럼 빠지기 쉬운 항목을 넉넉하게 넣으세요.</p>
      </article>
      <article>
        <h3>2. 월 단위로 환산</h3>
        <p>주문 1건 결과가 괜찮아도 월 주문 수, 고정비, 약정 기간을 합치면 판단이 달라질 수 있습니다.</p>
      </article>
      <article>
        <h3>3. 공식 기준 확인</h3>
        <p>플랫폼 수수료, 세금, 전기요금, 렌탈 조건은 수시로 바뀔 수 있어 최종 계약 전 공식 기준을 확인해야 합니다.</p>
      </article>
    </div>
  </section>

  <section class="related">
    <div class="section-title">
      <h2>같이 보면 좋은 계산기</h2>
      <p>{groupLabels[calculator.group]}</p>
    </div>
    <div class="related-list">
      {related.map((item) => (
        <a href={`/calculators/${item.slug}/`}>
          <span>{item.intent}</span>
          <strong>{item.shortTitle}</strong>
          <p>{item.description}</p>
        </a>
      ))}
    </div>
  </section>

  <script is:inline src="/calculators.js" defer></script>
</BaseLayout>

<style>
  .crumb {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 18px;
    color: #69766f;
    font: 800 0.86rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .crumb a {
    color: #1e7a55;
    text-decoration: none;
  }
  .page-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    margin-bottom: 20px;
  }
  h1 {
    margin: 0;
    color: #10221c;
    font: 950 clamp(2rem, 4.5vw, 4.2rem)/1.04 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  .page-head p {
    margin: 12px 0 0;
    max-width: 760px;
    color: #52645b;
    font: 700 1.04rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .back-link {
    border: 1px solid #cbd8d2;
    border-radius: 8px;
    background: #fff;
    color: #10221c;
    padding: 11px 13px;
    text-decoration: none;
    font: 900 0.88rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    white-space: nowrap;
  }
  .guide,
  .related {
    margin-top: 38px;
  }
  .guide h2,
  .section-title h2 {
    margin: 0 0 14px;
    color: #10221c;
    font: 950 1.35rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .guide-grid,
  .related-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .guide article,
  .related-list a {
    border: 1px solid #d9e4df;
    border-radius: 8px;
    background: #fff;
    padding: 16px;
  }
  .guide h3 {
    margin: 0 0 8px;
    color: #10221c;
    font: 950 1rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .guide p,
  .related-list p {
    margin: 0;
    color: #52645b;
    font: 700 0.92rem/1.55 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .section-title {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: end;
  }
  .section-title p {
    margin: 0 0 14px;
    color: #69766f;
    font: 800 0.88rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .related-list a {
    display: grid;
    gap: 8px;
    color: inherit;
    text-decoration: none;
  }
  .related-list span {
    color: #1e7a55;
    font: 900 0.76rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .related-list strong {
    color: #10221c;
    font: 950 1.1rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  @media (max-width: 820px) {
    .page-head {
      grid-template-columns: 1fr;
    }
    .back-link {
      width: fit-content;
    }
    .guide-grid,
    .related-list {
      grid-template-columns: 1fr;
    }
  }
</style>
