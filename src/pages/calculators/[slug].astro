---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalculatorTool from '@/components/CalculatorTool.astro';
import { calculators, groupLabels } from '@/data/calculators';

export function getStaticPaths() {
  return calculators.map((calculator) => ({
    params: { slug: calculator.slug },
    props: { calculator }
  }));
}

const { calculator } = Astro.props;
const related = calculators
  .filter((item) => item.slug !== calculator.slug && item.group === calculator.group)
  .slice(0, 5);
const currentIndex = calculators.findIndex((item) => item.slug === calculator.slug);
const previousCalculator = calculators[(currentIndex - 1 + calculators.length) % calculators.length];
const nextCalculator = calculators[(currentIndex + 1) % calculators.length];
const groupedCalculators = Object.entries(groupLabels).map(([group, label]) => ({
  group,
  label,
  items: calculators.filter((item) => item.group === group)
}));
const guideByGroup = {
  seller: [
    ['1. 비용을 빠짐없이 입력', '판매가만 보지 말고 수수료, 결제비, 배송비, 광고비, 반품 손실까지 함께 넣으세요.'],
    ['2. 주문 1건과 월 기준을 분리', '주문당 이익이 남아도 월 고정비와 광고비가 커지면 전체 손익은 달라질 수 있습니다.'],
    ['3. 플랫폼 기준 확인', '카테고리별 수수료, 정산 방식, 배송 정책은 플랫폼마다 다르므로 최종 판매 전 공식 기준을 확인하세요.']
  ],
  living: [
    ['1. 월요금보다 총액 확인', '렌탈료나 통신비는 월 납입액보다 약정 기간 전체 비용으로 비교해야 조건이 보입니다.'],
    ['2. 할인과 위약금을 같이 계산', '사은품, 설치비, 위약금, 기존 할인 해지 여부를 함께 넣어야 실제 이득을 볼 수 있습니다.'],
    ['3. 계약 조건 확인', '프로모션과 약정 조건은 바뀔 수 있으니 신청 전 사업자 안내를 다시 확인하세요.']
  ],
  utility: [
    ['1. 월 현금흐름 확인', '대출이나 사업 손익은 총액뿐 아니라 매월 빠져나가는 금액을 먼저 확인해야 합니다.'],
    ['2. 기간을 길게 볼수록 총비용 확인', '월 납입액이 작아도 기간이 길면 총이자나 기회비용이 크게 늘어날 수 있습니다.'],
    ['3. 실제 조건으로 재계산', '금리, 상환방식, 세금, 보험료 같은 조건이 달라지면 결과도 달라집니다.']
  ]
};
const guideItems = guideByGroup[calculator.group];
const interpretationByGroup = {
  seller: {
    title: '결과를 해석하는 순서',
    body: '먼저 주문당 순이익이 0보다 큰지 확인하고, 다음으로 마진율과 광고비 한도를 봅니다. 마진율이 낮으면 반품률이나 광고비가 조금만 올라가도 손실로 바뀔 수 있습니다.',
    checks: ['순이익이 0원 아래로 내려가는 입력값 찾기', '수수료율과 배송비를 실제 정산 기준으로 교체', '광고비를 보수적으로 올려 다시 계산']
  },
  living: {
    title: '총액 기준으로 비교하기',
    body: '월 부담이 작아 보여도 약정 기간이 길면 총액 차이가 커집니다. 사은품, 위약금, 설치비처럼 한 번만 발생하는 금액까지 넣어야 실제 부담을 볼 수 있습니다.',
    checks: ['약정 기간 전체 비용 확인', '할인 종료 후 월요금 반영', '해지 위약금과 설치비 누락 여부 확인']
  },
  utility: {
    title: '월 부담과 총비용을 같이 보기',
    body: '대출, 예금, 투자 회수기간은 월 금액과 전체 기간의 총액이 동시에 중요합니다. 월 납입액이 낮아도 기간이 길어지면 총이자나 기회비용이 커질 수 있습니다.',
    checks: ['월 현금흐름이 감당 가능한지 확인', '기간을 바꿔 총비용 차이 비교', '금리와 세후 기준을 실제 조건으로 교체']
  }
};
const interpretation = interpretationByGroup[calculator.group];
const faqItems = [
  {
    question: `${calculator.shortTitle} 결과는 어디까지 믿어도 되나요?`,
    answer: '입력한 값과 화면에 표시된 기준을 바탕으로 한 참고용 결과입니다. 실제 계약, 정산, 세금, 금융 조건은 사업자와 기관의 공식 안내를 함께 확인해야 합니다.'
  },
  {
    question: '입력한 값이 서버로 저장되나요?',
    answer: '계산은 브라우저에서 처리됩니다. 저장 기능을 사용하면 값이 사용자의 브라우저 저장소에 남을 수 있지만 별도 회원 DB로 전송하지 않습니다.'
  },
  {
    question: '비교할 때 어떤 값을 바꿔봐야 하나요?',
    answer: '가장 불확실한 값을 보수적으로 바꿔보는 것이 좋습니다. 판매자는 반품률과 광고비, 생활비 계약은 약정 기간과 위약금, 금융 계산은 금리와 기간을 먼저 바꿔보세요.'
  }
];
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer
    }
  }))
};
const appJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: calculator.title,
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Web',
  isAccessibleForFree: true,
  description: calculator.description,
  url: `${Astro.site}calculators/${calculator.slug}/`,
  publisher: {
    '@type': 'Organization',
    name: '마진계산소'
  }
};
---
<BaseLayout
  title={`${calculator.title} | 마진계산소`}
  description={calculator.description}
  canonical={`/calculators/${calculator.slug}/`}
>
  <nav class="crumb" aria-label="현재 위치">
    <a href="/">홈</a>
    <span>/</span>
    <a href={`/#${calculator.group}`}>{groupLabels[calculator.group]}</a>
  </nav>

  <section class="page-head">
    <div>
      <h1>{calculator.title}</h1>
      <p>{calculator.description}</p>
    </div>
    <a class="back-link" href="/">전체 계산기 보기</a>
  </section>

  <section class="switcher" aria-label="계산기 이동">
    <label>
      <span>다른 계산기 바로가기</span>
      <select data-calculator-jump>
        {groupedCalculators.map(({ label, items }) => (
          <optgroup label={label}>
            {items.map((item) => (
              <option value={`/calculators/${item.slug}/`} selected={item.slug === calculator.slug}>
                {item.shortTitle}
              </option>
            ))}
          </optgroup>
        ))}
      </select>
    </label>
    <div class="pager">
      <a href={`/calculators/${previousCalculator.slug}/`}>이전: {previousCalculator.shortTitle}</a>
      <a href={`/calculators/${nextCalculator.slug}/`}>다음: {nextCalculator.shortTitle}</a>
    </div>
  </section>

  <CalculatorTool calculator={calculator} />

  <section class="guide">
    <h2>이 계산기를 쓰는 기준</h2>
    <div class="guide-grid">
      {guideItems.map(([title, body]) => (
        <article>
          <h3>{title}</h3>
          <p>{body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="interpretation">
    <div>
      <h2>{interpretation.title}</h2>
      <p>{interpretation.body}</p>
    </div>
    <ul>
      {interpretation.checks.map((check) => <li>{check}</li>)}
    </ul>
  </section>

  <section class="faq">
    <h2>자주 묻는 질문</h2>
    <div class="faq-list">
      {faqItems.map((item) => (
        <details>
          <summary>{item.question}</summary>
          <p>{item.answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="related">
    <div class="section-title">
      <h2>같이 보면 좋은 계산기</h2>
      <p>{groupLabels[calculator.group]}</p>
    </div>
    <div class="related-list">
      {related.map((item) => (
        <a href={`/calculators/${item.slug}/`}>
          <span>{item.intent}</span>
          <strong>{item.shortTitle}</strong>
          <p>{item.description}</p>
        </a>
      ))}
    </div>
  </section>

  <script is:inline src="/calculators.js" defer></script>
  <script
    is:inline
    define:vars={{
      recentCalculator: {
        slug: calculator.slug,
        title: calculator.shortTitle,
        href: `/calculators/${calculator.slug}/`,
        group: groupLabels[calculator.group]
      }
    }}
  >
    document.querySelector('[data-calculator-jump]')?.addEventListener('change', (event) => {
      const select = event.currentTarget;
      if (select instanceof HTMLSelectElement && select.value) {
        window.location.href = select.value;
      }
    });

    try {
      const key = 'margin-calculator-recent';
      const previous = JSON.parse(localStorage.getItem(key) || '[]');
      const next = [recentCalculator, ...previous.filter((item) => item.slug !== recentCalculator.slug)].slice(0, 5);
      localStorage.setItem(key, JSON.stringify(next));
    } catch {}
  </script>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(appJsonLd)} />
</BaseLayout>

<style>
  .crumb {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 16px;
    color: #74817b;
    font: 800 0.86rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .crumb a {
    color: #16824f;
    text-decoration: none;
  }
  .page-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 18px;
    align-items: end;
    margin-bottom: 20px;
  }
  h1 {
    margin: 0;
    color: #1c2a23;
    font: 950 clamp(1.9rem, 3.8vw, 3.4rem)/1.08 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  .page-head p {
    margin: 12px 0 0;
    max-width: 760px;
    color: #596760;
    font: 700 1rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .back-link {
    border: 1px solid #cfd8d3;
    border-radius: 8px;
    background: #fff;
    color: #1c2a23;
    padding: 11px 13px;
    text-decoration: none;
    font: 900 0.88rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    white-space: nowrap;
  }
  .switcher {
    display: grid;
    grid-template-columns: minmax(280px, 0.42fr) minmax(0, 1fr);
    gap: 12px;
    align-items: end;
    margin-bottom: 18px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 16px;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .switcher label {
    display: grid;
    gap: 7px;
    color: #33443c;
    font: 900 0.82rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .switcher select {
    width: 100%;
    min-height: 44px;
    border: 1px solid #ccd6d1;
    border-radius: 8px;
    background: #fff;
    color: #1c2a23;
    font: 900 0.94rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 0 12px;
    outline: none;
  }
  .switcher select:focus {
    border-color: #16824f;
    box-shadow: 0 0 0 3px rgba(22, 130, 79, 0.12);
  }
  .pager {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pager a {
    display: inline-flex;
    align-items: center;
    min-height: 38px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #f8faf9;
    color: #1c2a23;
    padding: 0 11px;
    text-decoration: none;
    font: 900 0.84rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .pager a:hover {
    border-color: #91b8a4;
    background: #edf8f2;
    color: #0f6c43;
  }
  .guide,
  .interpretation,
  .faq,
  .related {
    margin-top: 36px;
  }
  .guide h2,
  .interpretation h2,
  .faq h2,
  .section-title h2 {
    margin: 0 0 14px;
    color: #1c2a23;
    font: 950 1.22rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .guide-grid,
  .related-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  .guide article,
  .interpretation,
  .faq details,
  .related-list a {
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 16px;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .guide h3 {
    margin: 0 0 8px;
    color: #1c2a23;
    font: 950 1rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .guide p,
  .interpretation p,
  .faq p,
  .related-list p {
    margin: 0;
    color: #596760;
    font: 700 0.92rem/1.55 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .interpretation {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.44fr);
    gap: 18px;
    align-items: start;
  }
  .interpretation ul {
    margin: 0;
    padding-left: 1.2rem;
    color: #1c2a23;
    font: 850 0.95rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .interpretation li + li {
    margin-top: 6px;
  }
  .faq-list {
    display: grid;
    gap: 10px;
  }
  .faq details {
    padding: 0;
    overflow: hidden;
  }
  .faq summary {
    cursor: pointer;
    padding: 15px 16px;
    color: #1c2a23;
    font: 950 0.98rem/1.35 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .faq summary::marker {
    color: #16824f;
  }
  .faq details p {
    border-top: 1px solid #e7ece9;
    padding: 14px 16px 16px;
    background: #f8faf9;
  }
  .section-title {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: end;
  }
  .section-title p {
    margin: 0 0 14px;
    color: #74817b;
    font: 800 0.88rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .related-list a {
    display: grid;
    gap: 8px;
    color: inherit;
    text-decoration: none;
  }
  .related-list span {
    color: #16824f;
    font: 900 0.76rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .related-list strong {
    color: #1c2a23;
    font: 950 1.1rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  @media (max-width: 820px) {
    .page-head,
    .switcher {
      grid-template-columns: 1fr;
    }
    .back-link {
      width: fit-content;
    }
    .guide-grid,
    .interpretation,
    .related-list {
      grid-template-columns: 1fr;
    }
    .pager {
      justify-content: flex-start;
    }
  }
</style>
