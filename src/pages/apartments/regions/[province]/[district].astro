---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadApartmentPageData, type ApartmentEntry } from '@/lib/apartmentBulk';
import { displayDistrictName, districtHubPath, districtSegment, latestTotal, regionHubPath, regionalFeeInsights } from '@/lib/apartmentSeo';
import { siteUrl } from '@/lib/site';

export const getStaticPaths = async () => {
  const pages = await loadApartmentPageData();
  const groups = new Map<string, { province: string; district: string; apartments: ApartmentEntry[] }>();
  for (const { apartment } of pages) {
    const key = `${apartment.sd}|${apartment.sg}`;
    const group = groups.get(key) ?? { province: apartment.sd, district: apartment.sg, apartments: [] };
    group.apartments.push(apartment);
    groups.set(key, group);
  }
  return [...groups.values()].map(({ province, district, apartments }) => ({
    params: { province, district: districtSegment(district) },
    props: { province, district, apartments }
  }));
};

const { province, district, apartments } = Astro.props as { province: string; district: string; apartments: ApartmentEntry[] };
const districtName = displayDistrictName(province, district);
const sortedApartments = apartments.slice().sort((a, b) => a.n.localeCompare(b.n, 'ko'));
const insights = regionalFeeInsights(apartments);
const insightGroups = [
  { title: '전월 대비 상승 단지', note: '㎡당 총 관리비 증가액 순', rows: insights.rising, change: true },
  { title: '전월 대비 하락 단지', note: '㎡당 총 관리비 감소액 순', rows: insights.falling, change: true },
  { title: '공개 단가가 낮은 단지', note: '기준월 ㎡당 총 관리비 순', rows: insights.low, change: false },
  { title: '공개 단가가 높은 단지', note: '기준월 ㎡당 총 관리비 순', rows: insights.high, change: false }
];
const fee = (value: number) => `${value.toLocaleString('ko-KR')}원/㎡`;
const deltaFee = (value: number | null) => value === null
  ? '비교값 없음'
  : `${value > 0 ? '+' : ''}${value.toLocaleString('ko-KR')}원/㎡`;
const description = `${province} ${districtName} 관리비 공개 아파트 ${apartments.length.toLocaleString('ko-KR')}개의 최근 ㎡당 관리비와 세대수, 난방방식, 월별 상세 내역을 확인하세요.`;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '전국 단지 찾기', item: siteUrl('/apartments/') },
    { '@type': 'ListItem', position: 2, name: province, item: siteUrl(regionHubPath(province)) },
    { '@type': 'ListItem', position: 3, name: districtName, item: siteUrl(districtHubPath(province, district)) }
  ]
};
---
<BaseLayout
  title={`${province} ${districtName} 아파트 관리비 | 단지표`}
  description={description}
  canonical={districtHubPath(province, district)}
  robots="index, follow"
  structuredData={structuredData}
>
  <main class="district-hub">
    <nav class="breadcrumbs" aria-label="경로"><a href="/apartments/">전국</a><span>/</span><a href={regionHubPath(province)}>{province}</a><span>/</span><span>{districtName}</span></nav>
    <header class="hub-head">
      <div><p>K-apt 월별 공개자료</p><h1>{districtName} 아파트 관리비</h1><span>단지를 선택하면 월별 관리비 추이와 지역 내 비교값을 확인할 수 있습니다.</span></div>
      <a href={`/?region=${encodeURIComponent(province)}&district=${encodeURIComponent(district)}`}>지도에서 보기</a>
    </header>

    <section class="summary" aria-label={`${districtName} 관리비 요약`}>
      <div><span>공개 단지</span><strong>{apartments.length.toLocaleString('ko-KR')}</strong><small>개</small></div>
      <div><span>㎡당 중앙값</span><strong>{insights.medianFee ? insights.medianFee.toLocaleString('ko-KR') : '미공개'}</strong>{insights.medianFee > 0 && <small>원</small>}</div>
      <div><span>요약 범위</span><strong>{insights.minFee && insights.maxFee ? `${insights.minFee.toLocaleString('ko-KR')}~${insights.maxFee.toLocaleString('ko-KR')}` : '미공개'}</strong>{insights.minFee > 0 && <small>원/㎡</small>}</div>
      <div><span>비교 기준월</span><strong>{insights.referenceMonth || '미확인'}</strong><small>{insights.coverageCount ? `${insights.coverageCount.toLocaleString('ko-KR')}개 단지` : ''}</small></div>
    </section>

    <section class="insight-section" aria-labelledby="fee-insights-title">
      <header>
        <div><h2 id="fee-insights-title">{districtName} 관리비 공개 단가 요약</h2><p>{insights.referenceMonth ? `${insights.referenceMonth} 공개값을 같은 기준월끼리 비교했습니다.` : '비교 가능한 월별 공개값이 없습니다.'}</p></div>
        <span>단가 차이는 관리 서비스나 주거 품질을 뜻하지 않습니다.</span>
      </header>
      <div class="insight-grid">
        {insightGroups.map((group) => (
          <article>
            <header><h3>{group.title}</h3><span>{group.note}</span></header>
            {group.rows.length ? (
              <ol>
                {group.rows.map((row) => (
                  <li>
                    <a href={`/apartments/${row.apartment.s}/`}>
                      <span><strong>{row.apartment.n}</strong><small>{row.apartment.d || districtName} · {row.apartment.h.toLocaleString('ko-KR')}세대</small></span>
                      <b class={group.change ? (Number(row.delta) > 0 ? 'up' : 'down') : ''}>
                        {group.change ? deltaFee(row.delta) : fee(row.total)}
                        {group.change && <small>현재 {fee(row.total)}</small>}
                      </b>
                    </a>
                  </li>
                ))}
              </ol>
            ) : <p class="empty">표시할 수 있는 공개값이 없습니다.</p>}
          </article>
        ))}
      </div>
    </section>

    <section class="complex-section">
      <header><h2>{districtName} 공개 단지</h2><p>가나다순 · 금액은 단지별 최근 공개월 기준</p></header>
      <div class="complex-grid">
        {sortedApartments.map((apartment) => (
          <a href={`/apartments/${apartment.s}/`}>
            <span>{apartment.d || districtName}</span>
            <strong>{apartment.n}</strong>
            <small>{apartment.h.toLocaleString('ko-KR')}세대 · {apartment.y ? `${apartment.y}년` : '사용승인 미확인'} · {apartment.ht || '난방 미확인'}</small>
            <b>{latestTotal(apartment).toLocaleString('ko-KR')}원/㎡</b>
          </a>
        ))}
      </div>
    </section>

    <a class="map-cta" href={`/?region=${encodeURIComponent(province)}&district=${encodeURIComponent(district)}`}><span><strong>{districtName} 단지를 지도에서 비교</strong><small>위치와 주변 단지를 함께 확인합니다.</small></span><b>지도 열기</b></a>

    <p class="source">출처: 국토교통부 공동주택관리정보시스템(K-apt) 일괄 공개자료 · 비교 기준월은 가장 많이 공개된 월의 단지 수 대비 90% 이상이 포함된 가장 최근 월입니다. 중앙값과 순위는 해당 월의 ㎡당 총 관리비 공개 단가를 기준으로 하며, 세대별 실제 청구액은 전용면적과 사용량에 따라 달라집니다.{insights.excludedCount ? ` 중앙값의 25% 미만 또는 400% 초과인 ${insights.excludedCount.toLocaleString('ko-KR')}개 공개값은 요약 순위에서 제외했으며 단지 상세에는 그대로 표시됩니다.` : ''}{insights.latestAvailableMonth && insights.latestAvailableMonth !== insights.referenceMonth ? ` 일부 단지는 ${insights.latestAvailableMonth} 자료까지 공개되어 있습니다.` : ''}</p>
  </main>
</BaseLayout>

<style>
  :global(.main-content:has(.district-hub)) { width: min(1180px, calc(100vw - 40px)); }
  .district-hub { display: grid; gap: 16px; }
  .breadcrumbs { display: flex; gap: 7px; color: #77817c; font-size: .72rem; font-weight: 720; }
  .breadcrumbs a { color: inherit; }
  .hub-head { min-height: 92px; display: flex; align-items: end; justify-content: space-between; gap: 24px; }
  .hub-head p { margin: 0 0 4px; color: #08765c; font-size: .72rem; font-weight: 850; }
  .hub-head h1 { margin: 0; color: #17211d; font-size: 1.8rem; letter-spacing: 0; }
  .hub-head span { display: block; margin-top: 7px; color: #68736e; font-size: .8rem; }
  .hub-head > a { min-height: 38px; display: inline-flex; align-items: center; border: 1px solid #cddbd4; border-radius: 7px; color: #076e57; padding: 0 13px; font-size: .75rem; font-weight: 850; text-decoration: none; }
  .summary { display: grid; grid-template-columns: repeat(4, 1fr); border: 1px solid #dce4df; border-radius: 7px; background: #fff; }
  .summary div { min-width: 0; min-height: 82px; display: flex; align-items: baseline; gap: 5px; padding: 17px; border-right: 1px solid #e7ece9; }
  .summary div:last-child { border: 0; }
  .summary span { margin-right: auto; color: #75807a; font-size: .7rem; font-weight: 760; }
  .summary strong { overflow: hidden; color: #17211d; font-size: 1.08rem; text-overflow: ellipsis; white-space: nowrap; }
  .summary small { color: #75807a; font-size: .65rem; font-weight: 750; white-space: nowrap; }
  .insight-section { display: grid; gap: 13px; padding: 18px 0 2px; }
  .insight-section > header { display: flex; align-items: end; justify-content: space-between; gap: 18px; }
  .insight-section > header h2 { margin: 0; color: #17211d; font-size: 1rem; }
  .insight-section > header p { margin: 5px 0 0; color: #75807a; font-size: .7rem; }
  .insight-section > header > span { color: #7a847f; font-size: .67rem; }
  .insight-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); border-top: 1px solid #dce4df; border-left: 1px solid #dce4df; background: #fff; }
  .insight-grid article { min-width: 0; border-right: 1px solid #dce4df; border-bottom: 1px solid #dce4df; padding: 15px; }
  .insight-grid article > header { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 8px; }
  .insight-grid h3 { margin: 0; color: #26332d; font-size: .8rem; }
  .insight-grid article > header span { color: #7a847f; font-size: .62rem; white-space: nowrap; }
  .insight-grid ol { margin: 0; padding: 0; list-style: none; }
  .insight-grid li + li { border-top: 1px solid #edf1ef; }
  .insight-grid a { min-height: 55px; display: flex; align-items: center; justify-content: space-between; gap: 14px; color: #17211d; text-decoration: none; }
  .insight-grid a:hover strong { color: #08765c; }
  .insight-grid a > span { min-width: 0; display: grid; gap: 3px; }
  .insight-grid a strong { overflow: hidden; font-size: .75rem; text-overflow: ellipsis; white-space: nowrap; }
  .insight-grid a small { overflow: hidden; color: #7a847f; font-size: .62rem; font-weight: 650; text-overflow: ellipsis; white-space: nowrap; }
  .insight-grid b { flex: 0 0 auto; display: grid; gap: 2px; color: #26332d; font-size: .72rem; text-align: right; }
  .insight-grid b.up { color: #b4493f; }
  .insight-grid b.down { color: #08765c; }
  .insight-grid b small { color: #7a847f; font-size: .58rem; }
  .empty { min-height: 55px; display: flex; align-items: center; margin: 0; color: #87908c; font-size: .68rem; }
  .complex-section { border: 1px solid #dce4df; border-radius: 7px; background: #fff; padding: 18px; }
  .complex-section > header { display: flex; align-items: baseline; justify-content: space-between; gap: 16px; margin-bottom: 13px; }
  .complex-section h2 { margin: 0; font-size: 1rem; }
  .complex-section p { margin: 0; color: #78827d; font-size: .7rem; }
  .complex-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); border-top: 1px solid #e4eae6; border-left: 1px solid #e4eae6; }
  .complex-grid a { position: relative; min-width: 0; min-height: 92px; display: grid; align-content: center; gap: 4px; border-right: 1px solid #e4eae6; border-bottom: 1px solid #e4eae6; color: #17211d; padding: 13px 112px 13px 15px; text-decoration: none; }
  .complex-grid a:hover { background: #f2f8f5; }
  .complex-grid span { color: #08765c; font-size: .64rem; font-weight: 820; }
  .complex-grid strong { overflow: hidden; font-size: .84rem; text-overflow: ellipsis; white-space: nowrap; }
  .complex-grid small { overflow: hidden; color: #748079; font-size: .64rem; font-weight: 680; text-overflow: ellipsis; white-space: nowrap; }
  .complex-grid b { position: absolute; top: 50%; right: 14px; color: #2f3d36; font-size: .7rem; transform: translateY(-50%); }
  .map-cta { min-height: 66px; display: flex; align-items: center; justify-content: space-between; gap: 16px; border: 1px solid #cddbd4; border-radius: 7px; color: #17211d; padding: 12px 16px; text-decoration: none; }
  .map-cta > span { display: grid; gap: 4px; }
  .map-cta strong { font-size: .8rem; }
  .map-cta small { color: #748079; font-size: .65rem; }
  .map-cta b { color: #08765c; font-size: .72rem; }
  .source { margin: 0; color: #747f79; font-size: .69rem; line-height: 1.6; }
  @media (max-width: 760px) {
    :global(.main-content:has(.district-hub)) { width: calc(100vw - 24px); }
    .hub-head { align-items: flex-start; flex-direction: column; gap: 13px; }
    .hub-head h1 { font-size: 1.45rem; }
    .summary { grid-template-columns: repeat(2, 1fr); }
    .summary div { min-height: 92px; align-items: flex-start; justify-content: center; flex-direction: column; gap: 4px; padding: 14px; }
    .summary span { margin-right: 0; }
    .summary strong { max-width: 100%; font-size: 1rem; }
    .summary div:nth-child(2) { border-right: 0; }
    .summary div:nth-child(-n + 2) { border-bottom: 1px solid #e7ece9; }
    .insight-section > header { align-items: flex-start; flex-direction: column; gap: 5px; }
    .insight-grid { grid-template-columns: 1fr; }
    .insight-grid article > header { align-items: flex-start; flex-direction: column; gap: 3px; }
    .complex-grid { grid-template-columns: 1fr; }
    .complex-section { padding: 14px; }
    .complex-section > header { align-items: flex-start; flex-direction: column; gap: 4px; }
  }
</style>
