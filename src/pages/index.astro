---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalculatorTool from '@/components/CalculatorTool.astro';
import { calculators, groupLabels, type CalculatorGroup } from '@/data/calculators';

const primary = calculators[0];
const groups = new Map<CalculatorGroup, typeof calculators>();
for (const calculator of calculators) {
  const list = groups.get(calculator.group) ?? [];
  list.push(calculator);
  groups.set(calculator.group, list);
}

const quickLinks = [
  ['마진 계산', '/calculators/seller-margin/'],
  ['손익분기', '/calculators/break-even-price/'],
  ['대출 이자', '/calculators/loan-interest/'],
  ['렌탈 총비용', '/calculators/rental-total-cost/']
];

const finderGroups: Array<['all' | CalculatorGroup, string]> = [
  ['all', '전체'],
  ['seller', groupLabels.seller],
  ['living', groupLabels.living],
  ['utility', groupLabels.utility]
];

const groupSummaries: Record<CalculatorGroup, { body: string; examples: string[] }> = {
  seller: {
    body: '가격, 수수료, 쿠폰, 광고비처럼 판매 전 손익을 흔드는 숫자를 봅니다.',
    examples: ['마진', '쿠폰', '묶음배송']
  },
  living: {
    body: '렌탈, 할부, 구독, 유류비처럼 매달 빠져나가는 돈을 총액으로 비교합니다.',
    examples: ['렌탈', '할부', '적금']
  },
  utility: {
    body: '대출, 예금, 회수기간처럼 기간이 길수록 차이가 커지는 숫자를 계산합니다.',
    examples: ['대출', '예금', '회수기간']
  }
};

const searchHints = ['대출', '할부', '쿠폰', '렌탈', '적금', '배송비'];
---
<BaseLayout
  title="마진계산소 | 판매자 마진·생활비 계산기 허브"
  description="판매가, 원가, 수수료, 광고비, 반품률, 렌탈 총액, 인터넷 갈아타기 손익을 바로 계산하는 정적 계산기 허브입니다."
  canonical="/"
>
  <section class="hero-tool">
    <div class="hero-copy">
      <div>
        <h1>마진, 이자, 생활비를 바로 계산하세요.</h1>
        <p>
          판매자 비용과 월 고정비, 대출 이자처럼 놓치기 쉬운 숫자를 한 화면에서 확인합니다.
          기본값을 바꿔 실제 조건에 맞게 다시 계산해보세요.
        </p>
      </div>
      <div class="quick-box">
        <strong>자주 쓰는 계산기</strong>
        <div class="quick-row" aria-label="빠른 계산기 링크">
          {quickLinks.map(([label, href]) => (
            <a href={href}>{label}</a>
          ))}
        </div>
      </div>
    </div>
    <CalculatorTool calculator={primary} />
  </section>

  <section class="revenue-note">
    <h2>계산 전 체크</h2>
    <p>
      판매가만 보면 남는 것 같아도 수수료, 결제비, 배송비, 광고비, 반품 손실을 넣으면
      실제 마진이 크게 달라집니다. 기본값을 바꿔 내 상품 기준으로 다시 계산해보세요.
    </p>
  </section>

  <section class="pathway" aria-label="계산기 분류 바로가기">
    {([...groups.entries()] as Array<[CalculatorGroup, typeof calculators]>).map(([group, items]) => (
      <a class="path-card" href={`#${group}`}>
        <span>{groupLabels[group]}</span>
        <strong>{items.length}개 계산기</strong>
        <p>{groupSummaries[group].body}</p>
        <small>{groupSummaries[group].examples.join(' · ')}</small>
      </a>
    ))}
  </section>

  <section class="recent-tools" data-recent-tools hidden>
    <div class="section-title">
      <h2>최근 본 계산기</h2>
      <button type="button" data-recent-clear>비우기</button>
    </div>
    <div class="recent-list" data-recent-list></div>
  </section>

  <section class="finder" id="finder" aria-labelledby="finder-title">
    <div class="finder-head">
      <div>
        <h2 id="finder-title">필요한 계산기 찾기</h2>
        <p><span data-tool-count>{calculators.length}</span>개 계산기 중 지금 확인할 숫자를 검색하세요.</p>
      </div>
      <label class="search-box">
        <span>검색</span>
        <input type="search" placeholder="예: 대출, 광고비, 수수료" data-tool-search />
      </label>
    </div>
    <div class="finder-actions">
      <div class="filter-row" role="list" aria-label="계산기 분류">
        {finderGroups.map(([group, label]) => (
          <button type="button" data-tool-filter={group} class={group === 'all' ? 'active' : ''}>{label}</button>
        ))}
      </div>
      <button class="clear-search" type="button" data-tool-clear>초기화</button>
    </div>
    <div class="hint-row" aria-label="추천 검색어">
      {searchHints.map((hint) => (
        <button type="button" data-tool-hint={hint}>{hint}</button>
      ))}
    </div>
    <p class="empty-state" data-tool-empty hidden>조건에 맞는 계산기가 없습니다. 다른 단어로 검색해보세요.</p>
  </section>

  {[...groups.entries()].map(([group, items]) => (
    <section class="tool-section" id={group} data-tool-section={group}>
      <div class="section-title">
        <h2>{groupLabels[group]}</h2>
        <p>{items.length}개 도구</p>
      </div>
      <div class="tool-list">
        {items.map((calculator) => (
          <a
            class="tool-card"
            href={`/calculators/${calculator.slug}/`}
            data-tool-card
            data-group={calculator.group}
            data-search={`${calculator.shortTitle} ${calculator.title} ${calculator.description} ${calculator.intent}`}
          >
            <span>{calculator.intent}</span>
            <h3>{calculator.shortTitle}</h3>
            <p>{calculator.description}</p>
            <small>계산하기</small>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="ops-strip">
    <h2>계산기 선택 기준</h2>
    <div>
      <p>주문 1건 기준으로 볼 때는 판매자 계산기</p>
      <p>약정 기간 전체 비용을 볼 때는 생활비 계산기</p>
      <p>대출 이자와 시간 가치를 볼 때는 금융·운영 계산기</p>
    </div>
  </section>

  <script is:inline src="/calculators.js" defer></script>
  <script is:inline>
    const searchInput = document.querySelector('[data-tool-search]');
    const filterButtons = [...document.querySelectorAll('[data-tool-filter]')];
    const cards = [...document.querySelectorAll('[data-tool-card]')];
    const sections = [...document.querySelectorAll('[data-tool-section]')];
    const empty = document.querySelector('[data-tool-empty]');
    const count = document.querySelector('[data-tool-count]');
    const clearButton = document.querySelector('[data-tool-clear]');
    const hintButtons = [...document.querySelectorAll('[data-tool-hint]')];
    let activeGroup = 'all';

    function applyToolFilter() {
      const query = (searchInput?.value || '').trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const groupMatch = activeGroup === 'all' || card.dataset.group === activeGroup;
        const textMatch = !query || (card.dataset.search || '').toLowerCase().includes(query);
        const visible = groupMatch && textMatch;
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      sections.forEach((section) => {
        const hasVisibleCard = [...section.querySelectorAll('[data-tool-card]')].some((card) => !card.hidden);
        section.hidden = !hasVisibleCard;
      });

      if (empty) empty.hidden = visibleCount > 0;
      if (count) count.textContent = String(visibleCount);
    }

    searchInput?.addEventListener('input', applyToolFilter);
    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeGroup = button.dataset.toolFilter || 'all';
        filterButtons.forEach((item) => item.classList.toggle('active', item === button));
        applyToolFilter();
      });
    });
    clearButton?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      activeGroup = 'all';
      filterButtons.forEach((item) => item.classList.toggle('active', item.dataset.toolFilter === 'all'));
      applyToolFilter();
    });
    hintButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (searchInput) searchInput.value = button.dataset.toolHint || '';
        activeGroup = 'all';
        filterButtons.forEach((item) => item.classList.toggle('active', item.dataset.toolFilter === 'all'));
        applyToolFilter();
        searchInput?.focus();
      });
    });

    const recentWrap = document.querySelector('[data-recent-tools]');
    const recentList = document.querySelector('[data-recent-list]');
    const recentClear = document.querySelector('[data-recent-clear]');
    const recentKey = 'margin-calculator-recent';

    function renderRecentTools() {
      if (!recentWrap || !recentList) return;
      let recent = [];
      try {
        recent = JSON.parse(localStorage.getItem(recentKey) || '[]');
      } catch {
        recent = [];
      }
      recentWrap.hidden = recent.length === 0;
      recentList.innerHTML = recent
        .map(
          (item) => `
            <a href="${item.href}">
              <span>${item.group}</span>
              <strong>${item.title}</strong>
            </a>
          `
        )
        .join('');
    }

    recentClear?.addEventListener('click', () => {
      localStorage.removeItem(recentKey);
      renderRecentTools();
    });
    renderRecentTools();
  </script>
</BaseLayout>

<style>
  .hero-tool {
    display: grid;
    gap: 18px;
  }
  .hero-copy {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.55fr);
    gap: 22px;
    align-items: stretch;
    padding: 12px 0 2px;
  }
  h1 {
    margin: 0;
    max-width: 720px;
    color: #1c2a23;
    font: 950 clamp(2rem, 4.2vw, 3.9rem)/1.08 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  .hero-copy p {
    margin: 14px 0 0;
    max-width: 680px;
    color: #596760;
    font: 700 1rem/1.7 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .quick-box {
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 16px;
    align-self: end;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .quick-box strong {
    display: block;
    margin-bottom: 12px;
    color: #1c2a23;
    font: 900 0.95rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .quick-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  .quick-row a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #f8faf9;
    color: #1c2a23;
    text-decoration: none;
    font: 900 0.86rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 0 10px;
    text-align: center;
  }
  .quick-row a:hover {
    border-color: #91b8a4;
    background: #edf8f2;
  }
  .revenue-note,
  .ops-strip {
    margin-top: 28px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 18px 20px;
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }
  .pathway {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
    margin-top: 24px;
  }
  .path-card {
    display: grid;
    gap: 8px;
    min-height: 156px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 18px;
    color: inherit;
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .path-card:hover {
    border-color: #91b8a4;
    box-shadow: 0 8px 22px rgba(28, 42, 35, 0.07);
  }
  .path-card span,
  .path-card small {
    color: #16824f;
    font: 900 0.78rem/1.3 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .path-card strong {
    color: #1c2a23;
    font: 950 1.35rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .path-card p {
    margin: 0;
    color: #596760;
    font: 700 0.92rem/1.55 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .recent-tools {
    margin-top: 24px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 18px 20px;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .recent-tools[hidden] {
    display: none;
  }
  .recent-tools .section-title {
    margin-bottom: 12px;
  }
  .recent-tools button {
    min-height: 34px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    color: #596760;
    padding: 0 11px;
    font: 900 0.82rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    cursor: pointer;
  }
  .recent-tools button:hover {
    border-color: #16824f;
    background: #edf8f2;
    color: #0f6c43;
  }
  .recent-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .recent-list a {
    display: inline-grid;
    gap: 3px;
    min-width: 150px;
    border: 1px solid #e1e7e4;
    border-radius: 8px;
    background: #fbfdfc;
    color: inherit;
    text-decoration: none;
    padding: 10px 12px;
  }
  .recent-list a:hover {
    border-color: #91b8a4;
  }
  .recent-list span {
    color: #74817b;
    font: 800 0.74rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .recent-list strong {
    color: #1c2a23;
    font: 950 0.95rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .finder {
    margin-top: 24px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 20px;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .finder-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.45fr);
    gap: 18px;
    align-items: end;
  }
  .finder h2 {
    margin: 0;
    color: #1c2a23;
    font: 950 1.25rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .finder p {
    margin: 7px 0 0;
    color: #596760;
    font: 700 0.94rem/1.55 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .search-box {
    display: grid;
    gap: 7px;
    color: #33443c;
    font: 900 0.82rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .search-box input {
    width: 100%;
    min-height: 46px;
    border: 1px solid #ccd6d1;
    border-radius: 8px;
    background: #fff;
    color: #1c2a23;
    font: 800 0.98rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 0 12px;
    outline: none;
  }
  .search-box input:focus {
    border-color: #16824f;
    box-shadow: 0 0 0 3px rgba(22, 130, 79, 0.12);
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 16px;
  }
  .finder-actions {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-end;
  }
  .clear-search {
    min-height: 36px;
    margin-top: 16px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    color: #596760;
    padding: 0 12px;
    font: 900 0.85rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    cursor: pointer;
    white-space: nowrap;
  }
  .filter-row button {
    min-height: 36px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #f8faf9;
    color: #44544c;
    padding: 0 12px;
    font: 900 0.85rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    cursor: pointer;
  }
  .filter-row button.active,
  .filter-row button:hover,
  .clear-search:hover {
    border-color: #16824f;
    background: #edf8f2;
    color: #0f6c43;
  }
  .hint-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }
  .hint-row button {
    min-height: 32px;
    border: 1px solid #e1e7e4;
    border-radius: 999px;
    background: #fbfdfc;
    color: #596760;
    padding: 0 11px;
    font: 900 0.8rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    cursor: pointer;
  }
  .hint-row button:hover {
    border-color: #91b8a4;
    color: #0f6c43;
  }
  .empty-state {
    margin-top: 16px;
    border: 1px dashed #cfd8d3;
    border-radius: 8px;
    background: #f8faf9;
    padding: 14px;
  }
  .revenue-note h2,
  .ops-strip h2,
  .tool-section h2 {
    margin: 0;
    color: #1c2a23;
    font: 950 1.25rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .revenue-note p,
  .ops-strip p {
    margin: 0;
    color: #4e5d55;
    font: 700 0.95rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .ops-strip div {
    display: grid;
    gap: 6px;
  }
  .tool-section {
    margin-top: 40px;
  }
  .section-title {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 16px;
    margin-bottom: 14px;
  }
  .section-title p {
    margin: 0;
    color: #74817b;
    font: 800 0.88rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  .tool-card {
    min-height: 148px;
    display: flex;
    flex-direction: column;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 15px;
    text-decoration: none;
    color: inherit;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }
  .tool-card[hidden],
  .tool-section[hidden],
  .empty-state[hidden] {
    display: none;
  }
  .tool-card:hover {
    border-color: #91b8a4;
    box-shadow: 0 8px 22px rgba(28, 42, 35, 0.07);
  }
  .tool-card span {
    color: #16824f;
    font: 900 0.78rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-card h3 {
    margin: 14px 0 7px;
    color: #1c2a23;
    font: 950 1.08rem/1.3 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-card p {
    margin: 0;
    color: #596760;
    font: 700 0.9rem/1.55 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-card small {
    margin-top: auto;
    padding-top: 14px;
    color: #16824f;
    font: 900 0.82rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  @media (max-width: 920px) {
    .hero-copy,
    .revenue-note,
    .ops-strip,
    .finder-head {
      grid-template-columns: 1fr;
    }
    .tool-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .pathway {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 620px) {
    .finder-actions {
      display: grid;
    }
    .clear-search {
      width: fit-content;
    }
    .quick-row {
      grid-template-columns: 1fr;
    }
    .tool-list {
      grid-template-columns: 1fr;
    }
    .tool-card {
      min-height: auto;
    }
  }
</style>
