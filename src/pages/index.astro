---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalculatorTool from '@/components/CalculatorTool.astro';
import { calculators, groupLabels, type CalculatorGroup } from '@/data/calculators';

const primary = calculators[0];
const groups = new Map<CalculatorGroup, typeof calculators>();
for (const calculator of calculators) {
  const list = groups.get(calculator.group) ?? [];
  list.push(calculator);
  groups.set(calculator.group, list);
}

const quickLinks = [
  ['마진 계산', '/calculators/seller-margin/'],
  ['손익분기', '/calculators/break-even-price/'],
  ['광고비 한도', '/calculators/ad-roas-limit/'],
  ['렌탈 총비용', '/calculators/rental-total-cost/']
];
---
<BaseLayout
  title="마진계산소 | 판매자 마진·생활비 계산기 허브"
  description="판매가, 원가, 수수료, 광고비, 반품률, 렌탈 총액, 인터넷 갈아타기 손익을 바로 계산하는 정적 계산기 허브입니다."
  canonical="/"
>
  <section class="hero-tool">
    <div class="hero-copy">
      <h1>팔수록 손해 보는 가격인지 먼저 계산하세요.</h1>
      <p>
        판매자 마진, 손익분기 판매가, 광고비 한도, 렌탈 총비용, 인터넷 갈아타기 손익까지
        숫자만 넣고 바로 확인합니다.
      </p>
      <div class="quick-row" aria-label="빠른 계산기 링크">
        {quickLinks.map(([label, href]) => (
          <a href={href}>{label}</a>
        ))}
      </div>
    </div>
    <CalculatorTool calculator={primary} />
  </section>

  <section class="revenue-note">
    <h2>계산 전에 놓치기 쉬운 비용</h2>
    <p>
      판매가만 보면 남는 것 같아도 수수료, 결제비, 배송비, 광고비, 반품 손실을 넣으면
      실제 마진이 크게 달라집니다. 기본값을 바꿔 내 상품 기준으로 다시 계산해보세요.
    </p>
  </section>

  {[...groups.entries()].map(([group, items]) => (
    <section class="tool-section" id={group}>
      <div class="section-title">
        <h2>{groupLabels[group]}</h2>
        <p>{items.length}개 도구</p>
      </div>
      <div class="tool-list">
        {items.map((calculator) => (
          <a class="tool-card" href={`/calculators/${calculator.slug}/`}>
            <span>{calculator.intent}</span>
            <h3>{calculator.shortTitle}</h3>
            <p>{calculator.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="ops-strip">
    <h2>다음에 추가할 계산기</h2>
    <div>
      <p>도매가 역산 계산기</p>
      <p>무료배송 기준 판매가 계산기</p>
      <p>월 고정비를 반영한 목표 매출 계산기</p>
    </div>
  </section>

  <script is:inline src="/calculators.js" defer></script>
</BaseLayout>

<style>
  .hero-tool {
    display: grid;
    gap: 22px;
  }
  .hero-copy {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.55fr);
    gap: 24px;
    align-items: end;
    padding: 20px 0 4px;
  }
  h1 {
    margin: 0;
    max-width: 760px;
    color: #10221c;
    font: 950 clamp(2.1rem, 5vw, 4.7rem)/1.02 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  .hero-copy p {
    margin: 14px 0 0;
    max-width: 720px;
    color: #52645b;
    font: 700 1.05rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .quick-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }
  .quick-row a {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    border: 1px solid #d9e4df;
    border-radius: 8px;
    background: #fff;
    color: #10221c;
    text-decoration: none;
    font: 900 0.9rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 0 12px;
  }
  .quick-row a:hover {
    border-color: #8ab9a2;
    background: #eef7f2;
  }
  .revenue-note,
  .ops-strip {
    margin-top: 30px;
    border: 1px solid #d9e4df;
    border-radius: 8px;
    background: #eef7f2;
    padding: 18px;
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }
  .revenue-note h2,
  .ops-strip h2,
  .tool-section h2 {
    margin: 0;
    color: #10221c;
    font: 950 1.35rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .revenue-note p,
  .ops-strip p {
    margin: 0;
    color: #405149;
    font: 700 0.98rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .ops-strip div {
    display: grid;
    gap: 6px;
  }
  .tool-section {
    margin-top: 44px;
  }
  .section-title {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 16px;
    margin-bottom: 14px;
  }
  .section-title p {
    margin: 0;
    color: #69766f;
    font: 800 0.88rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .tool-card {
    min-height: 170px;
    display: flex;
    flex-direction: column;
    border: 1px solid #d9e4df;
    border-radius: 8px;
    background: #fff;
    padding: 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
  }
  .tool-card:hover {
    transform: translateY(-2px);
    border-color: #8ab9a2;
    box-shadow: 0 12px 28px rgba(16, 34, 28, 0.08);
  }
  .tool-card span {
    color: #1e7a55;
    font: 900 0.78rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-card h3 {
    margin: 18px 0 8px;
    color: #10221c;
    font: 950 1.2rem/1.25 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-card p {
    margin: 0;
    color: #52645b;
    font: 700 0.92rem/1.55 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  @media (max-width: 920px) {
    .hero-copy,
    .revenue-note,
    .ops-strip {
      grid-template-columns: 1fr;
    }
    .tool-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 620px) {
    .tool-list {
      grid-template-columns: 1fr;
    }
    .tool-card {
      min-height: auto;
    }
  }
</style>
