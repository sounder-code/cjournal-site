---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadApartmentManifest } from '@/lib/apartmentBulk';

const manifest = await loadApartmentManifest();
const sourceDate = `${manifest.sourceDate.slice(0, 4)}.${manifest.sourceDate.slice(4, 6)}.${manifest.sourceDate.slice(6, 8)}`;
const latestMonth = manifest.latestMonth.replace('-', '.');
const leadingRegions = [...manifest.regions].sort((a, b) => b.count - a.count).slice(0, 8);
---
<BaseLayout
  title="전국 아파트 관리비 비교 | 바로계산"
  description="K-apt 공개자료로 전국 아파트 관리비 이력과 지역·규모별 비교 수준을 확인합니다."
  canonical="/"
>
  <section class="home-workspace">
    <header class="home-head">
      <div>
        <p>K-apt 공동주택 관리비 데이터</p>
        <h1>우리 단지 관리비를<br />같은 조건끼리 비교합니다</h1>
        <p class="intro">단지 전체 관리비를 관리비부과면적으로 나눈 ㎡당 금액으로 맞추고, 같은 지역과 세대수 구간에서 어느 수준인지 보여줍니다.</p>
      </div>
      <form class="finder" action="/apartments/" method="get">
        <label for="home-apartment-query">단지명 또는 주소</label>
        <div><input id="home-apartment-query" name="q" type="search" placeholder="예: 광화문스페이스본, 종로구" autocomplete="off" required /><button type="submit">단지 찾기</button></div>
        <p>전국 {manifest.stats.complexes.toLocaleString('ko-KR')}개 공동주택에서 검색합니다.</p>
      </form>
    </header>

    <section class="data-status" aria-label="공개 데이터 현황">
      <div><span>상세 리포트</span><strong>{manifest.stats.publishableComplexes.toLocaleString('ko-KR')}</strong><small>5개월 이상 공개 단지</small></div>
      <div><span>관리비 내역</span><strong>{manifest.stats.publishedFeeRows.toLocaleString('ko-KR')}</strong><small>월별 공개 행</small></div>
      <div><span>최근 기준월</span><strong>{latestMonth}</strong><small>단지별 공개월은 다를 수 있음</small></div>
      <div><span>원본 추출일</span><strong>{sourceDate}</strong><small>K-apt 주간 일괄자료</small></div>
    </section>

    <section class="home-columns">
      <div class="region-browser">
        <header><div><h2>지역별 단지 찾기</h2><p>지역을 선택한 뒤 단지명, 주소, 관리비 수준으로 다시 좁힐 수 있습니다.</p></div><a href="/apartments/">전국 목록</a></header>
        <div>{leadingRegions.map((region) => <a href={`/apartments/?region=${encodeURIComponent(region.name)}`}><strong>{region.name}</strong><span>{region.count.toLocaleString('ko-KR')}개 단지</span></a>)}</div>
      </div>
      <aside class="quick-paths">
        <h2>무엇을 확인할 수 있나</h2>
        <a href="/map/"><strong>지도 비교</strong><span>좌표가 확인된 단지를 지도에서 비교</span></a>
        <a href="/management-fee-guide/"><strong>관리비 읽는 법</strong><span>공용·개별·충당금과 비교 단가 해설</span></a>
        <a href="/methodology/"><strong>산정 기준</strong><span>원본 결합, 단가와 백분위 계산 방식</span></a>
      </aside>
    </section>

    <section class="editorial-band">
      <div><p>비교 전에 알아둘 점</p><h2>낮은 관리비가 언제나 좋은 관리를 뜻하지는 않습니다</h2></div>
      <div><p>관리비는 난방방식, 준공연도, 공용시설, 경비 형태와 계절에 따라 달라집니다. 바로계산은 공개 금액을 같은 단위로 정리하지만 서비스 품질이나 관리 적정성을 판정하지 않습니다.</p><p>세대별 고지서는 전용면적과 실제 사용량, 정산에 따라 달라지므로 단지 비교 결과를 청구액으로 해석하면 안 됩니다.</p></div>
    </section>
  </section>
</BaseLayout>

<style>
  :global(.main-content:has(.home-workspace)) { width: min(1240px, calc(100vw - 40px)); }
  .home-workspace { display: grid; gap: 18px; }
  .home-head { min-height: 390px; display: grid; grid-template-columns: 1.08fr .92fr; align-items: center; gap: 70px; border-bottom: 1px solid var(--line); padding: 42px 24px; }
  .home-head > div > p:first-child { margin: 0 0 12px; color: var(--green-strong); font-size: .78rem; font-weight: 850; }
  h1 { margin: 0; font-size: clamp(2.25rem, 5vw, 4.4rem); line-height: 1.08; font-weight: 820; letter-spacing: 0; }
  .intro { max-width: 660px; margin: 20px 0 0; color: var(--muted); font-size: 1rem; line-height: 1.75; font-weight: 650; }
  .finder { border: 1px solid #d9e1dd; border-top: 4px solid var(--green); border-radius: 7px; background: #fff; padding: 24px; box-shadow: var(--shadow-md); }
  .finder label { display: block; margin-bottom: 9px; font-size: .78rem; font-weight: 850; }
  .finder > div { display: grid; grid-template-columns: minmax(0,1fr) auto; gap: 8px; }
  .finder input { min-width: 0; height: 50px; border: 1px solid var(--line-strong); border-radius: 5px; padding: 0 14px; font-weight: 700; }
  .finder button { border: 0; border-radius: 5px; background: var(--green-strong); color: #fff; padding: 0 18px; font-weight: 850; cursor: pointer; }
  .finder p { margin: 10px 0 0; color: var(--subtle); font-size: .72rem; font-weight: 700; }
  .data-status { display: grid; grid-template-columns: repeat(4,1fr); border: 1px solid var(--line); border-radius: 7px; background: #fff; }
  .data-status div { min-height: 108px; display: grid; align-content: center; gap: 3px; padding: 18px 22px; border-right: 1px solid var(--line); }
  .data-status div:last-child { border: 0; }
  .data-status span, .data-status small { color: var(--subtle); font-size: .7rem; font-weight: 750; }
  .data-status strong { font-size: 1.55rem; font-weight: 790; font-variant-numeric: tabular-nums; }
  .home-columns { display: grid; grid-template-columns: minmax(0,1fr) 340px; gap: 18px; }
  .region-browser, .quick-paths { border: 1px solid var(--line); border-radius: 7px; background: #fff; padding: 20px; }
  .region-browser header { display: flex; justify-content: space-between; gap: 20px; align-items: start; margin-bottom: 16px; }
  h2 { margin: 0; font-size: 1.18rem; }
  .region-browser header p { margin: 5px 0 0; color: var(--muted); font-size: .78rem; }
  .region-browser header > a { color: var(--green-strong); font-size: .76rem; font-weight: 850; text-decoration: none; }
  .region-browser > div { display: grid; grid-template-columns: repeat(2,1fr); border-top: 1px solid var(--line); border-left: 1px solid var(--line); }
  .region-browser > div a { display: flex; justify-content: space-between; gap: 12px; padding: 15px; border-right: 1px solid var(--line); border-bottom: 1px solid var(--line); color: var(--ink); text-decoration: none; }
  .region-browser > div span { color: var(--subtle); font-size: .72rem; }
  .quick-paths { display: grid; align-content: start; gap: 0; }
  .quick-paths h2 { margin-bottom: 10px; }
  .quick-paths a { display: grid; gap: 3px; border-top: 1px solid var(--line); padding: 16px 0; color: var(--ink); text-decoration: none; }
  .quick-paths span { color: var(--muted); font-size: .76rem; }
  .editorial-band { display: grid; grid-template-columns: .72fr 1.28fr; gap: 50px; background: #18221e; color: #fff; padding: 34px; }
  .editorial-band > div:first-child p { margin: 0 0 7px; color: #80d4ae; font-size: .74rem; font-weight: 850; }
  .editorial-band h2 { font-size: 1.5rem; line-height: 1.4; }
  .editorial-band > div:last-child p { margin: 0; color: #d3ddd8; font-size: .88rem; line-height: 1.75; }
  .editorial-band > div:last-child p + p { margin-top: 9px; }
  @media(max-width:850px){.home-head,.home-columns,.editorial-band{grid-template-columns:1fr}.home-head{min-height:0;gap:30px;padding:28px 0}.data-status{grid-template-columns:repeat(2,1fr)}.data-status div:nth-child(2){border-right:0}.data-status div:nth-child(-n+2){border-bottom:1px solid var(--line)}.home-columns{gap:12px}.editorial-band{gap:18px;padding:24px}}
  @media(max-width:520px){.finder{padding:18px}.finder>div{grid-template-columns:1fr}.finder button{height:46px}.region-browser>div{grid-template-columns:1fr}.data-status strong{font-size:1.2rem}.data-status div{padding:14px;min-height:94px}}
</style>
