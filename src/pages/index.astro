---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalculatorTool from '@/components/CalculatorTool.astro';
import { calculators, groupLabels, type CalculatorGroup } from '@/data/calculators';

const primary = calculators[0];
const groups = new Map<CalculatorGroup, typeof calculators>();
for (const calculator of calculators) {
  const list = groups.get(calculator.group) ?? [];
  list.push(calculator);
  groups.set(calculator.group, list);
}

const quickLinks = [
  ['마진 계산', '/calculators/seller-margin/'],
  ['단가 비교', '/calculators/unit-price-compare/'],
  ['대출 이자', '/calculators/loan-interest/'],
  ['월세 총부담', '/calculators/monthly-rent-total/']
];

const finderGroups: Array<['all' | CalculatorGroup, string]> = [
  ['all', '전체'],
  ...Object.entries(groupLabels).map(([group, label]) => [group as CalculatorGroup, label] as [CalculatorGroup, string])
];

const groupSummaries: Record<CalculatorGroup, { body: string; examples: string[] }> = {
  seller: {
    body: '가격, 수수료, 쿠폰, 광고비처럼 판매 전 손익을 흔드는 숫자를 봅니다.',
    examples: ['마진', '쿠폰', '묶음배송']
  },
  living: {
    body: '렌탈, 할부, 구독, 유류비처럼 매달 빠져나가는 돈을 총액으로 비교합니다.',
    examples: ['렌탈', '단가', '자동차']
  },
  utility: {
    body: '대출, 예금, 회수기간처럼 기간이 길수록 차이가 커지는 숫자를 계산합니다.',
    examples: ['대출', '복리', '퍼센트']
  },
  housing: {
    body: '월세, 관리비, 중개보수처럼 계약 전에 총부담을 알아야 하는 주거비를 봅니다.',
    examples: ['월세', '중개보수', '관리비']
  },
  health: {
    body: 'BMI, 칼로리, 물 섭취량처럼 매일 확인하기 쉬운 생활 건강 숫자를 계산합니다.',
    examples: ['BMI', '칼로리', '물']
  },
  work: {
    body: '급여, 프리랜서 정산, 연차수당처럼 일한 뒤 실제 남는 금액을 계산합니다.',
    examples: ['급여', '퇴직금', '연차']
  }
};

const searchHints = ['대출', '월세', '급여', '퇴직금', '복리', '단가', '자동차', 'BMI'];
const calculatorScriptVersion = calculators.length;
const startRoutes = [
  {
    title: '스마트스토어 상품을 올리기 전',
    body: '판매가, 수수료, 배송비, 광고비를 한 번에 넣고 팔아도 남는지 먼저 봅니다.',
    href: '/calculators/seller-margin/?price=29900&cost=12000&platformFee=5.6&paymentFee=3.3&shipping=3000&adCost=1200&returnRate=2',
    label: '마진 계산으로 시작'
  },
  {
    title: '쿠폰·세일 행사 전에',
    body: '할인율을 넣고 행사 후 주문당 순이익이 남는지 봅니다.',
    href: '/calculators/discount-margin/?regularPrice=39900&discountRate=15&cost=17000&feeRate=13.5&shipping=3500&adCost=1500',
    label: '할인 마진 보기'
  },
  {
    title: '대출 월 납입액이 걱정될 때',
    body: '원리금균등, 원금균등, 만기일시 방식별 월 납입액과 총이자를 비교합니다.',
    href: '/calculators/loan-interest/?principal=300000000&annualRate=4.2&years=30&repaymentType=equal-payment',
    label: '대출 이자 계산'
  },
  {
    title: '월 부담에서 대출 규모를 역산',
    body: '감당 가능한 월 납입액을 기준으로 대출 원금을 거꾸로 계산합니다.',
    href: '/calculators/loan-affordability/?monthlyPayment=700000&annualRate=4.5&years=30&income=3500000',
    label: '대출 가능액 보기'
  },
  {
    title: '월세 계약을 총액으로 볼 때',
    body: '보증금 기회비용, 월세, 관리비를 합쳐 실제 월평균 부담을 계산합니다.',
    href: '/calculators/monthly-rent-total/?deposit=10000000&monthlyRent=650000&maintenance=90000&months=24&depositRate=3.5',
    label: '월세 총부담 계산'
  },
  {
    title: '세전 월급과 실수령 차이를 볼 때',
    body: '보험·연금 공제율, 세금, 기타 공제를 넣고 실제 입금액을 확인합니다.',
    href: '/calculators/salary-net-pay/?grossPay=3500000&insuranceRate=9.4&incomeTax=95000&otherDeduction=0',
    label: '급여 실수령 계산'
  },
  {
    title: '대용량 상품이 정말 싼지 볼 때',
    body: '가격과 용량을 같은 단위로 맞춰 1개·1g·1ml 기준 단가를 비교합니다.',
    href: '/calculators/unit-price-compare/?priceA=12900&quantityA=500&priceB=18900&quantityB=900',
    label: '단가 비교 계산'
  },
  {
    title: '목표금액까지 얼마나 걸릴지 볼 때',
    body: '현재 모은 금액과 월 저축액, 예상 수익률을 넣어 목표 달성 기간을 계산합니다.',
    href: '/calculators/goal-savings/?goalAmount=30000000&currentAmount=5000000&monthlyDeposit=800000&annualReturn=3',
    label: '목표 저축 계산'
  },
  {
    title: '렌탈·통신비 계약을 비교할 때',
    body: '월요금보다 약정 총액과 사은품, 위약금을 같이 놓고 봅니다.',
    href: '/calculators/rental-total-cost/?monthly=29900&months=36&install=0&reward=150000',
    label: '렌탈 총액 계산'
  },
  {
    title: '구독비와 고정비를 줄일 때',
    body: '작은 월 지출을 연 단위와 3년 누적으로 바꿔 절감 효과를 봅니다.',
    href: '/calculators/subscription-cut/?monthlyTotal=89000&cutRate=35&newService=12000',
    label: '구독비 절감 계산'
  }
];
---
<BaseLayout
  title="바로계산 | 생활 계산기 모음"
  description="마진, 단가, 대출 이자, 월세 총부담, 급여 실수령액, 복리, 퇴직금, BMI까지 일상 판단에 필요한 계산기를 모았습니다."
  canonical="/"
>
  <section class="hero-tool">
    <div class="hero-copy">
      <div>
        <h1>필요한 계산을 <span>바로.</span></h1>
        <p>
          돈, 계약, 쇼핑, 급여, 건강처럼 일상에서 자주 마주치는 숫자를 한 화면에서 계산합니다.
          기본값을 바꿔 실제 조건에 맞게 다시 계산해보세요.
        </p>
        <div class="proof-row" aria-label="사이트 핵심 기능">
          <span>{calculators.length}개 계산기</span>
          <span>예시값 제공</span>
          <span>결과 복사·공유</span>
          <span>브라우저 저장</span>
        </div>
      </div>
      <div class="quick-box">
        <strong>자주 쓰는 계산기</strong>
        <div class="quick-row" aria-label="빠른 계산기 링크">
          {quickLinks.map(([label, href]) => (
            <a href={href}>{label}</a>
          ))}
        </div>
      </div>
    </div>
    <CalculatorTool calculator={primary} />
  </section>

  <section class="revenue-note">
      <h2>빠뜨리기 쉬운 비용</h2>
    <p>
      판매가만 보면 남는 것 같아도 수수료, 결제비, 배송비, 광고비, 반품 손실을 넣으면
      실제 마진이 크게 달라집니다. 기본값을 바꿔 내 상품 기준으로 다시 계산해보세요.
    </p>
  </section>

  <section class="starter-routes" aria-labelledby="starter-title">
    <div class="section-title">
      <h2 id="starter-title">자주 쓰는 상황</h2>
      <p>예시 조건으로 시작</p>
    </div>
    <div class="starter-grid">
      {startRoutes.map((route) => (
        <a href={route.href}>
          <strong>{route.title}</strong>
          <p>{route.body}</p>
          <span>{route.label}</span>
        </a>
      ))}
    </div>
  </section>

  <section class="pathway" aria-label="계산기 분류 바로가기">
    {([...groups.entries()] as Array<[CalculatorGroup, typeof calculators]>).map(([group, items]) => (
      <a class="path-card" href={`#${group}`}>
        <span>{groupLabels[group]}</span>
        <strong>{items.length}개 계산기</strong>
        <p>{groupSummaries[group].body}</p>
        <small>{groupSummaries[group].examples.join(' · ')}</small>
      </a>
    ))}
  </section>

  <section class="recent-tools" data-recent-tools hidden>
    <div class="section-title">
      <h2>최근 본 계산기</h2>
      <button type="button" data-recent-clear>비우기</button>
    </div>
    <div class="recent-list" data-recent-list></div>
  </section>

  <section class="saved-tools" data-favorite-tools hidden>
    <div class="section-title">
      <h2>즐겨찾는 계산기</h2>
      <button type="button" data-favorite-clear>비우기</button>
    </div>
    <div class="recent-list" data-favorite-list></div>
  </section>

  <section class="finder" id="finder" aria-labelledby="finder-title">
    <div class="finder-head">
      <div>
        <h2 id="finder-title">필요한 계산기 찾기</h2>
        <p><span data-tool-count>{calculators.length}</span>개 계산기 중 지금 볼 항목을 검색하세요.</p>
      </div>
      <label class="search-box">
        <span>검색</span>
        <input type="search" placeholder="예: 월세, 급여, 대출, BMI" data-tool-search />
      </label>
    </div>
    <div class="finder-actions">
      <div class="filter-row" role="list" aria-label="계산기 분류">
        {finderGroups.map(([group, label]) => (
          <button type="button" data-tool-filter={group} class={group === 'all' ? 'active' : ''}>{label}</button>
        ))}
      </div>
      <button class="clear-search" type="button" data-tool-clear>초기화</button>
    </div>
    <div class="hint-row" aria-label="추천 검색어">
      {searchHints.map((hint) => (
        <button type="button" data-tool-hint={hint}>{hint}</button>
      ))}
    </div>
    <p class="empty-state" data-tool-empty hidden>조건에 맞는 계산기가 없습니다. 다른 단어로 검색해보세요.</p>
  </section>

  {[...groups.entries()].map(([group, items]) => (
    <section class="tool-section" id={group} data-tool-section={group}>
      <div class="section-title">
        <h2>{groupLabels[group]}</h2>
        <p>{items.length}개 계산기</p>
      </div>
      <div class="tool-list">
        {items.map((calculator) => (
          <a
            class="tool-card"
            href={`/calculators/${calculator.slug}/`}
            data-tool-card
            data-group={calculator.group}
            data-search={`${calculator.shortTitle} ${calculator.title} ${calculator.description} ${calculator.intent}`}
          >
            <span>{calculator.intent}</span>
            <h3>{calculator.shortTitle}</h3>
            <p>{calculator.description}</p>
            <small>계산하기</small>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="ops-strip">
    <h2>무엇부터 볼까</h2>
    <div>
      <p>가격과 비용 구조를 볼 때는 마진·판매 계산기</p>
      <p>약정 기간 전체 부담을 볼 때는 생활비·주거 계산기</p>
      <p>이자, 복리, 목표 기간을 볼 때는 금융·시간 계산기</p>
      <p>급여, 퇴직금, 건강 기준처럼 반복되는 숫자는 분야별 계산기</p>
    </div>
  </section>

  <script is:inline src={`/calculators.js?v=${calculatorScriptVersion}`} defer></script>
  <script is:inline>
    {
    const searchInput = document.querySelector('[data-tool-search]');
    const filterButtons = [...document.querySelectorAll('[data-tool-filter]')];
    const cards = [...document.querySelectorAll('[data-tool-card]')];
    const sections = [...document.querySelectorAll('[data-tool-section]')];
    const empty = document.querySelector('[data-tool-empty]');
    const count = document.querySelector('[data-tool-count]');
    const clearButton = document.querySelector('[data-tool-clear]');
    const hintButtons = [...document.querySelectorAll('[data-tool-hint]')];
    let activeGroup = 'all';

    function applyToolFilter() {
      const query = (searchInput?.value || '').trim().toLowerCase();
      let visibleCount = 0;

      cards.forEach((card) => {
        const groupMatch = activeGroup === 'all' || card.dataset.group === activeGroup;
        const textMatch = !query || (card.dataset.search || '').toLowerCase().includes(query);
        const visible = groupMatch && textMatch;
        card.hidden = !visible;
        if (visible) visibleCount += 1;
      });

      sections.forEach((section) => {
        const hasVisibleCard = [...section.querySelectorAll('[data-tool-card]')].some((card) => !card.hidden);
        section.hidden = !hasVisibleCard;
      });

      if (empty) empty.hidden = visibleCount > 0;
      if (count) count.textContent = String(visibleCount);
    }

    searchInput?.addEventListener('input', applyToolFilter);
    filterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        activeGroup = button.dataset.toolFilter || 'all';
        filterButtons.forEach((item) => item.classList.toggle('active', item === button));
        applyToolFilter();
      });
    });
    clearButton?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      activeGroup = 'all';
      filterButtons.forEach((item) => item.classList.toggle('active', item.dataset.toolFilter === 'all'));
      applyToolFilter();
    });
    hintButtons.forEach((button) => {
      button.addEventListener('click', () => {
        if (searchInput) searchInput.value = button.dataset.toolHint || '';
        activeGroup = 'all';
        filterButtons.forEach((item) => item.classList.toggle('active', item.dataset.toolFilter === 'all'));
        applyToolFilter();
        searchInput?.focus();
      });
    });

    const recentWrap = document.querySelector('[data-recent-tools]');
    const recentList = document.querySelector('[data-recent-list]');
    const recentClear = document.querySelector('[data-recent-clear]');
    const favoriteWrap = document.querySelector('[data-favorite-tools]');
    const favoriteList = document.querySelector('[data-favorite-list]');
    const favoriteClear = document.querySelector('[data-favorite-clear]');
    const recentKey = 'margin-calculator-recent';
    const favoriteKey = 'margin-calculator-favorites';

    function readStoredList(key) {
      try {
        return JSON.parse(localStorage.getItem(key) || '[]');
      } catch {
        return [];
      }
    }

    function appendStoredTool(list, item) {
      const link = document.createElement('a');
      link.href = item.href || `/calculators/${item.slug}/`;
      const group = document.createElement('span');
      group.textContent = item.group || '저장한 계산기';
      const title = document.createElement('strong');
      title.textContent = item.title || item.slug || '계산기';
      link.append(group, title);
      list.append(link);
    }

    function renderStoredTools({ key, wrap, list }) {
      if (!wrap || !list) return;
      const items = readStoredList(key);
      wrap.hidden = items.length === 0;
      list.replaceChildren();
      items.forEach((item) => appendStoredTool(list, item));
    }

    function renderRecentTools() {
      renderStoredTools({ key: recentKey, wrap: recentWrap, list: recentList });
    }

    function renderFavoriteTools() {
      renderStoredTools({ key: favoriteKey, wrap: favoriteWrap, list: favoriteList });
    }

    recentClear?.addEventListener('click', () => {
      localStorage.removeItem(recentKey);
      renderRecentTools();
    });
    favoriteClear?.addEventListener('click', () => {
      localStorage.removeItem(favoriteKey);
      renderFavoriteTools();
    });
    renderRecentTools();
    renderFavoriteTools();
    }
  </script>
</BaseLayout>

<style>
  .hero-tool {
    display: grid;
    gap: 20px;
    position: relative;
    padding-top: 8px;
  }
  .hero-copy {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.46fr);
    gap: 24px;
    align-items: stretch;
    padding: 20px 0 4px;
  }
  h1 {
    margin: 0;
    max-width: 760px;
    color: var(--ink);
    font: 950 clamp(2.18rem, 4.5vw, 4.35rem)/1.04 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  h1 span {
    color: var(--green-strong);
  }
  .hero-copy p {
    margin: 14px 0 0;
    max-width: 680px;
    color: #4c5a53;
    font: 750 1.02rem/1.72 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    word-break: keep-all;
    overflow-wrap: anywhere;
  }
  .proof-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 20px;
  }
  .proof-row span {
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    border: 1px solid #dce6e1;
    border-radius: 8px;
    background: #fff;
    color: #26352f;
    padding: 0 11px;
    box-shadow: 0 1px 2px rgba(16, 22, 20, 0.04);
    font: 900 0.8rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    white-space: nowrap;
  }
  .quick-box {
    border: 1px solid rgba(255, 255, 255, 0.13);
    border-radius: 8px;
    background:
      radial-gradient(circle at 88% 8%, rgba(20, 164, 108, 0.22), transparent 30%),
      linear-gradient(135deg, rgba(38, 103, 180, 0.20), transparent 46%),
      #101916;
    padding: 18px;
    align-self: end;
    box-shadow: var(--shadow-lg);
  }
  .quick-box strong {
    display: block;
    margin-bottom: 12px;
    color: #f6fbf8;
    font: 900 0.95rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .quick-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  .quick-row a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.085);
    color: #f6fbf8;
    text-decoration: none;
    font: 900 0.86rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 0 10px;
    text-align: center;
  }
  .quick-row a:hover {
    border-color: rgba(151, 194, 255, 0.48);
    background: rgba(151, 194, 255, 0.16);
  }
  .revenue-note,
  .ops-strip {
    margin-top: 26px;
    border: 1px solid #dce6e1;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.86);
    padding: 18px 20px;
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
    box-shadow: 0 1px 2px rgba(16, 22, 20, 0.04);
    border-left: 4px solid var(--green);
  }
  .pathway {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
    margin-top: 26px;
  }
  .starter-routes {
    margin-top: 30px;
  }
  .starter-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .starter-grid a {
    display: grid;
    gap: 9px;
    min-height: 166px;
    border: 1px solid #dfe8e4;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.94);
    color: inherit;
