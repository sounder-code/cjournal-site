---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CalculatorTool from '@/components/CalculatorTool.astro';
import { calculators, groupLabels, type CalculatorGroup } from '@/data/calculators';

const primary = calculators[0];
const groups = new Map<CalculatorGroup, typeof calculators>();
for (const calculator of calculators) {
  const list = groups.get(calculator.group) ?? [];
  list.push(calculator);
  groups.set(calculator.group, list);
}

const quickLinks = [
  ['마진 계산', '/calculators/seller-margin/'],
  ['손익분기', '/calculators/break-even-price/'],
  ['광고비 한도', '/calculators/ad-roas-limit/'],
  ['렌탈 총비용', '/calculators/rental-total-cost/']
];
---
<BaseLayout
  title="마진계산소 | 판매자 마진·생활비 계산기 허브"
  description="판매가, 원가, 수수료, 광고비, 반품률, 렌탈 총액, 인터넷 갈아타기 손익을 바로 계산하는 정적 계산기 허브입니다."
  canonical="/"
>
  <section class="hero-tool">
    <div class="hero-copy">
      <div>
        <h1>마진, 이자, 생활비를 바로 계산하세요.</h1>
        <p>
          판매자 비용과 월 고정비, 대출 이자처럼 놓치기 쉬운 숫자를 한 화면에서 확인합니다.
          기본값을 바꿔 실제 조건에 맞게 다시 계산해보세요.
        </p>
      </div>
      <div class="quick-box">
        <strong>자주 쓰는 계산기</strong>
        <div class="quick-row" aria-label="빠른 계산기 링크">
          {quickLinks.map(([label, href]) => (
            <a href={href}>{label}</a>
          ))}
        </div>
      </div>
    </div>
    <CalculatorTool calculator={primary} />
  </section>

  <section class="revenue-note">
    <h2>계산 전 체크</h2>
    <p>
      판매가만 보면 남는 것 같아도 수수료, 결제비, 배송비, 광고비, 반품 손실을 넣으면
      실제 마진이 크게 달라집니다. 기본값을 바꿔 내 상품 기준으로 다시 계산해보세요.
    </p>
  </section>

  {[...groups.entries()].map(([group, items]) => (
    <section class="tool-section" id={group}>
      <div class="section-title">
        <h2>{groupLabels[group]}</h2>
        <p>{items.length}개 도구</p>
      </div>
      <div class="tool-list">
        {items.map((calculator) => (
          <a class="tool-card" href={`/calculators/${calculator.slug}/`}>
            <span>{calculator.intent}</span>
            <h3>{calculator.shortTitle}</h3>
            <p>{calculator.description}</p>
          </a>
        ))}
      </div>
    </section>
  ))}

  <section class="ops-strip">
    <h2>계산기 선택 기준</h2>
    <div>
      <p>주문 1건 기준으로 볼 때는 판매자 계산기</p>
      <p>약정 기간 전체 비용을 볼 때는 생활비 계산기</p>
      <p>대출 이자와 시간 가치를 볼 때는 금융·운영 계산기</p>
    </div>
  </section>

  <script is:inline src="/calculators.js" defer></script>
</BaseLayout>

<style>
  .hero-tool {
    display: grid;
    gap: 18px;
  }
  .hero-copy {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.55fr);
    gap: 22px;
    align-items: stretch;
    padding: 12px 0 2px;
  }
  h1 {
    margin: 0;
    max-width: 720px;
    color: #1c2a23;
    font: 950 clamp(2rem, 4.2vw, 3.9rem)/1.08 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  .hero-copy p {
    margin: 14px 0 0;
    max-width: 680px;
    color: #596760;
    font: 700 1rem/1.7 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .quick-box {
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 16px;
    align-self: end;
    box-shadow: 0 1px 2px rgba(28, 42, 35, 0.04);
  }
  .quick-box strong {
    display: block;
    margin-bottom: 12px;
    color: #1c2a23;
    font: 900 0.95rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .quick-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
  }
  .quick-row a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #f8faf9;
    color: #1c2a23;
    text-decoration: none;
    font: 900 0.86rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    padding: 0 10px;
    text-align: center;
  }
  .quick-row a:hover {
    border-color: #91b8a4;
    background: #edf8f2;
  }
  .revenue-note,
  .ops-strip {
    margin-top: 28px;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 18px 20px;
    display: grid;
    grid-template-columns: 180px minmax(0, 1fr);
    gap: 18px;
    align-items: start;
  }
  .revenue-note h2,
  .ops-strip h2,
  .tool-section h2 {
    margin: 0;
    color: #1c2a23;
    font: 950 1.25rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .revenue-note p,
  .ops-strip p {
    margin: 0;
    color: #4e5d55;
    font: 700 0.95rem/1.65 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .ops-strip div {
    display: grid;
    gap: 6px;
  }
  .tool-section {
    margin-top: 40px;
  }
  .section-title {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 16px;
    margin-bottom: 14px;
  }
  .section-title p {
    margin: 0;
    color: #74817b;
    font: 800 0.88rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  .tool-card {
    min-height: 148px;
    display: flex;
    flex-direction: column;
    border: 1px solid #d8dfdb;
    border-radius: 8px;
    background: #fff;
    padding: 15px;
    text-decoration: none;
    color: inherit;
    transition: border-color 160ms ease, box-shadow 160ms ease;
  }
  .tool-card:hover {
    border-color: #91b8a4;
    box-shadow: 0 8px 22px rgba(28, 42, 35, 0.07);
  }
  .tool-card span {
    color: #16824f;
    font: 900 0.78rem/1.2 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-card h3 {
    margin: 14px 0 7px;
    color: #1c2a23;
    font: 950 1.08rem/1.3 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tool-card p {
    margin: 0;
    color: #596760;
    font: 700 0.9rem/1.55 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  @media (max-width: 920px) {
    .hero-copy,
    .revenue-note,
    .ops-strip {
      grid-template-columns: 1fr;
    }
    .tool-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 620px) {
    .quick-row {
      grid-template-columns: 1fr;
    }
    .tool-list {
      grid-template-columns: 1fr;
    }
    .tool-card {
      min-height: auto;
    }
  }
</style>
