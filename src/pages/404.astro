---
import BaseLayout from '@/layouts/BaseLayout.astro';
---
<BaseLayout title="페이지를 찾을 수 없습니다 | 단지표" description="요청한 페이지가 없거나 주소가 변경되었습니다." robots="noindex, nofollow">
  <section class="not-found">
    <p>404</p><h1>페이지를 찾을 수 없습니다</h1>
    <p>주소를 다시 확인하거나 단지 찾기에서 원하는 아파트를 검색해 주세요.</p>
    <div><a href="/apartments/">단지 찾기</a><a href="/">홈으로</a></div>
  </section>
</BaseLayout>
<style>
  .not-found { max-width: 720px; min-height: 58vh; display: grid; align-content: center; justify-items: start; gap: 12px; }
  .not-found > p:first-child { margin: 0; color: var(--green-strong); font-size: .85rem; font-weight: 900; }
  h1 { margin: 0; font-size: clamp(2rem,6vw,4rem); line-height: 1.1; }
  .not-found > p:not(:first-child) { margin: 0; color: var(--muted); font-weight: 650; }
  .not-found div { display: flex; gap: 8px; margin-top: 10px; }
  .not-found a { border: 1px solid var(--line-strong); border-radius: 5px; background: #fff; color: var(--ink); padding: 10px 14px; text-decoration: none; font-weight: 850; }
  .not-found a:first-child { border-color: var(--green-strong); background: var(--green-strong); color: #fff; }
</style>
