---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SeoHead from '@/components/SeoHead.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  robots?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  updatedTime?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
  fullBleed?: boolean;
  hideHeader?: boolean;
}

const { title, description, canonical, robots, type, publishedTime, updatedTime, structuredData, fullBleed = false, hideHeader = false } = Astro.props;
const gtmId = (import.meta.env.PUBLIC_GTM_ID || 'GTM-TXMPF75Z').trim();
const gaId = (import.meta.env.PUBLIC_GA_ID || 'G-SE44ENS3KV').trim();
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="google-adsense-account" content="ca-pub-3605659204864367" />
    {
      gtmId && (
        <script
          is:inline
          set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`}
        />
      )
    }
    {gaId && <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
    {
      gaId && (
        <script
          is:inline
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}',{anonymize_ip:true,send_page_view:true});`}
        />
      )
    }
    <SeoHead title={title} description={description} canonical={canonical} robots={robots} type={type} publishedTime={publishedTime} updatedTime={updatedTime} />
    {structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData).replace(/</g, '\\u003c')} />}
  </head>
  <body class:list={{ 'full-bleed-page': fullBleed }}>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          ></iframe>
        </noscript>
      )
    }
    {!hideHeader && <Header />}
    <main class:list={['container', 'main-content', { 'main-content-full': fullBleed }]}>
      <slot />
    </main>
    {!fullBleed && <Footer />}
    <script is:inline>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest('[data-affiliate-link="true"]');
        if (!(link instanceof HTMLAnchorElement)) return;

        const payload = {
          event: 'affiliate_click',
          offer_id: link.dataset.offerId || '',
          offer_title: link.dataset.offerTitle || '',
          post_slug: link.dataset.postSlug || '',
          href: link.href
        };

        window['dataLayer'] = window['dataLayer'] || [];
        window['dataLayer'].push(payload);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #101513;
    --muted: #53615a;
    --subtle: #7a8781;
    --line: #dfe7e3;
    --line-strong: #c7d4ce;
    --surface: #ffffff;
    --surface-soft: #f7faf8;
    --canvas: #f5f6f5;
    --green: #14a46c;
    --green-strong: #0c754c;
    --green-soft: #eaf8f1;
    --navy: #101916;
    --blue: #2667b4;
    --blue-soft: #edf5ff;
    --amber: #b7791f;
    --amber-soft: #fff7e8;
    --red: #b84a42;
    --shadow-sm: 0 1px 2px rgba(16, 22, 20, 0.05);
    --shadow-md: 0 14px 34px rgba(16, 22, 20, 0.08);
    --shadow-lg: 0 28px 64px rgba(16, 22, 20, 0.15);
  }
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Apple SD Gothic Neo', 'Noto Sans KR', 'Segoe UI', sans-serif;
    font-weight: 400;
    color: var(--ink);
    background: var(--canvas);
    line-height: 1.55;
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }
  ::selection {
    background: rgba(22, 130, 79, 0.18);
  }
  :focus-visible {
    outline: 3px solid rgba(47, 102, 134, 0.32);
    outline-offset: 3px;
  }
  .container { width: min(1400px, calc(100vw - 40px)); margin: 0 auto; }
  .main-content { min-height: 72vh; padding: 24px 0 64px; }
  .main-content-full { width: 100%; max-width: none; min-height: 0; padding: 0; }
  .site-footer {
    background: rgba(255, 255, 255, 0.96);
    border-top: 1px solid var(--line);
    border-bottom: 0;
  }
  button,
  input,
  select {
    font: inherit;
  }
  @media (max-width: 760px) {
    .container { width: calc(100vw - 24px); }
    .main-content { padding-top: 16px; }
    .main-content-full { width: 100%; padding: 0; }
  }
  .header-inner { padding: 12px 0; }
  .logo {
    color: var(--ink);
    text-decoration: none;
    font: 950 1.18rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  nav { display: flex; gap: 14px; }
  nav a { color: var(--muted); text-decoration: none; font-weight: 800; }
  .site-footer .container { padding: 18px 0; }
  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .site-footer nav {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .site-footer nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 800;
  }
  .site-footer nav a:hover {
    color: var(--ink);
    text-decoration: underline;
  }
  .site-footer p {
    margin: 0 0 4px;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .muted { color: #63706a; }
  .meta {
    font-size: 0.9rem;
    color: #63706a;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tags a {
    font-size: 0.84rem;
    color: #214b78;
    text-decoration: none;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    border: 1px solid #d4dce7;
    background: transparent;
    padding: 4px 8px;
    border-radius: 999px;
  }
  .tags a:hover { border-color: #9bb3cf; }
  .article-card {
    background: #fff;
    border: 1px solid #dadad6;
    padding: 16px;
  }
  .article-card p { margin: 0 0 8px; color: #252525; }
  .ad-slot { min-height: 90px; border-radius: 8px; margin: 18px 0; }
  .ad-slot-disabled { border: 1px dashed #c7d3e3; background: #f3f7fc; }

  /* Global media safety for mobile screens */
  img,
  picture,
  video,
  canvas,
  svg {
    max-width: 100%;
    height: auto;
  }

  iframe {
    max-width: 100%;
  }
</style>
