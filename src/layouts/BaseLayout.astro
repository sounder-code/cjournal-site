---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SeoHead from '@/components/SeoHead.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  updatedTime?: string;
}

const { title, description, canonical, type, publishedTime, updatedTime } = Astro.props;
const gtmId = (import.meta.env.PUBLIC_GTM_ID || 'GTM-TXMPF75Z').trim();
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {
      gtmId && (
        <script
          is:inline
          set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`}
        />
      )
    }
    <SeoHead title={title} description={description} canonical={canonical} type={type} publishedTime={publishedTime} updatedTime={updatedTime} />
  </head>
  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          ></iframe>
        </noscript>
      )
    }
    <Header />
    <main class="container main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest('[data-affiliate-link="true"]');
        if (!(link instanceof HTMLAnchorElement)) return;

        const payload = {
          event: 'affiliate_click',
          offer_id: link.dataset.offerId || '',
          offer_title: link.dataset.offerTitle || '',
          post_slug: link.dataset.postSlug || '',
          href: link.href
        };

        window['dataLayer'] = window['dataLayer'] || [];
        window['dataLayer'].push(payload);
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #101614;
    --muted: #59635e;
    --subtle: #78827d;
    --line: #dde4e0;
    --line-strong: #c9d3ce;
    --surface: #ffffff;
    --surface-soft: #f6f8f7;
    --canvas: #f7f9f8;
    --green: #16824f;
    --green-strong: #0f6c43;
    --green-soft: #edf7f1;
    --navy: #111c18;
    --blue: #2563a7;
    --blue-soft: #eef5ff;
    --amber: #b7791f;
    --amber-soft: #fff7e8;
    --red: #b84a42;
    --shadow-sm: 0 1px 2px rgba(16, 22, 20, 0.05);
    --shadow-md: 0 12px 30px rgba(16, 22, 20, 0.08);
    --shadow-lg: 0 24px 54px rgba(16, 22, 20, 0.14);
  }
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', -apple-system, BlinkMacSystemFont, sans-serif;
    color: var(--ink);
    background:
      linear-gradient(90deg, rgba(16, 22, 20, 0.035) 1px, transparent 1px),
      linear-gradient(180deg, #ffffff 0, var(--canvas) 420px, var(--canvas) 100%);
    background-size: 44px 44px, auto;
    line-height: 1.55;
    text-rendering: optimizeLegibility;
  }
  ::selection {
    background: rgba(22, 130, 79, 0.18);
  }
  :focus-visible {
    outline: 3px solid rgba(47, 102, 134, 0.32);
    outline-offset: 3px;
  }
  .container { width: min(1180px, calc(100vw - 32px)); margin: 0 auto; }
  .main-content { min-height: 68vh; padding: 28px 0 58px; }
  .site-header {
    background: rgba(255, 255, 255, 0.94);
    border-top: 0;
    border-bottom: 1px solid rgba(216, 223, 219, 0.9);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(14px) saturate(130%);
  }
  .site-footer {
    background: var(--surface);
    border-top: 1px solid var(--line);
    border-bottom: 0;
  }
  .header-inner { padding: 12px 0; }
  .logo {
    color: var(--ink);
    text-decoration: none;
    font: 950 1.25rem/1 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }
  nav { display: flex; gap: 14px; }
  nav a { color: var(--muted); text-decoration: none; font-weight: 800; }
  .site-footer .container { padding: 18px 0; }
  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .site-footer nav {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .site-footer nav a {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 800;
  }
  .site-footer nav a:hover {
    color: var(--ink);
    text-decoration: underline;
  }
  .site-footer p {
    margin: 0 0 4px;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .muted { color: #63706a; }
  .meta {
    font-size: 0.9rem;
    color: #63706a;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tags a {
    font-size: 0.84rem;
    color: #214b78;
    text-decoration: none;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    border: 1px solid #d4dce7;
    background: transparent;
    padding: 4px 8px;
    border-radius: 999px;
  }
  .tags a:hover { border-color: #9bb3cf; }
  .article-card {
    background: #fff;
    border: 1px solid #dadad6;
    padding: 16px;
  }
  .article-card p { margin: 0 0 8px; color: #252525; }
  .ad-slot { min-height: 90px; border-radius: 8px; margin: 18px 0; }
  .ad-slot-disabled { border: 1px dashed #c7d3e3; background: #f3f7fc; }

  /* Global media safety for mobile screens */
  img,
  picture,
  video,
  canvas,
  svg {
    max-width: 100%;
    height: auto;
  }

  iframe {
    max-width: 100%;
  }
</style>
