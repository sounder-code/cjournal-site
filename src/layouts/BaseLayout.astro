---
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import SeoHead from '@/components/SeoHead.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const gtmId = (import.meta.env.PUBLIC_GTM_ID || 'GTM-TXMPF75Z').trim();
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {
      gtmId && (
        <script
          is:inline
          set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${gtmId}');`}
        />
      )
    }
    <SeoHead title={title} description={description} canonical={canonical} />
  </head>
  <body>
    {
      gtmId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
          ></iframe>
        </noscript>
      )
    }
    <Header />
    <main class="container main-content">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const link = target.closest('[data-affiliate-link="true"]');
        if (!(link instanceof HTMLAnchorElement)) return;

        const payload = {
          event: 'affiliate_click',
          offer_id: link.dataset.offerId || '',
          offer_title: link.dataset.offerTitle || '',
          post_slug: link.dataset.postSlug || '',
          href: link.href
        };

        const w = window as any;
        (w.dataLayer = w.dataLayer || []).push(payload);
      });
    </script>
  </body>
</html>

<style is:global>
  :root { color-scheme: light; }
  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    font-family: 'Noto Serif KR', 'Apple SD Gothic Neo', sans-serif;
    color: #111;
    background: #fff;
    line-height: 1.65;
  }
  .container { width: min(1200px, 94vw); margin: 0 auto; }
  .main-content { min-height: 68vh; padding: 24px 0 40px; }
  .site-header {
    background: #fff;
    border-top: 3px solid #1f3f67;
    border-bottom: 1px solid #d6d6d2;
  }
  .site-footer {
    background: #fff;
    border-top: 1px solid #d6d6d2;
    border-bottom: 0;
  }
  .header-inner { padding: 14px 0; }
  .logo { color: #172230; text-decoration: none; font-weight: 800; }
  nav { display: flex; gap: 14px; }
  nav a { color: #44576e; text-decoration: none; font-weight: 600; }
  .site-footer .container { padding: 18px 0; }
  .muted { color: #616161; }
  .meta {
    font-size: 0.9rem;
    color: #5a5a5a;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .tags a {
    font-size: 0.84rem;
    color: #214b78;
    text-decoration: none;
    font-family: 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    border: 1px solid #d4dce7;
    background: transparent;
    padding: 4px 8px;
    border-radius: 999px;
  }
  .tags a:hover { border-color: #9bb3cf; }
  .article-card {
    background: #fff;
    border: 1px solid #dadad6;
    padding: 16px;
  }
  .article-card p { margin: 0 0 8px; color: #252525; }
  .ad-slot { min-height: 90px; border-radius: 8px; margin: 18px 0; }
  .ad-slot-disabled { border: 1px dashed #c7d3e3; background: #f3f7fc; }

  /* Global media safety for mobile screens */
  img,
  picture,
  video,
  canvas,
  svg {
    max-width: 100%;
    height: auto;
  }

  iframe {
    max-width: 100%;
  }
</style>
