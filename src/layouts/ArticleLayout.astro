---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSense from '@/components/AdSense.astro';
import MonetizationBlock from '@/components/MonetizationBlock.astro';
import { formatDate, toDate } from '@/lib/date';

const { post } = Astro.props;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: toDate(post.data.publishedAt).toISOString(),
  dateModified: toDate(post.data.updatedAt).toISOString(),
  inLanguage: 'ko-KR',
  mainEntityOfPage: `${Astro.site}posts/${post.slug}/`,
  author: {
    '@type': 'Organization',
    name: '바로계산'
  }
};
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={`/posts/${post.slug}/`}
  type="article"
  publishedTime={toDate(post.data.publishedAt).toISOString()}
  updatedTime={toDate(post.data.updatedAt).toISOString()}
>
  <article>
    <h1>{post.data.title}</h1>
    <p class="meta">
      발행 {formatDate(post.data.publishedAt)} · 업데이트 {formatDate(post.data.updatedAt)} · {post.data.readingTimeMinutes}분
    </p>
    <AdSense slot="top" />
    <MonetizationBlock post={post} />
    <slot />
    <AdSense slot="mid" />
    <section>
      <h2>면책</h2>
      <p>
        계산 결과는 입력값을 바탕으로 한 참고용입니다.
        실제 계약, 세금, 수수료 기준은 각 제공자의 공식 안내를 확인하세요.
      </p>
    </section>
    <AdSense slot="bottom" />
  </article>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
</BaseLayout>

<style>
  article {
    max-width: 860px;
    min-width: 0;
    overflow-wrap: break-word;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--surface);
    padding: clamp(22px, 4vw, 42px);
    box-shadow: var(--shadow-sm);
  }

  article h1 {
    margin: 0 0 10px;
    color: var(--ink);
    font: 950 clamp(2rem, 5vw, 3.6rem)/1.12 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
    letter-spacing: 0;
  }

  article :global(h2) {
    margin: 34px 0 12px;
    color: var(--ink);
    font: 950 1.45rem/1.28 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }

  article :global(h3) {
    margin: 26px 0 10px;
    color: var(--ink);
    font: 900 1.18rem/1.35 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }

  article :global(p),
  article :global(li) {
    color: var(--muted);
    font: 700 1rem/1.8 'Noto Sans KR', 'Apple SD Gothic Neo', sans-serif;
  }

  article :global(p) {
    margin: 0 0 16px;
  }

  article :global(ul),
  article :global(ol) {
    margin: 0 0 18px;
    padding-left: 1.35rem;
  }

  article :global(strong) {
    color: var(--ink);
    font-weight: 950;
  }

  article img,
  article picture,
  article video,
  article canvas,
  article svg,
  article iframe {
    display: block;
    max-width: 100%;
    height: auto;
    margin-inline: auto;
    border-radius: 8px;
  }

  article figure {
    margin: 1.2rem 0;
    max-width: 100%;
  }

  article table,
  article pre {
    display: block;
    max-width: 100%;
    overflow-x: auto;
  }

  article section {
    margin-top: 32px;
    border-top: 1px solid var(--line);
    padding-top: 20px;
  }
</style>
