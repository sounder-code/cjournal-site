---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AdSense from '@/components/AdSense.astro';
import MonetizationBlock from '@/components/MonetizationBlock.astro';
import { formatDate, toDate } from '@/lib/date';

const { post } = Astro.props;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: toDate(post.data.publishedAt).toISOString(),
  dateModified: toDate(post.data.updatedAt).toISOString(),
  inLanguage: 'ko-KR',
  mainEntityOfPage: `${Astro.site}posts/${post.slug}/`,
  author: {
    '@type': 'Organization',
    name: '콘텐츠 허브'
  }
};
---
<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={`/posts/${post.slug}/`}
>
  <article>
    <h1>{post.data.title}</h1>
    <p class="meta">
      발행 {formatDate(post.data.publishedAt)} · 업데이트 {formatDate(post.data.updatedAt)} · {post.data.readingTimeMinutes}분
    </p>
    <AdSense slot="top" />
    <MonetizationBlock post={post} />
    <slot />
    <AdSense slot="mid" />
    <section>
      <h2>면책</h2>
      <p>
        본 콘텐츠는 일반적인 정보 제공 목적이며 개인 상황에 대한 의료, 법률, 금융 자문을 대체하지 않습니다.
        중요한 결정은 분야별 전문가와 상담하세요.
      </p>
    </section>
    <AdSense slot="bottom" />
  </article>
  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
</BaseLayout>

<style>
  article {
    min-width: 0;
    overflow-wrap: break-word;
  }

  article img,
  article picture,
  article video,
  article canvas,
  article svg,
  article iframe {
    display: block;
    max-width: 100%;
    height: auto;
    margin-inline: auto;
  }

  article figure {
    margin: 1.2rem 0;
    max-width: 100%;
  }

  article table,
  article pre {
    display: block;
    max-width: 100%;
    overflow-x: auto;
  }
</style>
