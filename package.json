{
  "name": "astro-seo-content-hub",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "gen:keywords": "tsx scripts/generate-keywords.ts",
    "gen:articles": "tsx scripts/generate-article.ts",
    "gen:post-images": "tsx scripts/generate-post-images.ts",
    "wash:posts": "tsx scripts/wash-posts.ts",
    "check:images": "tsx scripts/check-post-images.ts",
    "quality": "tsx scripts/quality-gate.ts",
    "build:index": "tsx scripts/build-index.ts",
    "content:publish-approved": "tsx scripts/publish-approved-content.ts",
    "data:kapt": "npm run data:kapt:download && npm run data:kapt:coordinates && npm run data:kapt:bulk",
    "data:kapt:download": "tsx scripts/download-kapt-bulk.ts",
    "data:kapt:coordinates": "tsx scripts/sync-kapt-coordinates.ts",
    "data:kapt:bulk": "tsx scripts/ingest-kapt-bulk.ts",
    "data:kapt:bulk:validate": "tsx scripts/validate-kapt-bulk.ts",
    "data:kapt:refresh:check": "tsx scripts/check-kapt-refresh.ts",
    "data:admin-centers": "tsx scripts/generate-admin-centers.ts",
    "quality:apartments": "tsx scripts/audit-apartment-pages.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f site",
    "docker:dev": "docker compose -f compose.dev.yaml up --build",
    "docker:dev:down": "docker compose -f compose.dev.yaml down",
    "docker:test": "sh scripts/docker-smoke-test.sh",
    "docker:deploy": "sh scripts/deploy-docker.sh"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.12",
    "astro": "^5.2.0",
    "exceljs": "^4.4.0",
    "gray-matter": "^4.0.3",
    "leaflet": "^1.9.4",
    "openai": "^5.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.7",
    "@types/proj4": "^2.5.6",
    "proj4": "^2.20.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
